<div class="user-wrapper">
  <h1>Create your account</h1>
  <p class="text-muted mb-4">Step 1 of 2: Tell us about yourself</p>

  <div class="alert alert-info mb-4">
    <strong>Commercial Collection Inquiry</strong><br>
    You're signing up to inquire about commercial collection services. We'll contact you within 1-2 business days to discuss your specific needs and provide custom pricing.
  </div>

  <div class="user-form mt-4"
       data-controller="form-abandonment"
       data-form-abandonment-form-name-value="commercial-inquiry-account"
       data-form-abandonment-plan-value="Commercial">
    <%= form_with model: @user, url: create_commercial_inquiry_account_path, method: :post, local: true, html: { data: { action: "submit->form-abandonment#formSubmit" } } do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:</h4>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :first_name, class: "form-label" %>
        <%= f.text_field :first_name, required: true, autofocus: true, class: "form-control", autocomplete: "given-name", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="mb-3">
        <%= f.label :last_name, class: "form-label" %>
        <%= f.text_field :last_name, required: true, class: "form-control", autocomplete: "family-name", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, required: true, class: "form-control", autocomplete: "email", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="mb-3">
        <%= f.label :phone_number, class: "form-label" %>
        <%= f.telephone_field :phone_number, required: true, class: "form-control", autocomplete: "tel", placeholder: "e.g., 0821234567", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, required: true, class: "form-control", autocomplete: "new-password", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
        <small class="form-text text-muted">6 characters minimum</small>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
        <%= f.password_field :password_confirmation, required: true, class: "form-control", autocomplete: "new-password", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="form-actions mt-4">
        <%= f.submit "Continue to Business Details", class: 'submit-btn' %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= link_to "Already have an account? Log in", new_user_session_path %>
    </div>
  </div>
</div>
