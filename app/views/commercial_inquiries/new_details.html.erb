<div class="user-wrapper">
  <h1>Tell us about your business</h1>
  <p class="text-muted mb-4">Step 2 of 2: Help us understand your collection needs</p>

  <div class="user-form mt-4"
       data-controller="form-abandonment"
       data-form-abandonment-form-name-value="commercial-inquiry-details"
       data-form-abandonment-plan-value="Commercial">
    <%= form_with model: @inquiry, url: create_commercial_inquiries_path, method: :post, local: true, html: { data: { action: "submit->form-abandonment#formSubmit" } } do |f| %>
      <% if @inquiry && @inquiry.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@inquiry.errors.count, "error") %> prohibited this inquiry from being saved:</h4>
          <ul>
            <% @inquiry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <h3 class="mb-3">Business Information</h3>

      <div class="mb-3">
        <%= f.label :business_name, class: "form-label" %>
        <%= f.text_field :business_name, required: true, class: "form-control", placeholder: "e.g., Green Leaf Café", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="mb-3">
        <%= f.label :business_address, class: "form-label" %>
        <%= f.text_area :business_address, required: true, class: "form-control", rows: 3, placeholder: "Full business address including street, suburb, and postal code", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <h3 class="mb-3 mt-4">Collection Requirements</h3>

      <div class="mb-3">
        <%= f.label :estimated_buckets, "How many 45L buckets per collection?", class: "form-label" %>
        <%= f.number_field :estimated_buckets, required: true, min: 1, max: 50, class: "form-control", placeholder: "Estimate your weekly volume", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
        <small class="form-text text-muted">Don't worry, this is just an estimate to help us prepare</small>
      </div>

      <div class="mb-3">
        <%= f.label :collection_frequency, "How often do you need collection?", class: "form-label" %>
        <%= f.select :collection_frequency,
            options_for_select(CommercialInquiry::COLLECTION_FREQUENCIES),
            { prompt: "Select frequency" },
            { required: true, class: "form-select", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } } %>
      </div>

      <div class="mb-3">
        <%= f.label :preferred_duration, "Preferred contract length (months)", class: "form-label" %>
        <%= f.select :preferred_duration,
            options_for_select([[3, 3], [6, 6], [12, 12]]),
            { prompt: "Select duration" },
            { required: true, class: "form-select", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } } %>
        <small class="form-text text-muted">Longer contracts typically receive better rates</small>
      </div>

      <div class="mb-3">
        <%= f.label :additional_notes, "Additional information (optional)", class: "form-label" %>
        <%= f.text_area :additional_notes, class: "form-control", rows: 4, placeholder: "Any special requirements, access instructions, or questions?", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div class="form-actions mt-4">
        <%= f.submit "Submit Inquiry", class: 'submit-btn' %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= link_to "← Back to account details", new_commercial_inquiry_account_path %>
    </div>
  </div>
</div>
