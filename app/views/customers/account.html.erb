<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-user"></i>
      </div>
      <div>
        <h1>My Account</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          <%= current_user.email %>
        </p>
      </div>
    </div>
  </div>

  <!-- Personal Details -->
  <div class="info-card mb-3">
    <div class="info-card-header">
      <i class="fa-solid fa-id-card"></i>
      <h3>Personal Details</h3>
    </div>
    <div class="info-card-body">
      <%= simple_form_for @user, url: user_registration_path, html: { method: :put } do |f| %>
        <%= f.input :first_name, label: "First name" %>
        <%= f.input :last_name, label: "Last name" %>
        <%= f.input :email, label: "Email" %>
        <%= f.input :phone_number, label: "Phone number", hint: "International format preferred (e.g. +27 82 555 1234)" %>
        <%= f.button :submit, "Save", class: "tiny-yellow-btn mt-2" %>
      <% end %>
    </div>
  </div>

  <!-- Password -->
  <div class="info-card mb-3">
    <div class="info-card-header">
      <i class="fa-solid fa-lock"></i>
      <h3>Change Password</h3>
    </div>
    <div class="info-card-body">
      <%= simple_form_for @user, url: user_registration_path, html: { method: :put } do |f| %>
        <%= f.input :password, label: "New password", hint: "Leave blank to keep your current password" %>
        <%= f.input :password_confirmation, label: "Confirm new password" %>
        <%= f.input :current_password, label: "Current password" %>
        <%= f.button :submit, "Update password", class: "tiny-yellow-btn mt-2" %>
      <% end %>
    </div>
  </div>

  <!-- Address -->
  <% if @subscription %>
    <div class="info-card mb-3">
      <div class="info-card-header">
        <i class="fa-solid fa-location-dot"></i>
        <h3>Collection Address</h3>
      </div>
      <div class="info-card-body">
        <%= simple_form_for @subscription do |f| %>
          <div data-controller="address-autocomplete"
               data-address-autocomplete-api-key-value="<%= ENV['MAPBOX_API_KEY'] %>">
            <%= f.input :street_address,
                        input_html: { data: { address_autocomplete_target: "address" }, class: "d-none" },
                        label: "Street address" %>
          </div>
          <br>
          <%= f.input :suburb,
                      as: :select,
                      collection: Subscription::SUBURBS,
                      prompt: "Select a suburb" %>
          <%= f.input :access_code, label: "Access code", hint: "Gate code or special access instructions" %>
          <%= f.button :submit, "Save address", class: "tiny-yellow-btn mt-2" %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
