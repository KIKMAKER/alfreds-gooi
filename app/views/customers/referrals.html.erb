<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-gift"></i>
      </div>
      <div>
        <h1>Refer a Friend</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          Earn R50 off for each person you refer
        </p>
      </div>
    </div>
  </div>

  <% if @no_subscription %>

    <div class="info-card text-center">
      <div class="info-card-body" style="padding: 2.5rem 1.5rem;">
        <%= image_tag 'Alfred Sticker.svg', class: 'avatar-large mb-3' %>
        <h3>Subscribe to get your referral code</h3>
        <p class="text-muted mb-0">Once you're gooiing, you'll get a personal code to share. For every friend who subscribes using it, you earn R50 off your next renewal.</p>
      </div>
    </div>

  <% else %>

    <!-- Your code card -->
    <div class="info-card mb-3">
      <div class="info-card-header">
        <i class="fa-solid fa-tag"></i>
        <h3>Your referral code</h3>
      </div>
      <div class="info-card-body text-center" style="padding: 1.5rem;">
        <div class="referral-code-display mb-1"><%= @referral_code %></div>
        <p class="text-muted small mb-4">Share this with friends — they get a discount, you earn R50 off your next subscription.</p>
        <%= link_to @whatsapp_link, target: "_blank", class: "action-btn" do %>
          <i class="fa-brands fa-whatsapp"></i> Share on WhatsApp
        <% end %>
      </div>
    </div>

    <!-- Message preview -->
    <div class="info-card mb-3">
      <div class="info-card-header">
        <i class="fa-regular fa-comment"></i>
        <h3>Your share message</h3>
      </div>
      <div class="info-card-body">
        <p class="text-muted small mb-0" style="line-height: 1.6; font-style: italic;">"<%= @message %>"</p>
      </div>
    </div>

    <!-- Referrals earned -->
    <% if @referral_count > 0 %>
      <div class="info-card mb-3">
        <div class="info-card-header">
          <i class="fa-solid fa-circle-check" style="color: #3c8a63;"></i>
          <h3>Your referrals</h3>
        </div>
        <div class="info-card-body">
          <% @referrals.each do |referral| %>
            <div class="info-row">
              <span class="info-label"><%= referral.referee.first_name %></span>
              <span class="info-value" style="color: #3c8a63;">R50 earned</span>
            </div>
          <% end %>
          <div class="mt-3 p-3" style="background: #f0faf4; border-radius: 12px; border: 1px solid #84cba3;">
            <p class="mb-0" style="color: #023F3A; font-weight: 600;">
              Total: R<%= @referral_count * 50 %> off your next subscription
            </p>
          </div>
        </div>
      </div>
    <% end %>

  <% end %>

</div>
