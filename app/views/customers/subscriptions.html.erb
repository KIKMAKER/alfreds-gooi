<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-file-contract"></i>
      </div>
      <div>
        <h1>My Subscriptions</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          <%= @subscriptions.count %> subscription<%= @subscriptions.count == 1 ? '' : 's' %>
        </p>
      </div>
    </div>
    <%= link_to statement_path(current_user), class: "tiny-yellow-btn",
                style: "background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); color: white; white-space: nowrap;" do %>
      <i class="fa-solid fa-file-lines"></i> Statement
    <% end %>
  </div>

  <% if @subscriptions.any? %>
    <% @subscriptions.each do |sub| %>
      <div class="info-card mb-3">
        <div class="info-card-header">
          <i class="fa-solid fa-location-dot"></i>
          <div style="flex: 1; min-width: 0;">
            <h3 style="margin: 0; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= sub.short_address %>
            </h3>
            <div style="font-size: 0.8rem; color: #666; font-family: 'Montserrat', sans-serif;">
              <%= sub.suburb %>
            </div>
          </div>
          <%
            badge_class = case sub.status
                          when 'active'    then 'active'
                          when 'pending'   then 'pending'
                          when 'pause'     then 'paused'
                          when 'completed' then 'completed'
                          else 'completed'
                          end
          %>
          <span class="subscription-status-badge <%= badge_class %>"><%= sub.status.titleize %></span>
        </div>

        <div class="info-card-body">
          <div class="info-row">
            <span class="info-label">Plan</span>
            <span class="info-value"><%= sub.plan %></span>
          </div>
          <div class="info-row">
            <span class="info-label">Duration</span>
            <span class="info-value"><%= sub.duration %> month<%= sub.duration > 1 ? 's' : '' %></span>
          </div>
          <div class="info-row">
            <span class="info-label">Period</span>
            <span class="info-value">
              <%= sub.start_date ? sub.start_date.strftime("%d %b %Y") : "TBD" %> –
              <%= sub.end_date   ? sub.end_date.strftime("%d %b %Y")   : "TBD" %>
            </span>
          </div>
          <div class="info-row">
            <span class="info-label">Collections</span>
            <span class="info-value"><%= sub.total_collections %> done</span>
          </div>
          <% if sub.XL? || sub.Commercial? %>
            <div class="info-row">
              <span class="info-label">Buckets collected</span>
              <span class="info-value"><%= sub.total_bags %></span>
            </div>
          <% else %>
            <div class="info-row">
              <span class="info-label">Bags collected</span>
              <span class="info-value"><%= sub.total_bags %></span>
            </div>
          <% end %>

          <% if sub.monthly_invoicing? %>
            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #f0f0f0;">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="info-label">Contract progress</span>
                <span class="info-label">R<%= number_with_delimiter(sub.amount_invoiced.to_i) %> / R<%= number_with_delimiter(sub.contract_total.to_i) %></span>
              </div>
              <div class="progress" style="height: 8px; border-radius: 50px;">
                <div class="progress-bar" role="progressbar"
                     style="width: <%= sub.invoicing_progress_percentage %>%; background: linear-gradient(90deg, #3c8a63, #108A63);"
                     aria-valuenow="<%= sub.invoicing_progress_percentage %>"
                     aria-valuemin="0" aria-valuemax="100">
                </div>
              </div>
            </div>
          <% end %>

          <% if sub.invoices.any? %>
            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #f0f0f0;">
              <% sub.invoices.order(issued_date: :desc).each do |invoice| %>
                <%= link_to invoice_path(invoice), class: "d-flex justify-content-between align-items-center mb-2", style: "text-decoration: none;" do %>
                  <span style="font-size: 0.875rem; color: #023F3A; font-weight: 500;">
                    Invoice #<%= invoice.number || invoice.id %>
                  </span>
                  <div class="d-flex align-items-center gap-2">
                    <span style="font-size: 0.875rem; color: #666;">R<%= number_with_delimiter(invoice.total_amount.to_i) %></span>
                    <% if invoice.paid %>
                      <span class="subscription-status-badge active" style="font-size: 0.75rem; padding: 2px 8px;">Paid</span>
                    <% else %>
                      <span class="subscription-status-badge paused" style="font-size: 0.75rem; padding: 2px 8px;">Unpaid</span>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= link_to new_subscription_path, class: "action-btn" do %>
      <i class="fa-solid fa-plus"></i> Add subscription
    <% end %>

  <% else %>
    <div class="info-card text-center">
      <div class="info-card-body" style="padding: 2.5rem 1.5rem;">
        <i class="fa-solid fa-file-contract" style="font-size: 3rem; color: #ccc; display: block; margin-bottom: 1rem;"></i>
        <h3>No subscriptions yet</h3>
        <p class="text-muted mb-4">Get started with a weekly compost collection.</p>
        <%= link_to "View Plans", new_subscription_path, class: "action-btn" %>
      </div>
    </div>
  <% end %>

</div>
