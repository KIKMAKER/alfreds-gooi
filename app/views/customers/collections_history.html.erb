<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-clock-rotate-left"></i>
      </div>
      <div>
        <h1>All Collections</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          <%= @total %> total
        </p>
      </div>
    </div>
    <%= link_to my_stats_path, class: "tiny-yellow-btn",
                style: "background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); color: white; white-space: nowrap;" do %>
      <i class="fa-solid fa-arrow-left"></i> Back
    <% end %>
  </div>

  <% if @collections.any? %>
    <div class="info-card mb-3">
      <div class="info-card-body">
        <% @collections.each do |c| %>
          <div class="info-row">
            <span class="info-label"><%= c.date&.strftime('%d %b %Y') %></span>
            <span class="info-value" style="<%= c.skip ? 'color: #aaa; font-weight: 400;' : '' %>">
              <% if c.skip %>
                Skipped
              <% else %>
                <% parts = [] %>
                <% if c.buckets_45l.to_i > 0 || c.buckets_25l.to_i > 0 %>
                  <% parts << "#{c.buckets_45l} × 45L" if c.buckets_45l.to_i > 0 %>
                  <% parts << "#{c.buckets_25l} × 25L" if c.buckets_25l.to_i > 0 %>
                <% elsif c.buckets&.positive? %>
                  <% size = c.subscription&.bucket_size || 45 %>
                  <% parts << "#{c.buckets.to_i} × #{size}L" %>
                <% end %>
                <% if c.bags&.positive? %>
                  <% parts << "#{c.bags} bag#{c.bags == 1 ? '' : 's'}" %>
                <% end %>
                <%= parts.any? ? parts.join(", ") : "Upcoming" %>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <% if @total_pages > 1 %>
      <div class="d-flex justify-content-center align-items-center gap-3">
        <% if @page > 1 %>
          <%= link_to collections_history_path(page: @page - 1, per: @per), class: "action-btn" do %>
            <i class="fa-solid fa-arrow-left"></i> Previous
          <% end %>
        <% end %>
        <span class="text-muted small">Page <%= @page %> of <%= @total_pages %></span>
        <% if @page < @total_pages %>
          <%= link_to collections_history_path(page: @page + 1, per: @per), class: "action-btn" do %>
            Next <i class="fa-solid fa-arrow-right"></i>
          <% end %>
        <% end %>
      </div>
    <% end %>

  <% else %>
    <div class="info-card text-center">
      <div class="info-card-body" style="padding: 2.5rem 1.5rem;">
        <i class="fa-regular fa-calendar" style="font-size: 3rem; color: #ccc; display: block; margin-bottom: 1rem;"></i>
        <p class="text-muted mb-0">No collections yet.</p>
      </div>
    </div>
  <% end %>

</div>
