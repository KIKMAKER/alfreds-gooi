<div class="user-wrapper">
  <h1>Confirm your subscription details</h1>

  <div class="signup-progress mb-4">
    <div class="progress-steps">
      <div class="progress-step completed">
        <div class="step-number">✓</div>
        <div class="step-label">Account</div>
      </div>
      <div class="progress-connector"></div>
      <div class="progress-step active">
        <div class="step-number">2</div>
        <div class="step-label">Address</div>
      </div>
    </div>
  </div>

  <% if @plan.present? && @duration.present? %>
    <div class="alert alert-info mb-4">
      <strong>Selected Plan:</strong> <%= @plan %> - <%= @duration %> month<%= @duration.to_i > 1 ? 's' : '' %>
      <% if @discount_code.present? %>
        <br><strong>Discount Code:</strong> <%= @discount_code %>
      <% elsif @referral_code.present? %>
        <br><strong>Referral Code:</strong> <%= @referral_code %> (15% off)
      <% end %>
    </div>
  <% end %>

  <div class="user-form mt-4"
       data-controller="form-abandonment"
       data-form-abandonment-form-name-value="signup-subscription"
       data-form-abandonment-plan-value="<%= @plan %>"
       data-form-abandonment-duration-value="<%= @duration %>">
    <%= form_with model: @subscription, url: create_subscription_path, method: :post, local: true, html: { data: { action: "submit->form-abandonment#formSubmit" } } do |f| %>
      <% if @subscription && @subscription.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@subscription.errors.count, "error") %> prohibited this subscription from being saved:</h4>
          <ul>
            <% @subscription.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <h3 class="mb-3">Pick Up Location</h3>

      <div class="mb-3">
        <%= f.label :suburb, class: "form-label" %>
        <%= f.select :suburb,
            options_for_select(Subscription::SUBURBS, @subscription&.suburb),
            { prompt: "Select a suburb" },
            { required: true, class: "form-select", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } } %>
      </div>

      <div class="mb-3">
        <%= f.label :apartment_unit_number, "Building name and unit number (if relevant)", class: "form-label" %>
        <%= f.text_field :apartment_unit_number, class: "form-control", placeholder: "e.g Unit 1 Garden View", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <div data-controller="address-autocomplete" data-address-autocomplete-api-key-value="<%= ENV['MAPBOX_API_KEY'] %>">
        <%= f.label :street_address, "Street Address", class: "form-label street-label" %>
        <%= f.text_field :street_address,
            required: true,
            class: "d-none",
            data: { address_autocomplete_target: "address", form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
      </div>

      <% if @plan != 'Commercial' %>
        <div class="mt-4 p-3 bg-light rounded">
          <p class="mb-2"><strong>Optional:</strong> Have a referral or discount code?</p>

          <div class="mb-3">
            <%= label_tag :referral_code, "Referral Code", class: "form-label" %>
            <%= text_field_tag :referral_code, @referral_code, class: "form-control", placeholder: "Enter friend's code for 15% off", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
          </div>

          <p class="text-center mb-2">or</p>

          <div class="mb-0">
            <%= label_tag :discount_code, "Discount Code", class: "form-label" %>
            <%= text_field_tag :discount_code, @discount_code, class: "form-control", placeholder: "Enter your discount code", data: { form_abandonment_target: "field", action: "focus->form-abandonment#fieldFocus blur->form-abandonment#fieldBlur" } %>
          </div>
        </div>
      <% end %>

      <div class="form-actions mt-4">
        <%= f.submit "Complete Signup", class: 'submit-btn' %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= link_to "← Back to account details", new_account_signup_path(
        plan: @plan,
        duration: @duration,
        discount_code: @discount_code,
        referral: @referral_code
      ) %>
    </div>
  </div>
</div>
