<div class="user-wrapper">
  <h1>Create your account</h1>

  <div class="signup-progress mb-4">
    <div class="progress-steps">
      <div class="progress-step active">
        <div class="step-number">1</div>
        <div class="step-label">Account</div>
      </div>
      <div class="progress-connector"></div>
      <div class="progress-step">
        <div class="step-number">2</div>
        <div class="step-label">Address</div>
      </div>
    </div>
  </div>

  <% if @plan.present? && @duration.present? %>
    <div class="alert alert-info mb-4">
      <strong>Selected Plan:</strong> <%= @plan %> - <%= @duration %> month<%= @duration.to_i > 1 ? 's' : '' %>
      <% if @discount_code.present? %>
        <br><strong>Discount Code:</strong> <%= @discount_code %>
      <% elsif @referral_code.present? %>
        <br><strong>Referral Code:</strong> <%= @referral_code %> (15% off)
      <% end %>
    </div>
  <% end %>

  <div class="user-form mt-4">
    <%= form_with model: @user, url: create_account_signup_path, method: :post, local: true do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:</h4>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :first_name, class: "form-label" %>
        <%= f.text_field :first_name, required: true, autofocus: true, class: "form-control", autocomplete: "given-name" %>
      </div>

      <div class="mb-3">
        <%= f.label :last_name, class: "form-label" %>
        <%= f.text_field :last_name, required: true, class: "form-control", autocomplete: "family-name" %>
      </div>

      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, required: true, class: "form-control", autocomplete: "email" %>
      </div>

      <div class="mb-3">
        <%= f.label :phone_number, class: "form-label" %>
        <%= f.telephone_field :phone_number, required: true, class: "form-control", autocomplete: "tel", placeholder: "e.g., 0821234567" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, required: true, class: "form-control", autocomplete: "new-password" %>
        <small class="form-text text-muted">6 characters minimum</small>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
        <%= f.password_field :password_confirmation, required: true, class: "form-control", autocomplete: "new-password" %>
      </div>

      <div class="form-actions mt-4">
        <%= f.submit "Continue to Address Details", class: 'submit-btn' %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= link_to "Already have an account? Log in", new_user_session_path %>
    </div>
  </div>
</div>
