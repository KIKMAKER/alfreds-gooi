<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-cart-shopping"></i>
      </div>
      <div>
        <h1>Order</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          Delivered with your next collection
        </p>
      </div>
    </div>
  </div>

  <% if @products.any? %>
    <% @products.each do |product| %>
      <div class="info-card mb-3">
        <% if product.primary_image %>
          <div style="width: 100%; height: 220px; overflow: hidden; border-radius: 16px 16px 0 0;">
            <%= image_tag product.primary_image,
                          alt: product.title,
                          style: "width: 100%; height: 100%; object-fit: cover;" %>
          </div>
        <% end %>
        <div class="info-card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h3 style="margin: 0; font-size: 1rem; font-family: 'Montserrat', sans-serif; font-weight: 700; color: #023F3A;">
              <%= product.title %>
            </h3>
            <span style="font-size: 1.1rem; font-weight: 700; color: #3c8a63; font-family: 'Montserrat', sans-serif; white-space: nowrap; margin-left: 1rem;">
              R<%= product.price.to_i %>
            </span>
          </div>

          <% if product.description.present? %>
            <p style="color: #666; font-size: 0.875rem; line-height: 1.5; margin-bottom: 1rem;">
              <%= product.description %>
            </p>
          <% end %>

          <% if product.in_stock? %>
            <div class="d-flex align-items-center justify-content-between" style="border-top: 1px solid #f0f0f0; padding-top: 1rem;">
              <small class="text-muted"><%= product.stock %> in stock</small>
              <%= form_with url: add_to_order_path, method: :post, local: true do |f| %>
                <%= f.hidden_field :product_id, value: product.id %>
                <div class="d-flex align-items-center gap-2">
                  <%= f.number_field :quantity, value: 1, min: 1, max: product.stock,
                      class: "form-control text-center",
                      style: "width: 64px; border-radius: 50px; border-color: #e0e0e0;" %>
                  <%= f.submit "Add to order", class: "tiny-yellow-btn" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div style="border-top: 1px solid #f0f0f0; padding-top: 1rem;">
              <span style="color: #bc4749; font-size: 0.875rem; font-weight: 600;">Out of stock</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="info-card text-center">
      <div class="info-card-body" style="padding: 2.5rem 1.5rem;">
        <i class="fa-solid fa-box-open" style="font-size: 3rem; color: #ccc; display: block; margin-bottom: 1rem;"></i>
        <p class="text-muted mb-0">No products available at the moment. Check back soon!</p>
      </div>
    </div>
  <% end %>

  <!-- Current order -->
  <% if @current_order&.order_items&.any? %>
    <div class="info-card mt-4">
      <div class="info-card-header">
        <i class="fa-solid fa-basket-shopping"></i>
        <h3>Your Order</h3>
      </div>
      <div class="info-card-body">
        <% @current_order.order_items.each do |item| %>
          <div class="info-row">
            <span class="info-label"><%= item.product.title %></span>
            <div class="d-flex align-items-center gap-3">
              <span class="info-value"><%= item.quantity %> × R<%= item.price.to_i %></span>
              <%= button_to remove_from_order_path(item), method: :delete,
                            class: "btn btn-sm p-0 border-0 bg-transparent",
                            style: "color: #bc4749; font-size: 0.85rem;" do %>
                <i class="fa-solid fa-xmark"></i>
              <% end %>
            </div>
          </div>
        <% end %>

        <div style="border-top: 1px solid #f0f0f0; padding-top: 1rem; margin-top: 0.5rem;" class="d-flex justify-content-between align-items-center">
          <span style="font-weight: 700; color: #023F3A; font-family: 'Montserrat', sans-serif;">
            Total: R<%= @current_order.total_amount.to_i %>
          </span>
          <%= link_to "Checkout", checkout_order_path(@current_order), class: "tiny-yellow-btn" %>
        </div>
      </div>
    </div>
  <% end %>

</div>
