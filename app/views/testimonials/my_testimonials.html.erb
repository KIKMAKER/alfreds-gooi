<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-star"></i>
      </div>
      <div>
        <h1>My Feedback</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          Your shared feedback
        </p>
      </div>
    </div>
    <%= link_to new_testimonial_path, class: "tiny-yellow-btn",
                style: "background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); color: white; white-space: nowrap;" do %>
      <i class="fa-solid fa-plus"></i> Add New
    <% end %>
  </div>

  <% if @testimonials.any? %>
    <% @testimonials.each do |testimonial| %>
      <div class="info-card mb-3">
        <div class="info-card-header">
          <i class="fa-solid fa-quote-left"></i>
          <div style="flex: 1;">
            <h3 style="margin: 0; font-size: 0.9rem;">
              <%= testimonial.created_at.strftime("%d %b %Y") %>
            </h3>
          </div>
          <% if testimonial.public %>
            <span class="subscription-status-badge active">Public</span>
          <% else %>
            <span class="subscription-status-badge completed">Private</span>
          <% end %>
        </div>

        <div class="info-card-body">
          <% if testimonial.photo.attached? %>
            <div style="width: 100%; height: 200px; border-radius: 10px; overflow: hidden; margin-bottom: 1rem;">
              <%= image_tag testimonial.photo,
                            alt: "Your photo",
                            style: "width: 100%; height: 100%; object-fit: cover;" %>
            </div>
          <% end %>

          <p style="font-style: italic; color: #444; line-height: 1.6; margin-bottom: 1.25rem;">
            "<%= testimonial.content %>"
          </p>

          <div class="d-flex gap-2 align-items-center flex-wrap" style="border-top: 1px solid #f0f0f0; padding-top: 1rem;">
            <%= form_with model: testimonial, method: :patch, local: true, class: "d-inline" do |f| %>
              <%= f.hidden_field :public, value: !testimonial.public %>
              <%= f.submit testimonial.public ? "Make Private" : "Make Public",
                           class: "action-btn",
                           style: "font-size: 0.8rem; padding: 0.35rem 0.875rem;" %>
            <% end %>
            <span class="text-muted small ms-auto">
              <% if testimonial.public %>
                <i class="fa-solid fa-eye"></i> Visible on gooi.me
              <% else %>
                <i class="fa-solid fa-eye-slash"></i> Only visible to Gooi team
              <% end %>
            </span>
          </div>
        </div>
      </div>
    <% end %>

  <% else %>
    <div class="info-card text-center">
      <div class="info-card-body" style="padding: 2.5rem 1.5rem;">
        <i class="fa-regular fa-comment" style="font-size: 3rem; color: #ccc; display: block; margin-bottom: 1rem;"></i>
        <h3>No feedback yet</h3>
        <p class="text-muted mb-4">Share your Gooi experience — it helps us grow and inspires others to join!</p>
        <%= link_to "Write a Testimonial", new_testimonial_path, class: "action-btn" %>
      </div>
    </div>
  <% end %>

</div>
