<div class="user-wrapper">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Customer Testimonials</h1>
      <p class="text-muted">Manage customer feedback and toggle public visibility</p>
    </div>
    <div>
      <%= link_to "New Testimonial", new_testimonial_path, class: "small-yellow-btn" %>
    </div>
  </div>

  <% if @testimonials.any? %>
    <div class="row g-4">
      <% @testimonials.each do |testimonial| %>
        <div class="col-md-6 col-lg-4">
          <div class="testimonial-admin-card h-100 <%= 'public-testimonial' if testimonial.public %>">
            <div class="testimonial-admin-header">
              <div>
                <h5><%= testimonial.user.first_name || testimonial.user.email %></h5>
                <small class="text-muted">
                  <%= testimonial.created_at.strftime('%b %d, %Y') %>
                </small>
              </div>
              <span class="badge <%= testimonial.public ? 'bg-success' : 'bg-secondary' %>">
                <%= testimonial.public ? 'Public' : 'Private' %>
              </span>
            </div>

            <% if testimonial.photo.attached? %>
              <div class="testimonial-admin-photo">
                <%= image_tag testimonial.photo, alt: "#{testimonial.user.first_name}'s photo" %>
              </div>
            <% end %>

            <p class="testimonial-admin-content">"<%= testimonial.content %>"</p>

            <div class="testimonial-admin-actions">
              <%= form_with(model: testimonial, method: :patch, local: true, class: "d-inline") do |f| %>
                <%= f.hidden_field :public, value: !testimonial.public %>
                <%= f.submit (testimonial.public ? "Make Private" : "Make Public"),
                    class: "small-yellow-btn" %>
              <% end %>

              <%= button_to "Delete", testimonial_path(testimonial),
                  method: :delete,
                  data: { turbo_confirm: "Are you sure you want to delete this testimonial?" },
                  class: "link-title text-danger" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="outline p-4 text-center">
      <p class="mb-3">No testimonials yet. Share the testimonial form with your customers!</p>
      <%= link_to "Create Test Testimonial", new_testimonial_path, class: "small-yellow-btn" %>
    </div>
  <% end %>
</div>

<style>
.testimonial-admin-card {
  background: white;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.testimonial-admin-card.public-testimonial {
  border-color: #28a745;
}

.testimonial-admin-card:hover {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  transform: translateY(-2px);
}

.testimonial-admin-header {
  display: flex;
  justify-content: space-between;
  align-items: start;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 2px solid #f0f0f0;
}

.testimonial-admin-header h5 {
  margin: 0;
  font-size: 18px;
  color: #333;
}

.testimonial-admin-photo {
  width: 100%;
  height: 200px;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 16px;
}

.testimonial-admin-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.testimonial-admin-content {
  font-style: italic;
  color: #555;
  line-height: 1.6;
  margin-bottom: 16px;
  min-height: 80px;
}

.testimonial-admin-actions {
  display: flex;
  gap: 12px;
  align-items: center;
  padding-top: 12px;
  border-top: 2px solid #f0f0f0;
}
</style>
