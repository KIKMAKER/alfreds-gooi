<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-regular fa-comment"></i>
      </div>
      <div>
        <h1>Share your experience</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          Your feedback helps us improve and grow
        </p>
      </div>
    </div>
  </div>

  <div class="info-card">
    <div class="info-card-body">
      <%= simple_form_for @testimonial do |f| %>
        <%= f.error_notification %>

        <%= f.input :content,
            label: "Your testimonial",
            hint: "<span id='char-count'>0</span> / 500 characters".html_safe,
            input_html: {
              rows: 8,
              placeholder: "What has your experience with Gooi been like?",
              maxlength: 500,
              class: 'form-control'
            } %>

        <%= f.input :photo,
            as: :file,
            label: "Add a photo (optional)",
            hint: "A photo of your setup, garden, or anything related. Max 5MB.",
            input_html: { accept: "image/*" } %>

        <%= f.input :public,
            as: :boolean,
            label: "Make this testimonial public",
            hint: "Public testimonials may appear on our website or socials. If unchecked, only the Gooi team will see it." %>

        <div class="d-flex gap-3 mt-3">
          <%= f.button :submit, "Submit", class: "tiny-yellow-btn" %>
          <%= link_to "Cancel", manage_path, class: "link-title" %>
        </div>
      <% end %>
    </div>
  </div>

</div>

<script>
  document.addEventListener('turbo:load', function() {
    const textarea = document.querySelector('textarea[name="testimonial[content]"]');
    const counter = document.getElementById('char-count');
    if (textarea && counter) {
      textarea.addEventListener('input', function() { counter.textContent = this.value.length; });
      counter.textContent = textarea.value.length;
    }
  });
</script>
