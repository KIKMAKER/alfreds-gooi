<% content_for :meta_title, "Blog – Gooi Compost Collection Cape Town" %>
<% content_for :meta_description, "Tips, stories, and composting guides from the Gooi team. Learn what to compost, how it works, and what happens to your food scraps." %>

<div class="page-container">
  <section class="map-section">
    <div class="container" style="max-width: 900px;">
      <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
          <li class="breadcrumb-item active" aria-current="page">Blog</li>
        </ol>
      </nav>

      <h1 class="mb-2">The Gooi Blog</h1>
      <p class="mb-5">Composting tips, community stories, and updates from the bakkie.</p>

      <% if @posts.any? %>
        <div class="blog-post-list">
          <% @posts.each do |post| %>
            <%= link_to post_path(post), class: "blog-post-card" do %>
              <% if post.cover_image_url.present? %>
                <div class="blog-post-card__image">
                  <img src="<%= post.cover_image_url %>" alt="<%= post.title %>">
                </div>
              <% end %>
              <div class="blog-post-card__body">
                <p class="blog-post-card__date"><%= post.published_at&.strftime("%-d %B %Y") %></p>
                <h3 class="blog-post-card__title"><%= post.title %></h3>
                <% if post.excerpt.present? %>
                  <p class="blog-post-card__excerpt"><%= post.excerpt %></p>
                <% end %>
                <span class="blog-post-card__cta">Read more →</span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <p class="text-muted">No posts yet — check back soon.</p>
        </div>
      <% end %>
    </div>
  </section>
</div>
