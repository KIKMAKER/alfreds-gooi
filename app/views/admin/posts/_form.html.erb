<%= simple_form_for [:admin, @post] do |f| %>
  <%= f.error_notification %>

  <%= f.input :title, input_html: { class: "form-control" } %>
  <%= f.input :slug, hint: "Auto-generated from title. Edit to customise the URL.", input_html: { class: "form-control" } %>
  <%= f.input :excerpt, input_html: { class: "form-control", rows: 3 }, hint: "Short summary shown on the blog index." %>
  <%= f.input :body, as: :text, input_html: { class: "form-control font-monospace", rows: 20 },
      hint: "Markdown. ## Heading → section title with yellow dot. > blockquote → styled pullquote. ![Caption](url) → full-width image. First paragraph is auto-styled as a lede." %>
  <div class="mb-3">
    <label class="form-label fw-semibold">Cover image</label>

    <% if @post.cover_image.attached? %>
      <div class="mb-2">
        <%= image_tag @post.cover_image, class: "img-thumbnail", style: "max-height: 180px;" %>
        <p class="text-muted small mt-1">Upload a new file below to replace this image.</p>
      </div>
    <% end %>

    <%= f.input :cover_image, as: :file, label: "Upload a file",
        input_html: { class: "form-control", accept: "image/*" },
        hint: "JPG or PNG. Will be used as the post header background." %>

    <%= f.input :cover_image_url, label: "Or paste an image URL",
        input_html: { class: "form-control" },
        hint: "Used if no file is uploaded. Uploaded file takes priority." %>
  </div>

  <div class="mt-3">
    <%= f.input :published, as: :boolean, label: "Publish this post?" %>
  </div>

  <div class="mt-4">
    <%= f.submit class: "btn-gooi" %>
    <%= link_to "Cancel", admin_posts_path, class: "ms-3" %>
  </div>
<% end %>
