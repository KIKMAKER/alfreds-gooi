<div class="page-container">
  <div class="container py-4">

    <%# ── Header ──────────────────────────────────────────────────── %>
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <h1><%= @block.name %></h1>
        <p class="text-muted mb-0">
          <code>/blocks/<%= @block.slug %></code>
          &nbsp;·&nbsp;
          <%= link_to "View public page →", block_path(@block.slug), target: "_blank", class: "text-decoration-none" %>
        </p>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "Edit", edit_admin_block_path(@block), class: "btn btn-sm btn-outline-secondary" %>
        <%= link_to "Delete", admin_block_path(@block),
              class: "btn btn-sm btn-outline-danger",
              data: { turbo_method: :delete, turbo_confirm: "Delete this block? All subscriptions will be unlinked." } %>
      </div>
    </div>

    <%# ── Stats row — use pre-computed ivars; no repeated DB hits ─── %>
    <div class="row g-3 mb-5">
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-1">This Week</h6>
            <p class="mb-1"><strong>Expected:</strong> <%= @stat_expected_l %>L</p>
            <p class="mb-1"><strong>Collected:</strong> <%= @stat_week_l %>L</p>
            <p class="mb-0 text-muted small">
              ~<%= @block.weight_kg(@stat_week_l) %>kg &nbsp;·&nbsp;
              ~<%= @block.co2e_kg(@stat_week_l) %>kg CO₂e saved
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-1">This Month</h6>
            <p class="mb-1"><strong>Collected:</strong> <%= @stat_month_l %>L</p>
            <p class="mb-0 text-muted small">
              ~<%= @block.weight_kg(@stat_month_l) %>kg &nbsp;·&nbsp;
              ~<%= @block.co2e_kg(@stat_month_l) %>kg CO₂e saved
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-1">All Time</h6>
            <p class="mb-1"><strong>Collected:</strong> <%= @stat_lifetime_l %>L</p>
            <p class="mb-0 text-muted small">
              ~<%= @block.weight_kg(@stat_lifetime_l) %>kg &nbsp;·&nbsp;
              ~<%= @block.co2e_kg(@stat_lifetime_l) %>kg CO₂e saved
            </p>
          </div>
        </div>
      </div>
    </div>

    <%# ── Details ─────────────────────────────────────────────────── %>
    <div class="row g-4 mb-5">
      <div class="col-md-6">
        <h5>Details</h5>
        <dl class="row">
          <dt class="col-sm-4">Suburb</dt>
          <dd class="col-sm-8"><%= @block.suburb || "— (assign subscriptions to populate)" %></dd>
          <dt class="col-sm-4">Address</dt>
          <dd class="col-sm-8 text-muted"><%= @block.derived_address || "—" %></dd>
          <dt class="col-sm-4">Residents</dt>
          <dd class="col-sm-8"><%= @block.resident_count || "—" %></dd>
          <dt class="col-sm-4">Description</dt>
          <dd class="col-sm-8"><%= @block.description.presence || "—" %></dd>
        </dl>
      </div>
      <% if @block.photos.attached? %>
        <div class="col-md-6">
          <h5>Photos</h5>
          <div class="d-flex flex-wrap gap-2">
            <% @block.photos.each do |photo| %>
              <%= image_tag photo, class: "img-thumbnail", style: "max-height: 100px; max-width: 150px; object-fit: cover;" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Subscriptions ───────────────────────────────────────────── %>
    <%# @subscriptions is a plain Array (.to_a in controller) — .count and
        .any? here use Ruby, not SQL. No extra DB queries. %>
    <div class="mb-5">
      <h5>Linked Subscriptions (<%= @subscriptions.count %>)</h5>

      <% if @subscriptions.any? %>
        <table class="table table-sm">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Collection day</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @subscriptions.each do |sub| %>
              <tr>
                <td>
                  <%= link_to "#{sub.user.first_name} #{sub.user.last_name}", admin_user_path(sub.user) %>
                </td>
                <td><%= sub.plan %></td>
                <td>
                  <span class="badge bg-<%= sub.active? ? 'success' : 'secondary' %>">
                    <%= sub.status %>
                  </span>
                </td>
                <td><%= sub.collection_day&.capitalize || "—" %></td>
                <td class="text-end">
                  <%= link_to "Remove",
                        remove_subscription_admin_block_path(@block, subscription_id: sub.id),
                        data: { turbo_method: :delete, turbo_confirm: "Remove #{sub.user.first_name} from this block?" },
                        class: "btn btn-sm btn-outline-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No subscriptions linked yet.</p>
      <% end %>
    </div>

    <%# ── Assign subscription ─────────────────────────────────────── %>
    <% if @unassigned_subscriptions.any? %>
      <div class="mb-5">
        <h5>Assign a subscription</h5>
        <p class="text-muted small">Pending, active, and paused subscriptions not already in a block.</p>

        <%= form_with url: assign_subscription_admin_block_path(@block), method: :post, local: true do |f| %>
          <div class="d-flex gap-2 align-items-end">
            <div class="flex-grow-1">
              <select name="subscription_id" class="form-select">
                <option value="">— select a subscription —</option>
                <% @unassigned_subscriptions.each do |sub| %>
                  <option value="<%= sub.id %>">
                    <%= sub.user.first_name %> <%= sub.user.last_name %>
                    — <%= sub.suburb %> (<%= sub.plan %>, <%= sub.status %>)
                  </option>
                <% end %>
              </select>
            </div>
            <%= f.submit "Assign", class: "btn-gooi" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Survey results ──────────────────────────────────────────── %>
    <div class="mb-5">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Resident Survey (<%= @survey_responses.count %> <%= "response".pluralize(@survey_responses.count) %>)</h5>
        <%= link_to "View survey page →", block_survey_path(@block.slug), target: "_blank", class: "text-decoration-none small" %>
      </div>

      <% if @survey_responses.any? %>
        <div class="row g-3 mb-3">
          <div class="col-sm-4">
            <div class="card text-center h-100">
              <div class="card-body py-3">
                <div class="fs-3 fw-bold text-success"><%= @block.survey_wants_phase_one_count %></div>
                <div class="small text-muted">want phase 1</div>
              </div>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="card text-center h-100">
              <div class="card-body py-3">
                <div class="fs-3 fw-bold text-primary"><%= @block.survey_wants_bin_count %></div>
                <div class="small text-muted">want to buy a bin</div>
              </div>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="card text-center h-100">
              <div class="card-body py-3">
                <div class="fs-3 fw-bold text-secondary"><%= @block.survey_has_bin_count %></div>
                <div class="small text-muted">already have a bin</div>
              </div>
            </div>
          </div>
        </div>

        <table class="table table-sm">
          <thead>
            <tr>
              <th>Unit</th>
              <th>Name</th>
              <th>Has bin</th>
              <th>Wants bin</th>
              <th>Phase 1</th>
              <th>Submitted</th>
            </tr>
          </thead>
          <tbody>
            <% @survey_responses.each do |r| %>
              <tr>
                <td><%= r.unit_number.presence || "—" %></td>
                <td><%= r.respondent_name.presence || "—" %></td>
                <td><%= r.has_compost_bin? ? "✓" : "—" %></td>
                <td><%= r.wants_to_buy_bin? ? "✓" : "—" %></td>
                <td>
                  <% if r.wants_phase_one? %>
                    <span class="badge bg-success">Yes</span>
                  <% else %>
                    <span class="badge bg-secondary">No</span>
                  <% end %>
                </td>
                <td class="text-muted small"><%= r.created_at.strftime("%-d %b") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No responses yet.</p>
      <% end %>

      <%# Send survey invite %>
      <div class="mt-3">
        <h6 class="text-muted">Send survey invite</h6>
        <%= form_with url: send_survey_admin_block_path(@block), method: :post, local: true do %>
          <div class="d-flex gap-2">
            <input type="email" name="recipient_email" class="form-control form-control-sm"
                   placeholder="Body corp or resident email" style="max-width: 320px;" required>
            <button type="submit" class="btn btn-sm btn-outline-success">Send invite</button>
          </div>
          <p class="text-muted small mt-1">
            Sends the survey link (<code><%= block_survey_url(@block.slug) %></code>) with composting context.
          </p>
        <% end %>
      </div>
    </div>

    <%# ── Quotations ───────────────────────────────────────────────── %>
    <div class="mb-5">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Quotations (<%= @quotations.count %>)</h5>
        <%= link_to "New quotation →", new_admin_quotation_path, class: "btn btn-sm btn-outline-secondary" %>
      </div>

      <% if @quotations.any? %>
        <table class="table table-sm">
          <thead>
            <tr>
              <th>#</th>
              <th>Prospect / Customer</th>
              <th>Status</th>
              <th>Total</th>
              <th>Expires</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @quotations.each do |q| %>
              <tr>
                <td><%= q.number %></td>
                <td><%= q.customer_name %></td>
                <td>
                  <span class="badge bg-<%= q.accepted? ? 'success' : q.expired? ? 'secondary' : 'warning text-dark' %>">
                    <%= q.status %>
                  </span>
                </td>
                <td>R<%= number_with_delimiter(q.total_amount.to_i) %></td>
                <td class="<%= 'text-danger' if q.expired? %>"><%= q.expires_at.strftime("%-d %b %Y") %></td>
                <td class="text-end">
                  <%= link_to "Edit", edit_admin_quotation_path(q), class: "btn btn-sm btn-outline-secondary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No quotations linked yet. Create one and assign it to this block.</p>
      <% end %>
    </div>

  </div>
</div>
