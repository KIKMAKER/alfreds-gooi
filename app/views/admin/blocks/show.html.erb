<div class="page-container">
  <div class="container py-4">

    <%# ── Header ──────────────────────────────────────────────────── %>
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <h1><%= @block.name %></h1>
        <p class="text-muted mb-0">
          <code>/blocks/<%= @block.slug %></code>
          &nbsp;·&nbsp;
          <%= link_to "View public page →", block_path(@block.slug), target: "_blank", class: "text-decoration-none" %>
        </p>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "Edit", edit_admin_block_path(@block), class: "btn btn-sm btn-outline-secondary" %>
        <%= link_to "Delete", admin_block_path(@block),
              class: "btn btn-sm btn-outline-danger",
              data: { turbo_method: :delete, turbo_confirm: "Delete this block? All subscriptions will be unlinked." } %>
      </div>
    </div>

    <%# ── Stats row ───────────────────────────────────────────────── %>
    <div class="row g-3 mb-5">
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-1">This Week</h6>
            <p class="mb-1">
              <strong>Expected:</strong> <%= @block.expected_weekly_volume_l %>L
            </p>
            <p class="mb-1">
              <strong>Collected:</strong> <%= @block.actual_volume_this_week_l %>L
            </p>
            <p class="mb-0 text-muted small">
              ~<%= @block.weight_kg(@block.actual_volume_this_week_l) %>kg &nbsp;·&nbsp;
              ~<%= @block.co2e_kg(@block.actual_volume_this_week_l) %>kg CO₂e saved
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-1">This Month</h6>
            <p class="mb-1">
              <strong>Collected:</strong> <%= @block.actual_volume_this_month_l %>L
            </p>
            <p class="mb-0 text-muted small">
              ~<%= @block.weight_kg(@block.actual_volume_this_month_l) %>kg &nbsp;·&nbsp;
              ~<%= @block.co2e_kg(@block.actual_volume_this_month_l) %>kg CO₂e saved
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <div class="card-body">
            <h6 class="text-muted text-uppercase small mb-1">All Time</h6>
            <p class="mb-1">
              <strong>Collected:</strong> <%= @block.lifetime_volume_l %>L
            </p>
            <p class="mb-0 text-muted small">
              ~<%= @block.weight_kg(@block.lifetime_volume_l) %>kg &nbsp;·&nbsp;
              ~<%= @block.co2e_kg(@block.lifetime_volume_l) %>kg CO₂e saved
            </p>
          </div>
        </div>
      </div>
    </div>

    <%# ── Details ─────────────────────────────────────────────────── %>
    <div class="row g-4 mb-5">
      <div class="col-md-6">
        <h5>Details</h5>
        <dl class="row">
          <dt class="col-sm-4">Suburb</dt>
          <dd class="col-sm-8"><%= @block.suburb || "— (assign subscriptions to populate)" %></dd>
          <dt class="col-sm-4">Address</dt>
          <dd class="col-sm-8 text-muted"><%= @block.derived_address || "—" %></dd>
          <dt class="col-sm-4">Residents</dt>
          <dd class="col-sm-8"><%= @block.resident_count || "—" %></dd>
          <dt class="col-sm-4">Description</dt>
          <dd class="col-sm-8"><%= @block.description.presence || "—" %></dd>
        </dl>
      </div>
      <% if @block.photos.attached? %>
        <div class="col-md-6">
          <h5>Photos</h5>
          <div class="d-flex flex-wrap gap-2">
            <% @block.photos.each do |photo| %>
              <%= image_tag photo, class: "img-thumbnail", style: "max-height: 100px; max-width: 150px; object-fit: cover;" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Subscriptions ───────────────────────────────────────────── %>
    <div class="mb-5">
      <h5>Linked Subscriptions (<%= @subscriptions.count %>)</h5>

      <% if @subscriptions.any? %>
        <table class="table table-sm">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Collection day</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @subscriptions.each do |sub| %>
              <tr>
                <td>
                  <%= link_to "#{sub.user.first_name} #{sub.user.last_name}", admin_user_path(sub.user) %>
                </td>
                <td><%= sub.plan %></td>
                <td>
                  <span class="badge bg-<%= sub.active? ? 'success' : 'secondary' %>">
                    <%= sub.status %>
                  </span>
                </td>
                <td><%= sub.collection_day&.capitalize || "—" %></td>
                <td class="text-end">
                  <%= link_to "Remove",
                        remove_subscription_admin_block_path(@block, subscription_id: sub.id),
                        data: { turbo_method: :delete, turbo_confirm: "Remove #{sub.user.first_name} from this block?" },
                        class: "btn btn-sm btn-outline-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No subscriptions linked yet.</p>
      <% end %>
    </div>

    <%# ── Assign subscription ─────────────────────────────────────── %>
    <% if @unassigned_subscriptions.any? %>
      <div>
        <h5>Assign a subscription</h5>
        <p class="text-muted small">Only active subscriptions not already in a block are shown.</p>

        <%= form_with url: assign_subscription_admin_block_path(@block), method: :post, local: true do |f| %>
          <div class="d-flex gap-2 align-items-end">
            <div class="flex-grow-1">
              <select name="subscription_id" class="form-select">
                <option value="">— select a subscription —</option>
                <% @unassigned_subscriptions.each do |sub| %>
                  <option value="<%= sub.id %>">
                    <%= sub.user.first_name %> <%= sub.user.last_name %>
                    &mdash; <%= sub.suburb %> (<%= sub.plan %>)
                  </option>
                <% end %>
              </select>
            </div>
            <%= f.submit "Assign", class: "btn-gooi" %>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
