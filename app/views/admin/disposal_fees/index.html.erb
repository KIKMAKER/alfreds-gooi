<div class="driver-wrapper">
  <h1>Disposal Fees Owed</h1>
  <p class="text-muted">
    Kilograms from completed drop-offs &times; the site's per-kg rate. Free sites are not listed.
  </p>

  <div class="d-flex flex-wrap gap-2 my-3">
    <%= link_to "Drop-Off Sites", admin_drop_off_sites_path, class: "small-yellow-btn" %>
  </div>

  <% if @rows.any? %>
    <table class="table table-sm align-middle">
      <thead>
        <tr>
          <th>Month</th>
          <th>Site</th>
          <th class="text-end">Kg dropped</th>
          <th class="text-end">Fee / kg</th>
          <th class="text-end">Fee owed</th>
        </tr>
      </thead>
      <tbody>
        <% @rows.each do |row| %>
          <tr>
            <td><%= row.month.strftime("%B %Y") %></td>
            <td><%= link_to row.site_name, admin_drop_off_site_path(row.site.slug || row.site.id) %></td>
            <td class="text-end"><%= number_with_precision(row.kg_dropped, precision: 2) %></td>
            <td class="text-end">R<%= number_with_precision(row.fee_per_kg, precision: 2) %></td>
            <td class="text-end"><strong>R<%= number_with_precision(row.fee_owed, precision: 2) %></strong></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="4" class="text-end"><strong>Total owed</strong></td>
          <td class="text-end"><strong>R<%= number_with_precision(@report.total_owed, precision: 2) %></strong></td>
        </tr>
      </tfoot>
    </table>
  <% else %>
    <p class="text-muted">No disposal fees owed yet. Sites only appear here once they charge a per-kg rate and have completed drop-offs.</p>
  <% end %>
</div>
