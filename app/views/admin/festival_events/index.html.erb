<div class="admin-container">
  <div class="pt-4 pb-3 d-flex justify-content-between align-items-end">
    <div>
      <p class="dash-eyebrow">Festival Tracker</p>
      <h1>Festival Events</h1>
    </div>
    <%= link_to "+ New festival", new_admin_festival_event_path, class: "fad-action-btn" %>
  </div>

  <% if @festival_events.any? %>
    <div class="fad-event-list">
      <% @festival_events.each do |event| %>
        <div class="fad-event-row">
          <div class="fad-event-row__main">
            <%= link_to event.name, admin_festival_event_path(event), class: "fad-event-row__name" %>
            <span class="fad-event-row__dates">
              <%= event.start_date.strftime("%-d %b") %> – <%= event.end_date.strftime("%-d %b %Y") %>
              &middot; <%= event.festival_participants.count %> participants
              &middot; <%= event.festival_waste_logs.count %> entries
            </span>
          </div>
          <div class="fad-event-row__actions">
            <%= link_to "Dashboard", dashboard_admin_festival_event_path(event), class: "fad-pill-link" %>
            <%= link_to "CSV", export_csv_admin_festival_event_path(event), class: "fad-pill-link" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="fad-empty">No festivals yet.</p>
  <% end %>
</div>
