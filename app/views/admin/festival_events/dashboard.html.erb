<div class="admin-container">
  <div class="pt-4 pb-3">
    <p class="dash-eyebrow">Festival Tracker</p>
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1><%= @festival_event.name %></h1>
        <p class="text-muted small"><%= @festival_event.start_date.strftime("%-d %b") %> – <%= @festival_event.end_date.strftime("%-d %b %Y") %></p>
      </div>
      <div class="fad-action-bar">
        <%= link_to "← Event", admin_festival_event_path(@festival_event), class: "fad-pill-link" %>
        <%= link_to "Export CSV", export_csv_admin_festival_event_path(@festival_event), class: "fad-pill-link" %>
        <%= button_to "Log waste →", enter_as_logger_admin_festival_event_path(@festival_event),
              method: :post, class: "fad-action-btn" %>
      </div>
    </div>
  </div>

  <%# KPI strip %>
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="dash-kpi-card">
        <div class="dash-kpi-label">Total waste tracked</div>
        <div class="dash-kpi-value"><%= number_with_precision(@grand_total, precision: 1) %> kg</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="dash-kpi-card">
        <div class="dash-kpi-label">Organics</div>
        <div class="dash-kpi-value"><%= number_with_precision(@gooi_total, precision: 1) %> kg</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="dash-kpi-card">
        <div class="dash-kpi-label">Inorganics</div>
        <div class="dash-kpi-value"><%= number_with_precision(@chanel_total, precision: 1) %> kg</div>
      </div>
    </div>
  </div>

  <%# Stream totals %>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="dash-category-card">
        <div class="dash-category-heading">Organics (all days)</div>
        <table class="fad-table mt-3">
          <tr>
            <td>Total organic</td>
            <td class="fad-table__val"><%= number_with_precision(@totals_by_category[FestivalWasteLog::ORGANIC_CATEGORY] || 0, precision: 2) %> kg</td>
          </tr>
          <tr class="fad-table__subhead"><td colspan="2">By source</td></tr>
          <% FestivalWasteLog.sources.each_key do |src| %>
            <tr>
              <td class="ps-3"><%= src.humanize %></td>
              <td class="fad-table__val"><%= number_with_precision(@totals_by_source[src] || 0, precision: 2) %> kg</td>
            </tr>
          <% end %>
          <tr class="fad-table__subhead"><td colspan="2">By destination</td></tr>
          <% FestivalWasteLog.destinations.each_key do |dest| %>
            <tr>
              <td class="ps-3"><%= dest.humanize %></td>
              <td class="fad-table__val"><%= number_with_precision(@totals_by_destination[dest] || 0, precision: 2) %> kg</td>
            </tr>
          <% end %>
        </table>
      </div>
    </div>
    <div class="col-md-6">
      <div class="dash-category-card">
        <div class="dash-category-heading">Inorganics (all days)</div>
        <table class="fad-table mt-3">
          <% FestivalWasteLog::CHANEL_CATEGORIES.each do |cat| %>
            <tr>
              <td><%= FestivalWasteLog::CATEGORY_LABELS[cat] %></td>
              <td class="fad-table__val"><%= number_with_precision(@totals_by_category[cat] || 0, precision: 2) %> kg</td>
            </tr>
          <% end %>
        </table>
      </div>
    </div>
  </div>

  <%# Per-day breakdown %>
  <% (1..@festival_event.day_count).each do |day| %>
    <div class="dash-category-card mb-3">
      <div class="dash-category-heading"><%= @festival_event.day_label(day) %></div>
      <table class="fad-table mt-3">
        <thead>
          <tr><th>Stream</th><th class="fad-table__val">Weight</th></tr>
        </thead>
        <tbody>
          <% FestivalWasteLog::ALL_CATEGORIES.each do |cat| %>
            <% kg = @totals_by_day_category[[day, cat]] || 0 %>
            <% next if kg == 0 %>
            <tr>
              <td><%= FestivalWasteLog::CATEGORY_LABELS[cat] %></td>
              <td class="fad-table__val"><%= number_with_precision(kg, precision: 2) %> kg</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# Raw log table %>
  <div class="dash-category-card mb-5">
    <div class="dash-category-heading">All entries</div>
    <% if @logs.any? %>
      <table class="fad-table mt-3">
        <thead>
          <tr>
            <th>Day</th>
            <th>Time</th>
            <th>Stream</th>
            <th class="fad-table__val">Weight</th>
            <th>By</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <tr>
              <td>Day <%= log.day_number %></td>
              <td><%= log.logged_at.strftime("%H:%M") %></td>
              <td><%= log.organic? ? log.organic_label : log.category_label %></td>
              <td class="fad-table__val"><%= number_with_precision(log.weight_kg, precision: 3) %> kg</td>
              <td class="fad-table__meta"><%= log.festival_participant&.name %></td>
              <td class="fad-table__meta"><%= log.notes %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="fad-empty">No entries yet.</p>
    <% end %>
  </div>
</div>
