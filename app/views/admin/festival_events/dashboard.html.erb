<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1><%= @festival_event.name %> – Dashboard</h1>
      <p class="text-muted"><%= @festival_event.start_date.strftime("%-d %b") %> – <%= @festival_event.end_date.strftime("%-d %b %Y") %></p>
    </div>
    <%= link_to "Export CSV", export_csv_admin_festival_event_path(@festival_event), class: "btn btn-success me-2" %>
    <%= button_to "Log waste →", enter_as_logger_admin_festival_event_path(@festival_event),
          method: :post, class: "btn btn-primary" %>
  </div>

  <%# Grand total cards %>
  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <div class="h2"><%= number_with_precision(@grand_total, precision: 1) %> kg</div>
          <div class="text-muted">Total waste tracked</div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <div class="h2"><%= number_with_precision(@gooi_total, precision: 1) %> kg</div>
          <div class="text-muted">Organics</div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center">
        <div class="card-body">
          <div class="h2"><%= number_with_precision(@chanel_total, precision: 1) %> kg</div>
          <div class="text-muted">Inorganics</div>
        </div>
      </div>
    </div>
  </div>

  <%# Totals by stream %>
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header"><strong>Organics (all days)</strong></div>
        <table class="table table-sm mb-0">
          <tr>
            <td>Total organic</td>
            <td class="text-end fw-bold"><%= number_with_precision(@totals_by_category[FestivalWasteLog::ORGANIC_CATEGORY] || 0, precision: 2) %> kg</td>
          </tr>
          <tr class="table-light"><td colspan="2" class="small text-muted ps-3">By source</td></tr>
          <% FestivalWasteLog.sources.each_key do |src| %>
            <tr>
              <td class="ps-3"><%= src.humanize %></td>
              <td class="text-end"><%= number_with_precision(@totals_by_source[src] || 0, precision: 2) %> kg</td>
            </tr>
          <% end %>
          <tr class="table-light"><td colspan="2" class="small text-muted ps-3">By destination</td></tr>
          <% FestivalWasteLog.destinations.each_key do |dest| %>
            <tr>
              <td class="ps-3"><%= dest.humanize %></td>
              <td class="text-end"><%= number_with_precision(@totals_by_destination[dest] || 0, precision: 2) %> kg</td>
            </tr>
          <% end %>
        </table>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-header"><strong>Inorganics (all days)</strong></div>
        <table class="table table-sm mb-0">
          <% FestivalWasteLog::CHANEL_CATEGORIES.each do |cat| %>
            <tr>
              <td><%= FestivalWasteLog::CATEGORY_LABELS[cat] %></td>
              <td class="text-end fw-bold"><%= number_with_precision(@totals_by_category[cat] || 0, precision: 2) %> kg</td>
            </tr>
          <% end %>
        </table>
      </div>
    </div>
  </div>

  <%# Per-day breakdown %>
  <% (1..@festival_event.day_count).each do |day| %>
    <div class="card mb-3">
      <div class="card-header"><strong><%= @festival_event.day_label(day) %></strong></div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th>Stream</th><th class="text-end">Weight</th></tr></thead>
          <tbody>
            <% FestivalWasteLog::ALL_CATEGORIES.each do |cat| %>
              <% kg = @totals_by_day_category[[day, cat]] || 0 %>
              <% next if kg == 0 %>
              <tr>
                <td><%= FestivalWasteLog::CATEGORY_LABELS[cat] %></td>
                <td class="text-end"><%= number_with_precision(kg, precision: 2) %> kg</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# Raw log table %>
  <div class="card mb-4">
    <div class="card-header"><strong>All entries</strong></div>
    <div class="card-body p-0">
      <% if @logs.any? %>
        <table class="table table-sm table-hover mb-0">
          <thead><tr><th>Day</th><th>Time</th><th>Stream</th><th>Weight</th><th>By</th><th>Notes</th></tr></thead>
          <tbody>
            <% @logs.each do |log| %>
              <tr>
                <td>Day <%= log.day_number %></td>
                <td><%= log.logged_at.strftime("%H:%M") %></td>
                <td><%= log.organic? ? log.organic_label : log.category_label %></td>
                <td><%= number_with_precision(log.weight_kg, precision: 3) %> kg</td>
                <td><%= log.festival_participant&.name %></td>
                <td class="text-muted small"><%= log.notes %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted p-3 mb-0">No entries yet.</p>
      <% end %>
    </div>
  </div>
</div>
