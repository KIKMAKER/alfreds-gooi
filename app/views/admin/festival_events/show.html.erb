<div class="admin-container">
  <div class="pt-4 pb-3">
    <p class="dash-eyebrow">Festival Tracker</p>
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h1><%= @festival_event.name %></h1>
        <p class="text-muted small">
          <%= @festival_event.start_date.strftime("%-d %b") %> – <%= @festival_event.end_date.strftime("%-d %b %Y") %>
          &middot; <%= @festival_event.day_count %> day(s)
        </p>
      </div>
      <div class="fad-action-bar">
        <%= link_to "Edit", edit_admin_festival_event_path(@festival_event), class: "fad-pill-link" %>
        <%= link_to "Dashboard", dashboard_admin_festival_event_path(@festival_event), class: "fad-pill-link" %>
        <%= link_to "Export CSV", export_csv_admin_festival_event_path(@festival_event), class: "fad-pill-link" %>
        <%= button_to "Log waste →", enter_as_logger_admin_festival_event_path(@festival_event),
              method: :post, class: "fad-action-btn" %>
      </div>
    </div>
  </div>

  <%# Participants %>
  <div class="dash-category-card mb-4">
    <div class="fad-card-header">
      <span class="dash-category-heading">Participants</span>
      <%= link_to "+ Add", new_admin_festival_event_festival_participant_path(@festival_event), class: "fad-pill-link" %>
    </div>

    <% if @festival_event.festival_participants.any? %>
      <table class="fad-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>PIN</th>
            <th>Entries</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @festival_event.festival_participants.order(:name).each do |p| %>
            <tr>
              <td><%= p.name %></td>
              <td><code class="fad-code"><%= p.pin || "—" %></code></td>
              <td><%= p.festival_waste_logs.count %></td>
              <td class="text-end">
                <%= button_to "Remove", admin_festival_event_festival_participant_path(@festival_event, p),
                    method: :delete, class: "fad-danger-link",
                    data: { turbo_confirm: "Remove #{p.name}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="fad-empty">No participants yet.</p>
    <% end %>
  </div>

  <p class="text-muted small">
    Field team login: <code class="fad-code"><%= new_festival_session_url %></code>
  </p>
</div>
