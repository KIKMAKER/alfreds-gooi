<div class="gooi-container">
  <div class="outline">
    <h1>Financial Dashboard</h1>

    <%# ─────────────────────────────────────────────────────────
        OPERATIONAL OVERVIEW — live from DB, no import needed
    ──────────────────────────────────────────────────────────── %>
    <% op = @operational[:operational]
       bk = @operational[:bakkie]
       rev = @operational[:revenue]
       dq = @operational[:data_quality] %>

    <div class="fin-section mb-5">
      <h2 class="fin-section__title">Your Working Day</h2>
      <p class="text-muted mb-3">
        <%= dq[:total_day_count] %> collection days on record
        (<%= dq[:earliest_day]&.strftime("%b %Y") %> – <%= dq[:latest_day]&.strftime("%b %Y") %>)
      </p>

      <div class="fin-stat-grid mb-3">
        <div class="fin-stat">
          <span class="fin-stat__label">Avg hours / day</span>
          <% if op[:avg_hours_per_day] %>
            <span class="fin-stat__value"><%= op[:avg_hours_per_day] %>h</span>
            <span class="fin-stat__note">last <%= dq[:reliable_day_count] %> days (reliable data)</span>
          <% else %>
            <span class="fin-stat__value text-muted">—</span>
            <span class="fin-stat__note">no reliable timing data yet</span>
          <% end %>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Avg km / day</span>
          <% if op[:avg_kms_per_day] %>
            <span class="fin-stat__value"><%= number_with_delimiter(op[:avg_kms_per_day]) %> km</span>
            <span class="fin-stat__note"><%= dq[:kms_day_count] %> days with km data</span>
          <% else %>
            <span class="fin-stat__value text-muted">—</span>
          <% end %>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Avg stops / day</span>
          <% if op[:avg_stops_per_day] %>
            <span class="fin-stat__value"><%= op[:avg_stops_per_day] %></span>
            <span class="fin-stat__note">last 3 months</span>
          <% else %>
            <span class="fin-stat__value text-muted">—</span>
          <% end %>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Avg buckets / day</span>
          <% if op[:avg_buckets_per_day] %>
            <span class="fin-stat__value"><%= op[:avg_buckets_per_day] %></span>
          <% else %>
            <span class="fin-stat__value text-muted">—</span>
          <% end %>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Days worked / month</span>
          <% if op[:avg_days_per_month] %>
            <span class="fin-stat__value"><%= op[:avg_days_per_month] %></span>
            <span class="fin-stat__note">avg across all months</span>
          <% else %>
            <span class="fin-stat__value text-muted">—</span>
          <% end %>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Hours / month</span>
          <% if op[:monthly_hours] %>
            <span class="fin-stat__value"><%= op[:monthly_hours] %>h</span>
          <% else %>
            <span class="fin-stat__value text-muted">—</span>
          <% end %>
        </div>
      </div>

      <% if dq[:bank_data_present] %>
        <div class="fin-stat-grid">
          <div class="fin-stat fin-stat--highlight">
            <span class="fin-stat__label">Cost per hour</span>
            <% if op[:cost_per_hour] %>
              <span class="fin-stat__value">R <%= number_with_delimiter(op[:cost_per_hour]) %></span>
              <span class="fin-stat__note">every hour of work costs this much</span>
            <% else %>
              <span class="fin-stat__value text-muted">—</span>
            <% end %>
          </div>

          <div class="fin-stat fin-stat--highlight">
            <span class="fin-stat__label">Cost per km</span>
            <% if op[:cost_per_km] %>
              <span class="fin-stat__value">R <%= number_with_delimiter(op[:cost_per_km]) %></span>
            <% else %>
              <span class="fin-stat__value text-muted">—</span>
            <% end %>
          </div>

          <div class="fin-stat fin-stat--highlight">
            <span class="fin-stat__label">Cost per stop</span>
            <% if op[:cost_per_stop] %>
              <span class="fin-stat__value">R <%= number_with_delimiter(op[:cost_per_stop]) %></span>
              <span class="fin-stat__note">per customer visit</span>
            <% else %>
              <span class="fin-stat__value text-muted">—</span>
            <% end %>
          </div>

          <div class="fin-stat fin-stat--highlight">
            <span class="fin-stat__label">Avg monthly costs</span>
            <span class="fin-stat__value">R <%= number_with_delimiter(op[:avg_monthly_costs].to_i) %></span>
            <span class="fin-stat__note">6-month avg, excl. bakkie & salary</span>
          </div>
        </div>
      <% else %>
        <div class="alert alert-info">
          <strong>Import your bank statements</strong> to unlock cost-per-hour and unit economics.
          <%= link_to "Upload a statement →", import_admin_expenses_path, class: "alert-link" %>
        </div>
      <% end %>
    </div>

    <%# ─────────────────────────────────────────────────────────
        THE BAKKIE
    ──────────────────────────────────────────────────────────── %>
    <div class="fin-section mb-5">
      <h2 class="fin-section__title">The Bakkie</h2>
      <p class="text-muted mb-3">
        Bought for R <%= number_with_delimiter(bk[:purchase_price].to_i) %> in
        <%= bk[:purchase_date].strftime("%B %Y") %> —
        depreciated over <%= OperationalMetrics::BAKKIE_DEPRECIATION_YEARS %> years.
      </p>

      <div class="fin-stat-grid">
        <div class="fin-stat">
          <span class="fin-stat__label">Monthly depreciation</span>
          <span class="fin-stat__value">R <%= number_with_delimiter(bk[:monthly_depreciation].to_i) %></span>
          <span class="fin-stat__note">cost the business every month</span>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Current book value</span>
          <span class="fin-stat__value">R <%= number_with_delimiter(bk[:book_value].to_i) %></span>
          <span class="fin-stat__note"><%= bk[:months_owned] %> months owned</span>
        </div>

        <div class="fin-stat">
          <span class="fin-stat__label">Fully depreciated in</span>
          <% if bk[:months_remaining] > 0 %>
            <span class="fin-stat__value"><%= bk[:months_remaining] %> months</span>
            <span class="fin-stat__note">then R<%= number_with_delimiter(bk[:monthly_depreciation].to_i) %>/month frees up</span>
          <% else %>
            <span class="fin-stat__value text-success">Fully depreciated</span>
          <% end %>
        </div>

        <% if dq[:bank_data_present] && op[:avg_monthly_costs].positive? %>
          <div class="fin-stat">
            <span class="fin-stat__label">Bakkie as % of costs</span>
            <span class="fin-stat__value"><%= ((bk[:monthly_depreciation] / op[:avg_monthly_costs]) * 100).round(1) %>%</span>
          </div>
        <% end %>
      </div>
    </div>

    <%# ─────────────────────────────────────────────────────────
        WHAT YOUR CUSTOMERS BRING IN
    ──────────────────────────────────────────────────────────── %>
    <div class="fin-section mb-5">
      <h2 class="fin-section__title">What Your Customers Bring In</h2>
      <p class="text-muted mb-3">
        Current MRR from <%= rev.values.sum { |v| v[:count] } %> active subscriptions:
        <strong>R <%= number_with_delimiter(op[:current_mrr].to_i) %>/month</strong>
        <% if rev.values.any? { |v| v[:with_amounts] < v[:count] } %>
          <span class="text-warning ms-2">
            ⚠ Some subscriptions are missing monthly amounts — MRR may be understated.
          </span>
        <% end %>
      </p>

      <table class="table table-bordered table-sm">
        <thead>
          <tr>
            <th>Plan</th>
            <th class="text-end">Active</th>
            <th class="text-end">Avg / month</th>
            <th class="text-end">Total / month</th>
            <% if op[:cost_per_stop] %>
              <th class="text-end">Covers ~X stops</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% rev.each do |plan, data| %>
            <tr>
              <td><strong><%= plan %></strong></td>
              <td class="text-end"><%= data[:count] %></td>
              <td class="text-end">
                <% if data[:avg_monthly].positive? %>
                  R <%= number_with_delimiter(data[:avg_monthly].to_i) %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="text-end">R <%= number_with_delimiter(data[:total_monthly].to_i) %></td>
              <% if op[:cost_per_stop] && data[:avg_monthly].positive? %>
                <td class="text-end"><%= (data[:avg_monthly] / op[:cost_per_stop]).round(1) %></td>
              <% elsif op[:cost_per_stop] %>
                <td class="text-end text-muted">—</td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr class="table-primary fw-bold">
            <td>Total</td>
            <td class="text-end"><%= rev.values.sum { |v| v[:count] } %></td>
            <td></td>
            <td class="text-end">R <%= number_with_delimiter(op[:current_mrr].to_i) %></td>
            <% if op[:cost_per_stop] %>
              <td></td>
            <% end %>
          </tr>
        </tfoot>
      </table>
    </div>

    <%# ─────────────────────────────────────────────────────────
        PRICE PER LITRE BY PLAN
    ──────────────────────────────────────────────────────────── %>
    <% litre_pricing = @operational[:litre_pricing] %>
    <% if litre_pricing.any? %>
      <div class="fin-section mb-5">
        <h2 class="fin-section__title">What You Charge Per Litre</h2>
        <p class="text-muted mb-3">
          Based on actual collections in the last 3 months.
          Standard customers bring bags (5L each); XL bring 25L buckets; Commercial have tracked 25L/45L buckets.
        </p>

        <table class="table table-bordered">
          <thead>
            <tr>
              <th>Plan</th>
              <th class="text-end">Active subs</th>
              <th class="text-end">Volume unit</th>
              <th class="text-end">Avg L/visit</th>
              <th class="text-end">Visits/month</th>
              <th class="text-end">Avg L/month</th>
              <th class="text-end">Avg charge/month</th>
              <th class="text-end fw-bold">R per litre</th>
              <th class="text-end">Total revenue/month</th>
            </tr>
          </thead>
          <tbody>
            <% litre_pricing.each do |plan, data| %>
              <tr>
                <td><strong><%= plan %></strong></td>
                <td class="text-end"><%= data[:active_count] %></td>
                <td class="text-end text-muted"><small><%= data[:volume_unit] %></small></td>
                <td class="text-end"><%= number_with_delimiter(data[:avg_litres_per_visit]) %>L</td>
                <td class="text-end"><%= data[:avg_visits_per_month] %></td>
                <td class="text-end"><%= number_with_delimiter(data[:avg_litres_per_month]) %>L</td>
                <td class="text-end">R <%= number_with_delimiter(data[:avg_monthly_charge].to_i) %></td>
                <td class="text-end">
                  <% if data[:price_per_litre] %>
                    <strong>R <%= data[:price_per_litre] %>/L</strong>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td class="text-end">R <%= number_with_delimiter(data[:total_monthly_revenue].to_i) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <p class="text-muted mt-2" style="font-size: 0.8rem;">
          <em>Price per litre = average monthly charge ÷ average litres collected per month.
          Visits/month is averaged across all active subscriptions of that plan.</em>
        </p>
      </div>
    <% end %>

    <%# ─────────────────────────────────────────────────────────
        PAY YOURSELF — salary sustainability calculator
    ──────────────────────────────────────────────────────────── %>
    <div class="fin-section mb-5">
      <h2 class="fin-section__title">Pay Yourself</h2>

      <% scenarios = @operational[:sustainability]
         costs_base = op[:avg_monthly_costs] + bk[:monthly_depreciation]
         available_before_salary = op[:current_mrr] - costs_base %>

      <div class="fin-payself-summary mb-4">
        <div class="fin-payself-row">
          <span>Current MRR</span>
          <span class="text-success">+ R <%= number_with_delimiter(op[:current_mrr].to_i) %></span>
        </div>
        <% if dq[:bank_data_present] %>
          <div class="fin-payself-row">
            <span>Running costs (avg 6 months)</span>
            <span class="text-danger">− R <%= number_with_delimiter(op[:avg_monthly_costs].to_i) %></span>
          </div>
        <% else %>
          <div class="fin-payself-row text-muted">
            <span>Running costs</span>
            <span>import bank statements to calculate</span>
          </div>
        <% end %>
        <div class="fin-payself-row">
          <span>Bakkie (monthly depreciation)</span>
          <span class="text-danger">− R <%= number_with_delimiter(bk[:monthly_depreciation].to_i) %></span>
        </div>
        <div class="fin-payself-row fin-payself-row--total">
          <span>Available for salary</span>
          <span class="<%= available_before_salary >= 5000 ? 'text-success' : 'text-warning' %>">
            R <%= number_with_delimiter(available_before_salary.to_i) %>
          </span>
        </div>
      </div>

      <h3 class="h5 mb-3">How many more customers do you need?</h3>
      <table class="table table-bordered table-sm">
        <thead>
          <tr>
            <th>Salary target</th>
            <th class="text-end">Can you afford it now?</th>
            <th class="text-end">Gap</th>
            <th class="text-end">Extra Standard needed</th>
            <th class="text-end">Extra XL needed</th>
          </tr>
        </thead>
        <tbody>
          <% scenarios.each do |s| %>
            <tr class="<%= s[:achievable] ? 'table-success' : '' %>">
              <td>R <%= number_with_delimiter(s[:target_salary]) %>/month</td>
              <td class="text-end">
                <% if s[:achievable] %>
                  <span class="text-success fw-bold">Yes ✓</span>
                <% else %>
                  <span class="text-muted">Not yet</span>
                <% end %>
              </td>
              <td class="text-end">
                <% if s[:gap].positive? %>
                  R <%= number_with_delimiter(s[:gap].to_i) %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="text-end">
                <%= s[:extra_standard_needed].positive? ? "+ #{s[:extra_standard_needed]}" : "—" %>
              </td>
              <td class="text-end">
                <%= s[:extra_xl_needed].positive? ? "+ #{s[:extra_xl_needed]}" : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% unless dq[:bank_data_present] %>
        <p class="text-muted mt-2">
          <em>Gap and customer counts are based on current MRR vs target — import bank statements to include actual running costs in the calculation.</em>
        </p>
      <% end %>
    </div>

    <!-- Date Range Selector -->
    <div class="d-flex gap-2 align-items-center mb-4">
      <%= form_with url: admin_financials_path, method: :get, class: "d-flex gap-2 align-items-center" do %>
        <%= select_tag :range,
            options_for_select([
              ['This Month', 'this_month'],
              ['Last Month', 'last_month'],
              ['This Quarter', 'this_quarter'],
              ['This Year', 'this_year'],
              ['Last Year', 'last_year']
            ], params[:range] || 'this_month'),
            class: "form-select w-auto" %>
        <%= submit_tag "Update", class: "btn-today-green" %>
      <% end %>
    </div>

    <!-- KPI Summary -->
    <div class="d-flex justify-content-around mb-4">
      <div>
        <p class="text-muted mb-1">Total Revenue</p>
        <h2>R <%= number_with_delimiter(@total_revenue.to_i) %></h2>
        <% if @mom_revenue_change %>
          <small class="<%= @mom_revenue_change >= 0 ? 'text-success' : 'text-danger' %>">
            <%= @mom_revenue_change >= 0 ? '↑' : '↓' %>
            <%= number_to_percentage(@mom_revenue_change.abs, precision: 1) %> MoM
          </small>
        <% end %>
      </div>

      <div>
        <p class="text-muted mb-1">Total Expenses</p>
        <h2>R <%= number_with_delimiter(@total_expenses.to_i) %></h2>
        <small class="text-muted">
          <%= @metrics.count %> <%= @metrics.count == 1 ? 'month' : 'months' %>
        </small>
      </div>

      <div>
        <p class="text-muted mb-1">Gross Profit</p>
        <h2>R <%= number_with_delimiter(@gross_profit.to_i) %></h2>
        <% if @total_revenue > 0 %>
          <small class="text-success">
            <%= number_to_percentage(@gross_profit / @total_revenue * 100, precision: 1) %> margin
          </small>
        <% end %>
      </div>

      <div>
        <p class="text-muted mb-1">Net Profit</p>
        <h2 class="<%= @net_profit >= 0 ? 'text-success' : 'text-danger' %>">
          R <%= number_with_delimiter(@net_profit.to_i) %>
        </h2>
        <% if @total_revenue > 0 %>
          <small class="<%= @net_profit >= 0 ? 'text-success' : 'text-danger' %>">
            <%= number_to_percentage(@net_profit / @total_revenue * 100, precision: 1) %> margin
          </small>
        <% end %>
      </div>
    </div>

    <!-- P&L Statement -->
    <h3 class="mt-4 mb-3">Profit & Loss Statement</h3>
    <table class="table table-bordered">
            <thead>
              <tr>
                <th>Item</th>
                <th class="text-end">Amount</th>
                <th class="text-end">% of Revenue</th>
              </tr>
            </thead>
            <tbody>
              <!-- Revenue -->
              <tr class="table-primary fw-bold">
                <td>TOTAL REVENUE</td>
                <td class="text-end">R <%= number_with_delimiter(@total_revenue.to_i) %></td>
                <td class="text-end">100.0%</td>
              </tr>

              <!-- Cost of Goods Sold -->
              <tr class="table-secondary">
                <td colspan="3"><strong>COST OF GOODS SOLD</strong></td>
              </tr>
              <% if @expense_breakdown[:cogs] > 0 %>
                <tr>
                  <td class="ps-4">Cost of Goods Sold</td>
                  <td class="text-end">R <%= number_with_delimiter(@expense_breakdown[:cogs].to_i) %></td>
                  <td class="text-end">
                    <% if @total_revenue > 0 %>
                      <%= number_to_percentage(@expense_breakdown[:cogs] / @total_revenue * 100, precision: 1) %>
                    <% else %>
                      0.0%
                    <% end %>
                  </td>
                </tr>
              <% end %>

              <!-- Gross Profit -->
              <tr class="table-info fw-bold">
                <td>GROSS PROFIT</td>
                <td class="text-end">R <%= number_with_delimiter(@gross_profit.to_i) %></td>
                <td class="text-end">
                  <% if @total_revenue > 0 %>
                    <%= number_to_percentage(@gross_profit / @total_revenue * 100, precision: 1) %>
                  <% else %>
                    0.0%
                  <% end %>
                </td>
              </tr>

              <!-- Operating Expenses -->
              <tr class="table-secondary">
                <td colspan="3"><strong>OPERATING EXPENSES</strong></td>
              </tr>

              <% if @expense_breakdown[:operational] > 0 %>
                <tr>
                  <td class="ps-4">Operational Costs</td>
                  <td class="text-end">R <%= number_with_delimiter(@expense_breakdown[:operational].to_i) %></td>
                  <td class="text-end">
                    <% if @total_revenue > 0 %>
                      <%= number_to_percentage(@expense_breakdown[:operational] / @total_revenue * 100, precision: 1) %>
                    <% else %>
                      0.0%
                    <% end %>
                  </td>
                </tr>
              <% end %>

              <% if @expense_breakdown[:fixed] > 0 %>
                <tr>
                  <td class="ps-4">Fixed Costs</td>
                  <td class="text-end">R <%= number_with_delimiter(@expense_breakdown[:fixed].to_i) %></td>
                  <td class="text-end">
                    <% if @total_revenue > 0 %>
                      <%= number_to_percentage(@expense_breakdown[:fixed] / @total_revenue * 100, precision: 1) %>
                    <% else %>
                      0.0%
                    <% end %>
                  </td>
                </tr>
              <% end %>

              <% if @expense_breakdown[:marketing] > 0 %>
                <tr>
                  <td class="ps-4">Marketing</td>
                  <td class="text-end">R <%= number_with_delimiter(@expense_breakdown[:marketing].to_i) %></td>
                  <td class="text-end">
                    <% if @total_revenue > 0 %>
                      <%= number_to_percentage(@expense_breakdown[:marketing] / @total_revenue * 100, precision: 1) %>
                    <% else %>
                      0.0%
                    <% end %>
                  </td>
                </tr>
              <% end %>

              <% if @expense_breakdown[:admin] > 0 %>
                <tr>
                  <td class="ps-4">Administrative</td>
                  <td class="text-end">R <%= number_with_delimiter(@expense_breakdown[:admin].to_i) %></td>
                  <td class="text-end">
                    <% if @total_revenue > 0 %>
                      <%= number_to_percentage(@expense_breakdown[:admin] / @total_revenue * 100, precision: 1) %>
                    <% else %>
                      0.0%
                    <% end %>
                  </td>
                </tr>
              <% end %>

              <% if @expense_breakdown[:other] > 0 %>
                <tr>
                  <td class="ps-4">Other Expenses</td>
                  <td class="text-end">R <%= number_with_delimiter(@expense_breakdown[:other].to_i) %></td>
                  <td class="text-end">
                    <% if @total_revenue > 0 %>
                      <%= number_to_percentage(@expense_breakdown[:other] / @total_revenue * 100, precision: 1) %>
                    <% else %>
                      0.0%
                    <% end %>
                  </td>
                </tr>
              <% end %>

              <!-- Net Profit -->
              <tr class="table-<%= @net_profit >= 0 ? 'success' : 'danger' %> fw-bold">
                <td>NET PROFIT</td>
                <td class="text-end">R <%= number_with_delimiter(@net_profit.to_i) %></td>
                <td class="text-end">
                  <% if @total_revenue > 0 %>
                    <%= number_to_percentage(@net_profit / @total_revenue * 100, precision: 1) %>
                  <% else %>
                    0.0%
                  <% end %>
                </td>
              </tr>
            </tbody>
          </table>

    <!-- Customer Churn Analysis -->
    <% if @period_churn %>
      <h3 class="mt-4 mb-3">Customer Churn Analysis</h3>

      <div class="mb-3 p-3 bg-light rounded">
        <p class="mb-2">
          <strong>3-Month Period (<%= @period_churn[:period] %>):</strong>
        </p>
        <div class="row">
          <div class="col-md-3">
            <small class="text-muted">Active Users (Start)</small>
            <div><strong><%= @period_churn[:users_at_start] %></strong></div>
          </div>
          <div class="col-md-3">
            <small class="text-muted">Active Users (End)</small>
            <div><strong><%= @period_churn[:users_at_end] %></strong></div>
          </div>
          <div class="col-md-3">
            <small class="text-muted">Churned Users</small>
            <div><strong class="<%= @period_churn[:churned_users] > 5 ? 'text-danger' : 'text-success' %>">
              <%= @period_churn[:churned_users] %>
            </strong></div>
          </div>
          <div class="col-md-3">
            <small class="text-muted">Period Churn Rate</small>
            <div><strong class="<%= @period_churn[:churn_rate] > 10 ? 'text-danger' : @period_churn[:churn_rate] > 5 ? 'text-warning' : 'text-success' %>">
              <%= number_to_percentage(@period_churn[:churn_rate], precision: 1) %>
            </strong></div>
          </div>
        </div>
        <p class="mb-0 mt-2">
          <small class="text-muted">
            Normalized monthly churn rate: <strong><%= number_to_percentage(@period_churn[:monthly_churn_rate], precision: 2) %></strong> (used in forecast)
          </small>
        </p>
      </div>

      <% if @period_churn[:churned_user_objects].any? %>
        <details class="mb-3">
          <summary class="text-danger fw-bold" style="cursor: pointer;">
            View <%= @period_churn[:churned_users] %> churned <%= @period_churn[:churned_users] == 1 ? 'user' : 'users' %>
          </summary>
          <div class="mt-2 p-3 border rounded">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Last Subscription End</th>
                </tr>
              </thead>
              <tbody>
                <% @period_churn[:churned_user_objects].each do |user| %>
                  <tr>
                    <td>
                      <%= link_to user.first_name, admin_user_path(user), class: "text-decoration-none" %>
                    </td>
                    <td><small><%= user.email %></small></td>
                    <td>
                      <% last_sub = user.subscriptions.order(end_date: :desc).first %>
                      <% if last_sub&.end_date %>
                        <small class="text-muted"><%= last_sub.end_date.strftime("%d %b %Y") %></small>
                      <% else %>
                        <small class="text-muted">-</small>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </details>
      <% end %>

      <% if @churn_history && @churn_history.any? %>
        <details class="mb-3">
          <summary class="text-muted" style="cursor: pointer;">View month-by-month breakdown</summary>
          <table class="table table-bordered table-sm mt-2">
            <thead>
              <tr>
                <th>Month</th>
                <th class="text-end">Active Users Start</th>
                <th class="text-end">Active Users End</th>
                <th class="text-end">Churned</th>
                <th class="text-end">Churn Rate</th>
              </tr>
            </thead>
            <tbody>
              <% @churn_history.each do |churn| %>
                <tr>
                  <td><%= churn[:month].strftime("%B %Y") %></td>
                  <td class="text-end"><%= churn[:users_at_start] %></td>
                  <td class="text-end"><%= churn[:users_at_end] %></td>
                  <td class="text-end"><%= churn[:churned_users] %></td>
                  <td class="text-end">
                    <span class="<%= churn[:churn_rate] > 10 ? 'text-danger' : churn[:churn_rate] > 5 ? 'text-warning' : 'text-success' %>">
                      <%= number_to_percentage(churn[:churn_rate], precision: 1) %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </details>
      <% end %>
    <% end %>

    <!-- Revenue Forecast -->
    <% if @forecast && @forecast.any? %>
      <h3 class="mt-4 mb-3">Revenue Forecast (Next 6 Months)</h3>
      <p class="text-muted mb-3">
        Based on <%= Subscription.active.count %> active subscriptions with <%= number_to_percentage(@period_churn[:monthly_churn_rate], precision: 2) %> monthly churn rate
      </p>
      <table class="table table-bordered">
              <thead>
                <tr>
                  <th>Month</th>
                  <th class="text-end">Committed Revenue</th>
                  <th class="text-end">Expected Revenue</th>
                  <th class="text-end">Projected Active Subs</th>
                </tr>
              </thead>
              <tbody>
                <% @forecast.each do |f| %>
                  <tr>
                    <td><%= f[:month].strftime("%B %Y") %></td>
                    <td class="text-end">R <%= number_with_delimiter(f[:committed_revenue].to_i) %></td>
                    <td class="text-end">R <%= number_with_delimiter(f[:expected_revenue].to_i) %></td>
                    <td class="text-end"><%= f[:projected_active_subs] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
    <% end %>

    <!-- Quick Actions -->
    <div class="d-flex gap-2 mt-4">
      <%= link_to "Add Expense", new_admin_expense_path, class: "btn-today-green" %>
      <%= link_to "Upload Bank Statement", import_admin_expenses_path, class: "btn-today-green" %>
      <%= link_to "View All Expenses", admin_expenses_path, class: "link-title" %>
    </div>
  </div>
</div>
