<div class="user-wrapper">
  <h1 class="my-4">Edit Discount Code</h1>
  <%= simple_form_for [:admin, @discount_code] do |f| %>
    <%= f.input :code, placeholder: "e.g. EARTHWEEK25" %>
    <%= f.input :discount_cents, label: "Discount (in cents)", hint: "6600 = R66 off" %>
    <%= f.input :discount_percent, label: "Discount (%)" %>
    <%= f.input :usage_limit, label: "Usage limit (optional)" %>
    <%= f.input :expires_at,
              as: :string,
              input_html: { data: { controller: "datepicker" } },
              label: "Expires at (optional)" %>
    <%= f.button :submit, "Update Code", class: "small-yellow-btn" %>
  <% end %>
  <%= link_to "Back", admin_discount_code_path(@discount_code), class: "mt-3 d-block" %>
</div>
