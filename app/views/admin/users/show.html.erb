<!-- app/views/admin/users/show.html.erb -->
<div class="gooi-container">
  <div class="outline">
    <div>
      <br>
      <% name = ( @user.respond_to?(:full_name) && @user.full_name.present?) ? @user.full_name : [@user.first_name, @user.last_name].compact.join(" ") %>
      <h1><%= name.presence || @user.email %></h1>

      <p><strong>Email:</strong> <%= @user.email %></p>
      <% if @user.respond_to?(:phone_number) && @user.phone_number.present? %>
        <p><strong>Phone:</strong> <%= @user.phone_number %></p>
      <% end %>
      <% if @user.respond_to?(:customer_id) && @user.customer_id.present? %>
        <p><strong>Customer ID:</strong> <%= @user.customer_id %></p>
      <% end %>
      <% if @referred_by %>
        <p><strong>Referred by:</strong> <%= link_to @referred_by.first_name + " " + @referred_by.last_name.to_s, admin_user_path(@referred_by), class: "link-title" %></p>
      <% end %>

      <%= link_to "New Subscription", new_admin_subscription_path(user_id: @user.id), class: "btn-today-green my-2" %>

      <% if @user.journey_token.present? %>
        <%= link_to "🌱 Journey page", journey_url(@user.journey_token), target: "_blank", class: "btn-today-green my-2" %>
      <% end %>

      <%= link_to "Transfer subscriptions in", transfer_subscriptions_admin_user_path(@user), class: "btn-today-green my-2" %>

      <%= button_to "Claim payments for my invoices",
              claim_orphaned_payments_admin_user_path(@user),
              method: :post,
              class: "btn-today-green my-2",
              form: { data: { turbo_confirm: "Find all payments linked to #{@user.first_name}'s invoices that are sitting on other accounts, and move them here?" } } %>

      <%= link_to "Transfer payments in", transfer_payments_admin_user_path(@user), class: "btn-today-green my-2" %>

      <%= button_to "Duplicate last sub",
              renew_last_subscription_admin_user_path(@user),
              method: :post,
              class: "btn-today-green my-2",
              form: { data: { turbo_confirm: "Create a new subscription from the user's last one and generate an invoice?" } } %>

      <%= button_to "Fix boundaries (preview)",
              fix_subscription_boundaries_admin_user_path(@user, dry_run: 1),
              method: :post,
              class: "btn-today-green my-2",
              form: { data: { turbo: false } } %>

      <%= button_to "Fix boundaries",
              fix_subscription_boundaries_admin_user_path(@user),
              method: :post,
              class: "btn-today-green my-2",
              form: { data: { turbo_confirm: "This will set end_date and reassign collections for all completed subs. Continue?" } } %>

      <% if @user.subscriptions.where(monthly_invoicing: true, primary_subscription_id: nil).any? %>
        <%= button_to "Generate all monthly invoices",
                generate_all_monthly_invoices_admin_user_path(@user),
                method: :post,
                class: "btn-yellow my-2",
                form: { data: { turbo_confirm: "Run the monthly invoice generator for all eligible subscriptions for #{@user.first_name}? They will be combined into one invoice." } } %>
      <% end %>

      <hr>

      <div class="mb-3">
        <%= link_to "view invoices (#{@user.invoices.count})", invoices_path(user_id: @user.id), class: "link-title" %>
        |
        <%= link_to "view statement", statement_path(@user), class: "link-title" %>
        |
        <%= link_to "view collections (#{@user.collections.count})", collections_admin_user_path(@user), class: "link-title" %>
      </div>

      <% admin_payments = @user.payments.order(date: :desc) %>
      <div class="info-card mb-4">
        <div class="info-card-header">
          <i class="fa-solid fa-money-bill-transfer"></i>
          <h3>Payments</h3>
          <span style="margin-left: auto; font-size: 0.8rem; color: #888; font-weight: 400;">
            <%= admin_payments.count %> record<%= 's' unless admin_payments.count == 1 %> &middot;
            R<%= number_with_delimiter((admin_payments.sum(:total_amount) / 100.0).to_i) %> total
          </span>
        </div>

        <% if admin_payments.any? %>
          <div style="padding: 0;">
            <% admin_payments.each do |p| %>
              <div class="payment-row">
                <div class="payment-row__meta">
                  <span class="payment-row__date"><%= p.date&.strftime('%d %b %Y') || 'No date' %></span>
                  <span class="payment-row__detail">
                    <% type_key = p.payment_type.presence || (p.snapscan_id.present? ? 'snapscan' : 'unknown') %>
                    <span class="payment-type-chip payment-type-chip--<%= type_key %>"><%= type_key.upcase %></span>
                    <% if p.note.present? %>
                      &middot; <%= p.note %>
                    <% elsif p.user_reference.present? %>
                      &middot; ref: <%= p.user_reference %>
                    <% end %>
                  </span>
                </div>
                <div class="payment-row__right">
                  <span class="payment-row__amount">R<%= number_with_delimiter((p.total_amount / 100.0).to_i) %></span>
                  <% if p.manual? %>
                    <%= button_to admin_user_payment_path(@user, p),
                        method: :delete,
                        class: "payment-row__delete",
                        form: { data: { turbo_confirm: "Delete this manual payment entry?" } } do %>
                      <i class="fa-solid fa-trash-can"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <%= form_with scope: :payment, url: admin_user_payments_path(@user), method: :post, local: true do |f| %>
          <div class="payment-form">
            <div class="payment-form__field">
              <label>Date</label>
              <%= f.date_field :date, value: Date.today, required: true %>
            </div>
            <div class="payment-form__field">
              <label>Amount</label>
              <div class="payment-form__amount-wrap">
                <span>R</span>
                <%= f.number_field :amount_rands, placeholder: "0.00", step: "0.01", min: "0.01", required: true %>
              </div>
            </div>
            <div class="payment-form__field">
              <label>Type</label>
              <%= f.select :payment_type, Payment.payment_types.keys.map { |k| [k.titleize, k] } %>
            </div>
            <div class="payment-form__field" style="flex: 1; min-width: 180px;">
              <label>Note</label>
              <%= f.text_field :note, placeholder: "e.g. EFT ref ABC123" %>
            </div>
            <%= f.submit "Log Payment", class: "tiny-yellow-btn payment-form__submit" %>
          </div>
        <% end %>
      </div>

      <% if @lifetime_litres > 0 %>
        <div class="outline p-3 mb-4">
          <h3 class="mb-3">♻️ Lifetime Environmental Impact</h3>
          <div class="row">
            <div class="col-md-4">
              <p class="mb-1"><strong><%= @lifetime_litres.to_i %> L</strong></p>
              <p class="text-muted small">Kitchen scraps diverted from landfill</p>
            </div>
            <div class="col-md-4">
              <p class="mb-1"><strong><%= @lifetime_compost_kg %> kg</strong></p>
              <p class="text-muted small">Finished compost for local soil</p>
            </div>
            <div class="col-md-4">
              <p class="mb-1"><strong><%= @lifetime_co2e_kg %> kg CO₂e</strong></p>
              <p class="text-muted small">Emissions avoided</p>
            </div>
          </div>
        </div>
      <% end %>

      <h2>Subscriptions (<%= @subscriptions.size %>)</h2>

      <% if @subscriptions.any? %>
        <table class="table table-bordered">
          <thead>
            <tr>
              <th scope="col">ID</th>
              <th scope="col">Status</th>
              <th scope="col">Start Date</th>
              <th scope="col">Duration</th>
              <th scope="col">Total Collections</th>
              <th scope="col">Remaining Collections</th>
              <th scope="col">Holiday Start</th>
              <th scope="col">Holiday End</th>
            </tr>
          </thead>
          <tbody>
            <% @subscriptions.each do |subscription| %>

              <% completed = subscription.respond_to?(:completed?) && subscription.completed? %>
              <tr>
                <td>
                  <%= subscription.id %>
                  <% if subscription.title.present? %>
                    <small class="text-muted d-block"><%= subscription.title %></small>
                  <% end %>
                </td>
                <td><%= subscription.respond_to?(:status) ? subscription.status : "-" %></td>

                <td>
                  <%= link_to admin_subscription_path(subscription) do %>
                    <% sd = subscription.start_date&.strftime('%e %B %Y') || "unpaid" %>
                    <% if completed %><s><%= sd %></s><% else %><%= sd %><% end %>
                  <% end %>
                </td>
                <td>
                  <% dur = subscription.once_off? ? "once-off" : (subscription.duration || "unpaid") %>
                  <% if completed %><s><%= dur %></s><% else %><%= dur %><% end %>
                </td>

                <td>
                  <% total = subscription.collections.where(skip: false).count %>
                  <% skipped = subscription.collections.where(skip: true).count %>
                  <% display = "#{total}#{skipped > 0 ? " (#{skipped} skipped)" : ""}" %>
                  <% if completed %><s><%= display %></s><% else %><%= display %><% end %>
                </td>

                <td>
                  <% rem = (subscription.respond_to?(:remaining_collections) ? subscription.remaining_collections : nil) %>
                  <% if rem.present? %>
                    <% if rem < 0 %>
                      <%= button_to 'reassign preview',
                reassign_collections_subscription_path(subscription, dry_run: 1),
                method: :post, form: { data: { turbo: false } } %>

                      <%= button_to "reassign #{rem.truncate} collections",
                reassign_collections_subscription_path(subscription),
                method: :post, form: { data: { turbo: false } } %>
                    <% else %>
                      <%= rem.to_i.truncate %>
                    <% end %>
                  <% elsif subscription.once_off? %>
                    &mdash;
                  <% else %>
                    unpaid
                  <% end %>
                </td>

                <td>
                  <% hs = subscription.holiday_start&.strftime('%e %B %Y') %>
                  <% if completed && hs.present? %><s><%= hs %></s><% elsif hs.present? %><%= hs %><% elsif subscription.once_off? %>&mdash;<% else %>unpaid<% end %>
                </td>

                <td>
                  <% he = subscription.holiday_end&.strftime('%e %B %Y') %>
                  <% if completed && he.present? %><s><%= he %></s><% elsif he.present? %><%= he %><% elsif subscription.once_off? %>&mdash;<% else %>unpaid<% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p>No subscriptions.</p>
      <% end %>

      <p style="margin-top:1rem;">
        <%= link_to "Back to Users", admin_users_path, class: "btn-today-green" %>
        <%= link_to "Edit User", edit_admin_user_path(@user), class: "btn-today-green", style: "margin-left: .5rem" %>
      </p>
    </div>
  </div>
</div>
