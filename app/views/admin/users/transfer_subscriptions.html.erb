<div class="admin-container">
  <div class="d-flex align-items-start justify-content-between mt-4 mb-4">
    <div>
      <h1 class="mb-1">Transfer Subscriptions</h1>
      <p class="text-muted mb-0">
        Destination: <%= link_to @destination_user.full_name, admin_user_path(@destination_user), class: "link-title" %>
      </p>
    </div>
    <%= link_to "← Back", admin_user_path(@destination_user), class: "btn btn-outline-secondary btn-sm mt-1" %>
  </div>

  <%# Step 1: pick source user %>
  <div class="info-card mb-4">
    <div class="info-card-header">
      <i class="fa-solid fa-user-group"></i>
      <h3>Step 1 — Choose source customer</h3>
    </div>
    <div class="info-card-body">
      <%= form_with url: transfer_subscriptions_admin_user_path(@destination_user), method: :get, data: { turbo: false } do |f| %>
        <div class="d-flex gap-2 align-items-end">
          <div class="flex-grow-1">
            <%= label_tag :from_user_id, "Transfer subscriptions from:", class: "form-label" %>
            <%= select_tag :from_user_id,
                           options_from_collection_for_select(
                             @all_users.reject { |u| u.id == @destination_user.id },
                             :id,
                             ->(u) { "#{u.full_name} (#{u.email})" },
                             @source_user&.id
                           ),
                           prompt: "Select a customer…",
                           class: "form-select" %>
          </div>
          <%= f.submit "Load subscriptions →", class: "btn-today-green" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Step 2: pick subscriptions %>
  <% if @source_user %>
    <div class="info-card mb-4">
      <div class="info-card-header">
        <i class="fa-solid fa-arrows-rotate"></i>
        <h3>Step 2 — Select subscriptions to transfer</h3>
      </div>
      <div class="info-card-body">
        <% if @transferable_subscriptions.any? %>
          <%= form_with url: transfer_subscriptions_admin_user_path(@destination_user), method: :post, data: { turbo: false } do |f| %>
            <%= hidden_field_tag :from_user_id, @source_user.id %>

            <div class="mb-3">
              <% @transferable_subscriptions.each do |sub| %>
                <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                  <div class="form-check mb-0">
                    <%= check_box_tag "subscription_ids[]", sub.id, false, class: "form-check-input", id: "sub_#{sub.id}" %>
                  </div>
                  <label for="sub_<%= sub.id %>" class="mb-0 flex-grow-1" style="cursor: pointer;">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <strong><%= sub.plan.titleize %></strong>
                      <% if sub.title.present? %>
                        <span class="text-muted">— <%= sub.title %></span>
                      <% end %>
                      <span class="badge rounded-pill
                        <%= sub.active? ? 'bg-success' : sub.pending? ? 'bg-warning text-dark' : sub.pause? ? 'bg-secondary' : 'bg-dark' %>">
                        <%= sub.status %>
                      </span>
                    </div>
                    <small class="text-muted">
                      <%= sub.suburb %> &middot;
                      <%= sub.collection_day %> &middot;
                      #<%= sub.id %>
                      <% if sub.start_date %>
                        &middot; started <%= sub.start_date.strftime('%d %b %Y') %>
                      <% end %>
                    </small>
                  </label>
                </div>
              <% end %>
            </div>

            <p class="text-muted small mb-3">
              Transferring moves the subscription (and all its collections, invoices, and contacts) to
              <strong><%= @destination_user.full_name %></strong>.
              This cannot be undone from the UI — be sure.
            </p>

            <%= f.submit "Transfer selected subscriptions", class: "btn-yellow",
                data: { turbo_confirm: "Transfer the selected subscriptions to #{@destination_user.full_name}?" } %>
          <% end %>
        <% else %>
          <p class="text-muted mb-0"><%= @source_user.full_name %> has no subscriptions to transfer.</p>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
