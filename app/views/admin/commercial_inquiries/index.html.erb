<% status_colors = { "pending" => "#b45309", "contacted" => "#1d4ed8", "converted" => "#108A63", "declined" => "#6b7280" } %>

<div class="admin-container">
  <div class="pt-4 pb-3">
    <p class="dash-eyebrow">Growth</p>
    <h1>Commercial Inquiries</h1>
  </div>

  <div class="fad-event-list">
    <% if @inquiries.any? %>
      <% @inquiries.each do |inquiry| %>
        <div class="fad-event-row">
          <div class="fad-event-row__main">
            <%= link_to inquiry.business_name, admin_commercial_inquiry_path(inquiry), class: "fad-event-row__name" %>
            <span class="fad-event-row__dates">
              <%= inquiry.user.first_name %> <%= inquiry.user.last_name %>
              &middot; <%= inquiry.user.email %>
              &middot; <%= inquiry.estimated_buckets %> buckets
              &middot; <%= inquiry.collection_frequency %>
              &middot; <%= inquiry.preferred_duration %> months
              &middot; <span style="color: <%= status_colors[inquiry.status] %>; font-weight: 600;"><%= inquiry.status.capitalize %></span>
            </span>
          </div>
          <div class="fad-event-row__actions">
            <span class="text-muted small"><%= inquiry.created_at.strftime("%-d %b") %></span>
            <%= link_to "View →", admin_commercial_inquiry_path(inquiry), class: "fad-pill-link" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="fad-empty">No commercial inquiries yet.</p>
    <% end %>
  </div>
</div>
