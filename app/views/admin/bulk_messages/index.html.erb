<div class="user-wrapper">
  <h1>Bulk WhatsApp Messaging</h1>
  <p class="text-muted">Filter customers and generate personalised WhatsApp links for each contact</p>

  <%= form_with url: admin_bulk_messages_path, method: :get, local: true do |f| %>
    <div class="card p-4 mb-4" style="border-radius: 1em;">
      <h3 class="mb-3">Subscription Filters</h3>

      <div class="row g-3">
        <!-- Status Filter -->
        <div class="col-md-3">
          <%= f.label :status_filter, "Status", class: "form-label" %>
          <%= f.select :status_filter,
                       options_for_select([
                         ['— Active —', nil, disabled: true],
                         ['All Active', 'all_active'],
                         ['New Customers (first-time)', 'new_customers'],
                         ['Long-term (12+ months)', 'long_term'],
                         ['— Other —', nil, disabled: true],
                         ['Paused', 'paused'],
                         ['Recently Completed (last 2 weeks)', 'recently_completed'],
                         ['All Completed', 'all_completed'],
                         ['Pending', 'all_pending'],
                         ['Legacy', 'legacy']
                       ], params[:status_filter] || 'all_active'),
                       {},
                       class: "form-select" %>
        </div>

        <!-- Collection Day -->
        <div class="col-md-3">
          <%= f.label :collection_day, "Collection Day", class: "form-label" %>
          <%= f.select :collection_day,
                       options_for_select([['All Days', 'all']] + Subscription.collection_days.keys.map { |day| [day.titleize, day] }, params[:collection_day]),
                       {},
                       class: "form-select" %>
        </div>

        <!-- Suburb -->
        <div class="col-md-3">
          <%= f.label :suburb, "Suburb", class: "form-label" %>
          <%= f.select :suburb,
                       options_for_select([['All Suburbs', 'all']] + Subscription::SUBURBS.map { |s| [s, s] }, params[:suburb]),
                       {},
                       class: "form-select" %>
        </div>

        <!-- Plan -->
        <div class="col-md-3">
          <%= f.label :plan, "Plan", class: "form-label" %>
          <%= f.select :plan,
                       options_for_select([['All Plans', 'all']] + Subscription.plans.keys.map { |p| [p.titleize, p] }, params[:plan]),
                       {},
                       class: "form-select" %>
        </div>

        <!-- Collections Range -->
        <div class="col-md-3">
          <%= f.label :min_collections, "Min Collections", class: "form-label" %>
          <%= f.number_field :min_collections, value: params[:min_collections], class: "form-control", placeholder: "e.g. 5" %>
        </div>

        <div class="col-md-3">
          <%= f.label :max_collections, "Max Collections", class: "form-label" %>
          <%= f.number_field :max_collections, value: params[:max_collections], class: "form-control", placeholder: "e.g. 20" %>
        </div>

        <!-- Date Range -->
        <div class="col-md-3">
          <%= f.label :date_from, "First Sub From", class: "form-label" %>
          <%= f.date_field :date_from, value: params[:date_from], class: "form-control" %>
        </div>

        <div class="col-md-3">
          <%= f.label :date_to, "First Sub To", class: "form-label" %>
          <%= f.date_field :date_to, value: params[:date_to], class: "form-control" %>
        </div>

        <!-- Completed Date Range (shown for recently_completed / all_completed) -->
        <% if %w[recently_completed all_completed].include?(params[:status_filter]) %>
          <div class="col-md-3">
            <%= f.label :completed_from, "Completed From", class: "form-label" %>
            <%= f.date_field :completed_from,
                             value: params[:completed_from] || (params[:status_filter] == 'recently_completed' ? 2.weeks.ago.to_date : nil),
                             class: "form-control" %>
          </div>
          <div class="col-md-3">
            <%= f.label :completed_to, "Completed To", class: "form-label" %>
            <%= f.date_field :completed_to,
                             value: params[:completed_to] || (params[:status_filter] == 'recently_completed' ? Date.today : nil),
                             class: "form-control" %>
          </div>
        <% end %>

        <!-- Collection Date + Subset -->
        <div class="col-12"><hr class="my-2"></div>
        <div class="col-md-3">
          <%= f.label :collection_date, "Collection Date", class: "form-label" %>
          <%= f.date_field :collection_date, value: params[:collection_date], class: "form-control" %>
          <small class="text-muted">Filter by actual collection record on this date</small>
        </div>
        <div class="col-md-9 d-flex align-items-center gap-4 flex-wrap pt-4">
          <% [['all', 'All on this date'], ['normal', 'Normal collection'], ['skipped', 'Skipped'], ['new_customer', 'New customer']].each do |value, label| %>
            <div class="form-check">
              <%= f.radio_button :collection_subset, value,
                                 checked: (params[:collection_subset] || 'all') == value,
                                 class: "form-check-input" %>
              <%= f.label "collection_subset_#{value}", label, class: "form-check-label" %>
            </div>
          <% end %>
        </div>
      </div>

      <hr class="my-4">

      <h3 class="mb-3">Contact Filters</h3>
      <div class="row g-3">
        <!-- Relationship -->
        <div class="col-md-3">
          <%= f.label :relationship, "Relationship", class: "form-label" %>
          <%= f.select :relationship,
                       options_for_select([
                         ['All Contacts', 'all'],
                         ['Owner', 'owner'],
                         ['Spouse', 'spouse'],
                         ['Housemate', 'housemate'],
                         ['Family', 'family'],
                         ['Other', 'other']
                       ], params[:relationship] || 'all'),
                       {},
                       class: "form-select" %>
        </div>

        <!-- Opted-in only -->
        <div class="col-md-3 d-flex align-items-end">
          <div class="form-check mb-2">
            <%= f.check_box :opted_in_only, checked: params[:opted_in_only] == '1', class: "form-check-input" %>
            <%= f.label :opted_in_only, "WhatsApp opted-in only", class: "form-check-label" %>
          </div>
        </div>

        <!-- Primary only -->
        <div class="col-md-3 d-flex align-items-end">
          <div class="form-check mb-2">
            <%= f.check_box :primary_only, checked: params[:primary_only] == '1', class: "form-check-input" %>
            <%= f.label :primary_only, "Owner only (one per subscription)", class: "form-check-label" %>
          </div>
        </div>

        <!-- Non-primary only -->
        <div class="col-md-3 d-flex align-items-end">
          <div class="form-check mb-2">
            <%= f.check_box :non_primary_only, checked: params[:non_primary_only] == '1', class: "form-check-input" %>
            <%= f.label :non_primary_only, "Non-owner contacts only", class: "form-check-label" %>
          </div>
        </div>
      </div>

      <hr class="my-4">

      <h3 class="mb-3">Message</h3>
      <div class="mb-3">
        <%= f.label :message, "WhatsApp Message", class: "form-label" %>
        <%= f.text_area :message,
                        value: params[:message],
                        rows: 6,
                        class: "form-control",
                        placeholder: "Hi {first_name}! Just a reminder that your collection is on {collection_day}..." %>
        <div class="mt-2">
          <small class="text-muted d-block mb-1"><strong>Personalisation tokens:</strong></small>
          <div class="d-flex flex-wrap gap-2">
            <% [
              ['{first_name}', "Contact's first name"],
              ['{last_name}', "Contact's last name"],
              ['{full_name}', "Contact's full name"],
              ['{collection_day}', "Collection day (e.g. Tuesday)"],
              ['{suburb}', "Suburb"],
              ['{plan}', "Plan (Standard / XL)"],
              ['{account_start}', "Subscription start date"],
              ['{relationship}', "Contact's relationship (Owner, Spouse…)"],
              ['{collection_date}', "Collection date (e.g. Tuesday, 25 March)"]
            ].each do |token, description| %>
              <span class="badge bg-light text-dark border" title="<%= description %>"><%= token %></span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Filter & Generate Links", class: "submit-btn" %>
        <%= link_to "Reset", admin_bulk_messages_path, class: "btn btn-secondary-outline" %>
      </div>
    </div>
  <% end %>

  <% if @contacts.present? %>
    <% subscription_count = @contacts.map { |c| c.subscription_id }.uniq.count %>
    <div class="card p-4" style="border-radius: 1em;">
      <h3 class="mb-3">
        Results: <%= @contacts.count %> <%= 'contact'.pluralize(@contacts.count) %>
        <small class="text-muted fw-normal fs-6">across <%= subscription_count %> <%= 'subscription'.pluralize(subscription_count) %></small>
        <% if params[:collection_date].present? && params[:collection_subset].present? && params[:collection_subset] != 'all' %>
          <span class="badge bg-info ms-2" style="font-size: 0.75rem;">
            <%= { 'normal' => 'Normal collection', 'skipped' => 'Skipped', 'new_customer' => 'New customer' }[params[:collection_subset]] %>
          </span>
        <% end %>
      </h3>

      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Contact</th>
              <th>Phone</th>
              <th>Suburb</th>
              <th>Day</th>
              <th>Plan</th>
              <th>Collections</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% @contacts.each do |contact| %>
              <% sub = contact.subscription %>
              <tr>
                <td>
                  <%= link_to subscription_contact_path(sub, contact), class: "link-title" do %>
                    <%= contact.full_name %>
                    <% if contact.is_primary? %>
                      <span class="badge bg-success ms-1" style="font-size: 0.65rem;">Owner</span>
                    <% elsif contact.relationship.present? %>
                      <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;"><%= contact.relationship.titleize %></span>
                    <% end %>
                  <% end %>
                  <% if contact.whatsapp_opt_out? %>
                    <br><small class="text-danger"><i class="fa-brands fa-whatsapp"></i> opted out</small>
                  <% end %>
                </td>
                <td><%= contact.phone_number %></td>
                <td><%= sub&.suburb %></td>
                <td><%= sub&.collection_day&.titleize %></td>
                <td><%= sub&.plan&.titleize %></td>
                <td><%= sub&.total_collections || 0 %></td>
                <td>
                  <% if @message.present? %>
                    <% replacements = {
                      '{first_name}'     => contact.first_name,
                      '{last_name}'      => contact.last_name.to_s,
                      '{full_name}'      => contact.full_name,
                      '{collection_day}' => sub&.collection_day&.titleize.to_s,
                      '{suburb}'         => sub&.suburb.to_s,
                      '{plan}'           => sub&.plan&.titleize.to_s,
                      '{account_start}'  => sub&.start_date&.strftime("%d %b %Y").to_s,
                      '{relationship}'      => (contact.is_primary? ? 'Owner' : contact.relationship&.titleize).to_s,
                      '{collection_date}'   => params[:collection_date].present? ? Date.parse(params[:collection_date]).strftime('%A, %-d %B') : ''
                    } %>
                    <% personalized_message = replacements.reduce(@message) { |msg, (k, v)| msg.gsub(k, v) } %>
                    <% encoded_message = ERB::Util.url_encode(personalized_message) %>
                    <% phone = contact.formatted_phone %>
                    <% if phone.present? && !contact.whatsapp_opt_out? %>
                      <%= link_to "https://wa.me/#{phone.delete('+')}?text=#{encoded_message}",
                                  target: "_blank",
                                  class: "link-title" do %>
                        <i class="fa-brands fa-whatsapp"></i> WhatsApp
                      <% end %>
                    <% elsif contact.whatsapp_opt_out? %>
                      <span class="text-muted"><i class="fa-solid fa-ban"></i> Opted out</span>
                    <% else %>
                      <span class="text-muted">No phone</span>
                    <% end %>
                  <% else %>
                    <span class="text-muted">Enter message above</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% elsif params.key?(:status_filter) %>
    <div class="alert alert-info">
      No contacts match your filter criteria.
    </div>
  <% end %>
</div>
