<div class="driver-wrapper">
  <h1>Products & Stock Management</h1>

  <div class="d-flex gap-2 my-3">
    <%= link_to "New Product", new_admin_product_path, class: "small-yellow-btn" %>
    <%= link_to "View Shop", shop_index_path, class: "small-yellow-btn" %>
  </div>

  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Product</th>
          <th class="text-center">Price</th>
          <th class="text-center">Stock</th>
          <th class="text-center">Active</th>
          <th>Billing Type</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td><%= product.title %></td>
            <td class="text-center">R<%= product.price.to_i %></td>
            <td class="text-center <%= product.out_of_stock? ? 'text-danger' : 'text-success' %>">
              <%= product.stock %>
            </td>
            <td class="text-center"><%= product.is_active ? '✓' : '✗' %></td>
            <td>
              <span class="badge bg-<%= product.quote_only? ? 'warning text-dark' : product.invoice_only? ? 'secondary' : 'success' %>">
                <%= product.billing_type %>
              </span>
            </td>
            <td class="text-end">
              <%= link_to "Edit", edit_admin_product_path(product), class: "small-yellow-btn btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
