<div class="container mt-4">
  <h1>Add participant – <%= @festival_event.name %></h1>

  <%= form_with model: [:admin, @festival_event, @participant], class: "mt-3" do |f| %>
    <% if @participant.errors.any? %>
      <div class="alert alert-danger">
        <% @participant.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", placeholder: "e.g. Chanel" %>
    </div>

    <div class="mb-3">
      <%= f.label :pin, "PIN (min 4 characters)", class: "form-label" %>
      <%= f.text_field :pin, class: "form-control", placeholder: "e.g. 1234 or gooi2026", autocomplete: "off" %>
    </div>

    <%= f.submit "Add participant", class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_festival_event_path(@festival_event), class: "btn btn-link" %>
  <% end %>
</div>
