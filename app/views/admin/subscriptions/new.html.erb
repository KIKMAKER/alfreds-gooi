<div class="gooi-container">
  <div class="outline">
    <div>
      <br>
      <h1>New Subscription for <%= @user.full_name %></h1>
      <p class="text-muted"><%= @user.email %></p>

      <% if @subscription.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @subscription.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @subscription, url: admin_subscriptions_path, method: :post do |f| %>
        <%= hidden_field_tag :user_id, @user.id %>

        <div class="row g-3 mb-4" data-controller="subscription-plan">
          <div class="col-md-4">
            <%= f.label :plan, class: "form-label" %>
            <%= f.select :plan,
                         Subscription.plans.keys.map { |p| [p.titleize, p] },
                         { prompt: "Select plan" },
                         class: "form-select",
                         data: { action: "change->subscription-plan#planChanged" } %>
          </div>

          <div class="col-md-4" data-subscription-plan-target="durationField">
            <%= f.label :duration, "Duration (months)", class: "form-label" %>
            <%= f.select :duration,
                         [[1, 1], [3, 3], [6, 6], [12, 12]],
                         { prompt: "Select duration" },
                         class: "form-select" %>
          </div>

          <div class="col-md-4" data-subscription-plan-target="dateField" style="display:none">
            <%= f.label :start_date, "Collection Date", class: "form-label" %>
            <%= f.date_field :start_date, class: "form-control", data: { controller: "datepicker" } %>
          </div>

          <div class="col-md-4">
            <%= f.label :suburb, class: "form-label" %>
            <%= f.select :suburb,
                         Subscription::SUBURBS.sort,
                         { prompt: "Select suburb" },
                         class: "form-select" %>
          </div>

          <div class="col-md-8">
            <%= f.label :street_address, class: "form-label" %>
            <div data-controller="address-autocomplete" data-address-autocomplete-api-key-value="<%= ENV['MAPBOX_API_KEY'] %>">
              <%= f.text_field :street_address, class: "d-none", data: { address_autocomplete_target: "address" } %>
            </div>
          </div>

          <div class="col-md-4">
            <%= f.label :apartment_unit_number, "Unit / Apt", class: "form-label" %>
            <%= f.text_field :apartment_unit_number, class: "form-control", placeholder: "Optional" %>
          </div>

          <div class="col-md-4">
            <%= f.label :discount_code, "Discount Code", class: "form-label" %>
            <%= f.text_field :discount_code, class: "form-control", placeholder: "Optional" %>
          </div>

          <div class="col-md-4">
            <%= f.label :referral_code, "Referral Code", class: "form-label" %>
            <%= f.text_field :referral_code, class: "form-control", placeholder: "Optional" %>
          </div>

          <div class="col-md-4 d-flex align-items-end">
            <div class="form-check mb-2">
              <%= f.check_box :is_new_customer, checked: true, class: "form-check-input" %>
              <%= f.label :is_new_customer, "New customer (include starter kit)", class: "form-check-label" %>
            </div>
          </div>
        </div>

        <p class="text-muted small mb-4">
          Collection day is set automatically from suburb. Subscription will be created as <strong>pending</strong> — it activates when the invoice is paid.
        </p>

        <%= f.submit "Create Subscription + Send Invoice", class: "btn-yellow" %>
        <%= link_to "Cancel", admin_user_path(@user), class: "btn-today-green ms-2" %>
      <% end %>
    </div>
  </div>
</div>
