<div class="page-container">
  <section class="map-section">
    <div class="container" style="max-width:680px;">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><%= @interest.name %></h1>
        <div class="d-flex gap-2">
          <%= link_to "Edit", edit_admin_interest_path(@interest), class: "btn btn-outline-secondary btn-sm" %>
          <%= button_to "Delete", admin_interest_path(@interest), method: :delete,
                data: { turbo_confirm: "Delete this interest?" },
                class: "btn btn-outline-danger btn-sm" %>
        </div>
      </div>

      <dl class="row">
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">
          <%= mail_to @interest.email, @interest.email %>
        </dd>

        <dt class="col-sm-3">Suburb</dt>
        <dd class="col-sm-9"><%= @interest.suburb %></dd>

        <dt class="col-sm-3">Note</dt>
        <dd class="col-sm-9"><%= @interest.note.presence || "—" %></dd>

        <dt class="col-sm-3">Submitted</dt>
        <dd class="col-sm-9"><%= @interest.created_at.strftime("%-d %b %Y at %H:%M") %></dd>
      </dl>

      <%= link_to "← Back to list", admin_interests_path, class: "btn btn-link ps-0" %>
    </div>
  </section>
</div>
