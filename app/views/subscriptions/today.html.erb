<!--ALFREDS PAGE-->
<div class="driver-wrapper"
     data-controller="drop-off-timer"
     data-drop-off-timer-drivers-day-value="<%= @drivers_day.id %>"
     data-drop-off-timer-current-drop-off-value="<%= @current_drop_off&.id || 0 %>"
     data-drop-off-timer-arrival-time-value="<%= @current_drop_off&.arrival_time&.iso8601 || '' %>"
     data-drop-off-timer-site-name-value="<%= @current_drop_off&.drop_off_site&.name || '' %>">
  <div class="mb-3 text-center link-decorations">
    <h2 class="mb-2">Today's Route</h2>

    <%= link_to "Someone missing from the list?", recently_lapsed_subscriptions_path, class: "link-text" %>
  </div>

  <div class="collection-header">

    <div class="name">
      <p>Name</p>
    </div>
    <div class="bag">
      <p>Collect</p>
    </div>
    <div class="address">
      <p>Address</p>
    </div>
    <p>Message</p>
  </div>
  <div class="collections"  >
    <%#= button_to 'Reset Collection Order', reset_order_drivers_day_collections_path(@drivers_day), method: :post, class: "btn btn-warning", data: { turbo: false } %>
    <ul data-controller="sortable"
        data-sortable-url-value="<%= reorder_drivers_day_path(@drivers_day) %>">
      <% @route_items.each do |item| %>
        <% if item.is_a?(DropOffEvent) %>
          <li class="collection sortable-item <%= 'done' if item.is_done? %>"
              data-sortable-type="drop_off_event"
              data-sortable-id="<%= item.id %>">
            <span class="drag-handle">⠿</span>
            <div class="name" style="display: flex; gap: 8px; align-items: center;">
              <span
                data-drop-off-id="<%= item.id %>"
                data-action="click->drop-off-timer#selectDropOff"
                style="cursor: pointer; font-size: 20px; user-select: none;"
                title="Click to start timer">
                ⏱️
              </span>
              <p><%= link_to "#{item.drop_off_site.name.split.first}", drivers_day_drop_off_event_path(@drivers_day, item)%></p>
            </div>
            <div class="bag">
              <%= link_to "Weigh", drivers_day_drop_off_event_path(@drivers_day, item), class: "small-yellow-btn" %>
            </div>
            <div class="address">
              <%= link_to item.drop_off_site.street_address, "https://maps.google.com/?q=#{item.drop_off_site.street_address}, #{item.drop_off_site.suburb}", target: :_blank %>
            </div>
            <div class="emojies">
              <% omw_message = "Hello #{item.drop_off_site.contact_name}. I am on my way!" %>
              <p class="emoji"><%= link_to "🚗", "https://wa.me/#{item.drop_off_site.phone_number}?text=#{ERB::Util.url_encode(omw_message)}", target: :_blank %></p>
              <% here_message = "Hello #{item.drop_off_site.contact_name}. I am here!" %>
              <p class="emoji"><%= link_to "🏠",  "https://wa.me/#{item.drop_off_site.phone_number}?text=#{ERB::Util.url_encode(here_message)}", target: :_blank %></p>
            </div>
          </li>
        <% else %>
          <li class="collection sortable-item"
              data-sortable-type="collection"
              data-sortable-id="<%= item.id %>">
            <span class="drag-handle">⠿</span>
            <div class="name">
              <p><%= link_to item.subscription.user.first_name.truncate(13), subscription_path(item.subscription) %></p>
              <% if current_user.admin? %>
                <p><%= link_to 'X', collection_path(item), data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} %></p>
              <% end %>
            </div>
            <div class="bag">
              <% if item.skip %>
                <%= link_to "skip", edit_collection_path(item), class: "small-yellow-btn" %>
              <% else %>
                <% if (item.bags || 0) >= 1 %>
                  <%= link_to "#{pluralize(item.bags, 'bag')}", edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif (item.buckets || 0) >= 1 %>
                  <%= link_to "#{pluralize(item.buckets, 'bucket')}", edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif item.new_customer %>
                  <%= link_to "Meet", edit_collection_path(item) , class: "small-yellow-btn"%>
                <% elsif item.subscription.Standard? %>
                  <%= link_to "#{pluralize(item.bags, 'bag')}", edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif item.subscription.XL? %>
                  <%= link_to "#{pluralize(item.buckets&.floor, 'bucket')}", edit_collection_path(item), class: "small-yellow-btn"  %>
                <% elsif item.subscription.Commercial? %>
                  <%= link_to "#{pluralize(item.buckets_45l.to_i + item.buckets_25l.to_i, 'bucket')}", edit_collection_path(item), class: "small-yellow-btn"  %>
                <% else %>
                  <%= link_to "collect", edit_collection_path(item), class: "small-yellow-btn" %>
                <% end %>
              <% end %>
            </div>
            <div class="address">
              <%= link_to item.subscription.street_address&.truncate(20), "https://maps.google.com/?q=#{item.subscription.street_address}", target: :_blank %>
            </div>
            <div class="emojies">
              <p class="emoji"><%= link_to "🚗", item.subscription.user.generate_whatsapp_link("Hello #{item.user.first_name}. I am on my way!"), target: :_blank %></p>
              <p class="emoji"><%= link_to "🏠", item.subscription.user.generate_whatsapp_link("I am at your house."), target: :_blank %></p>
              <p class="emoji"><%= link_to "🪴", item.subscription.user.generate_whatsapp_link("Thank you #{item.user.first_name}, I have got your bag. Hope you have a wonderful weekend."), target: :_blank %></p>
            </div>
          </li>
        <% end %>
      <% end %>
    </ul>
    <!--</ul>-->
  </div>

  <!-- Floating Timer Button -->
  <div class="floating-timer-btn">
    <div class="timer-content">
      <div class="site-name" data-drop-off-timer-target="siteName">
        <%= @current_drop_off&.drop_off_site&.name || 'Select drop-off' %>
      </div>
      <div class="timer-display" data-drop-off-timer-target="timer"></div>
      <button
        class="timer-btn"
        data-drop-off-timer-target="button"
        <%= 'disabled' unless @current_drop_off %>
      >
        <%= @current_drop_off&.arrival_time ? 'Leaving' : "I'm Here" %>
      </button>
      <div class="timer-status" data-drop-off-timer-target="status">
        <%= @current_drop_off&.arrival_time ? 'Timer running...' : 'Ready to record arrival' %>
      </div>
    </div>
  </div>

</div>
