<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title">Missing From List</h1>
      <p class="dd-header__sub">Completed subscriptions not yet renewed</p>
    </div>
    <div class="dd-header__actions">
      <%= link_to "← Today's List", today_subscriptions_path, class: "btn-secondary-outline btn-sm" %>
    </div>
  </div>

  <% if flash[:whatsapp_url] %>
    <div class="dd-form-card dd-form-card--highlight mb-3">
      <div class="dd-form-card__body text-center">
        <p class="fw-semibold mb-2">✓ <%= flash[:added_name] %> added to today's list</p>
        <%= link_to flash[:whatsapp_url], target: "_blank", class: "tiny-yellow-btn" do %>
          <i class="fa-brands fa-whatsapp me-1"></i> WhatsApp <%= flash[:added_name] %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @recently_lapsed.any? %>

    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-rotate-left"></i>
        <h3>Lapsed customers</h3>
      </div>
      <div class="dd-form-card__body p-0">
        <% @recently_lapsed.each do |subscription| %>
          <% user = subscription.user %>
          <% last_collection = subscription.collections.where(skip: false).order(date: :desc).first %>
          <% days_since_last = last_collection ? (Date.today - last_collection.date).to_i : nil %>
          <div class="quick-msg-row">
            <div>
              <div class="quick-msg-row__name"><%= user.first_name %> <%= user.last_name %></div>
              <div class="quick-msg-row__meta">
                <%= subscription.suburb %> &middot;
                ended <%= subscription.end_date.strftime('%-d %b') %>
                <% if days_since_last %>
                  &middot; last collected <%= days_since_last %> days ago
                <% end %>
              </div>
            </div>
            <div class="quick-msg-row__actions">
              <%= button_to "Add + WhatsApp",
                  collect_courtesy_subscription_path(subscription),
                  method: :post,
                  class: "tiny-yellow-btn",
                  data: { turbo_confirm: "Add #{user.first_name} to today's list?" } %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  <% else %>

    <div class="dd-form-card">
      <div class="dd-form-card__body text-center py-4">
        <p class="fs-4 mb-2">🎉</p>
        <p class="fw-semibold mb-1">No lapsed customers on today's route</p>
        <p class="text-muted small mb-3">
          Everyone on today's collection day is either already on the list or has resubscribed.
        </p>
        <%= link_to "Back to Today's List", today_subscriptions_path, class: "tiny-yellow-btn" %>
      </div>
    </div>

  <% end %>

  <div class="dd-form-card mt-3" data-controller="customer-lookup">
    <div class="dd-form-card__header">
      <i class="fa-solid fa-magnifying-glass"></i>
      <h3>Not seeing someone?</h3>
    </div>
    <div class="dd-form-card__body">
      <p class="text-muted small mb-3">Find any customer and add them to today's list.</p>
      <select class="form-select mb-3"
              data-customer-lookup-target="select"
              data-action="change->customer-lookup#pick">
        <option value="">— Select a customer —</option>
        <% @all_customers.each do |cust| %>
          <% sub = cust.subscriptions.max_by(&:created_at) %>
          <% next unless sub %>
          <option value="<%= sub.id %>">
            <%= cust.first_name %> <%= cust.last_name %>
            (<%= sub.suburb %> · <%= sub.collection_day %> · <%= sub.status %>)
          </option>
        <% end %>
      </select>

      <form method="post"
            action=""
            data-customer-lookup-target="form"
            class="d-none">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <input type="submit" value="Add + WhatsApp" class="tiny-yellow-btn">
      </form>
    </div>
  </div>

</div>
