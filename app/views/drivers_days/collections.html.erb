<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title">Collections</h1>
      <p class="dd-header__sub"><%= @drivers_day.date.strftime('%A, %d %B %Y') %> &middot; <%= @collections.length %> stops</p>
    </div>
    <div class="dd-header__actions">
      <%= link_to drivers_day_path(@drivers_day), class: "tiny-yellow-btn" do %>
        <i class="fa-solid fa-arrow-left"></i> Back
      <% end %>
    </div>
  </div>

  <div class="dd-list">
    <% @collections.each_with_index do |collection, i| %>
      <div class="dd-collection-item <%= 'dd-collection-item--skip' if collection.skip? %>">

        <div class="dd-collection-item__pos"><%= i + 1 %></div>

        <div class="dd-collection-item__main">
          <div class="dd-collection-item__name">
            <%= collection.subscription&.display_name || "Unknown" %>
            <% if collection.subscription&.protein_waste_stream? %>
              <span class="dd-collection-badge dd-collection-badge--protein">
                <i class="fa-solid fa-drumstick-bite"></i> Protein
              </span>
            <% end %>
            <% if collection.new_customer %>
              <span class="dd-collection-badge dd-collection-badge--new">New</span>
            <% end %>
            <% if collection.skip? %>
              <span class="dd-collection-badge dd-collection-badge--skip">Skipped</span>
            <% end %>
            <% if collection.done? %>
              <span class="dd-collection-badge dd-collection-badge--done">Done</span>
            <% end %>
          </div>

          <div class="dd-collection-item__meta">
            <% sub = collection.subscription %>
            <% if sub&.Commercial? %>
              <span><%= collection.buckets_45l %>&times;45L, <%= collection.buckets_25l %>&times;25L</span>
            <% elsif sub&.XL? %>
              <span><%= collection.buckets %> buckets</span>
            <% else %>
              <span><%= collection.bags %> bags</span>
            <% end %>
            <% if sub&.protein_waste_stream? %>
              <span class="dd-collection-item__note dd-collection-item__note--protein">
                <i class="fa-solid fa-box"></i> Sealed swap buckets — protein stream
              </span>
            <% end %>
            <% if collection.kiki_note.present? %>
              <span class="dd-collection-item__note">
                <i class="fa-solid fa-note-sticky"></i> <%= collection.kiki_note %>
              </span>
            <% end %>
            <% if collection.alfred_message.present? %>
              <span class="dd-collection-item__note dd-collection-item__note--alfred">
                <i class="fa-solid fa-message"></i> <%= collection.alfred_message %>
              </span>
            <% end %>
          </div>
        </div>

        <div class="dd-list-item__actions">
          <%= link_to edit_collection_path(collection), class: "tiny-yellow-btn" do %>
            <i class="fa-solid fa-pen"></i>
          <% end %>
          <%= link_to collection_path(collection),
              data: { turbo_method: :delete, turbo_confirm: "Delete this collection?" },
              class: "tiny-yellow-btn" do %>
            <i class="fa-solid fa-trash"></i>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>

  <div class="quick-actions">
    <%= link_to drivers_day_path(@drivers_day), class: "action-btn" do %>
      <i class="fa-solid fa-chart-bar"></i> Day Summary
    <% end %>
    <%= link_to drivers_days_path, class: "action-btn" do %>
      <i class="fa-solid fa-list"></i> All Days
    <% end %>
  </div>

</div>
