<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title">Well done!</h1>
      <p class="dd-header__sub">Almost there — just a few last details</p>
    </div>
  </div>

  <div class="dd-form-card">
    <div class="dd-form-card__header">
      <i class="fa-solid fa-flag-checkered"></i>
      <h3>Wrap up the day</h3>
    </div>
    <div class="dd-form-card__body">
      <p class="text-muted mb-3">Remember to clean the buckets and put away the keys.</p>

      <%= simple_form_for @drivers_day, url: end_drivers_day_path do |f| %>

        <% flag_field = @drivers_day.end_time_flag_field %>
        <% if @drivers_day.errors[:end_time].any? || @drivers_day.errors[:start_time].any? %>
          <% fixing_start = flag_field == :start_time %>
          <div class="dd-endtime-warning">
            <div class="dd-endtime-warning__head">
              <i class="fa-solid fa-triangle-exclamation"></i>
              <span><%= fixing_start ? "Check the start time" : "Check the finish time" %></span>
            </div>
            <p class="dd-endtime-warning__msg">
              <%= @drivers_day.errors.full_messages_for(flag_field).first %>
            </p>

            <% if fixing_start %>
              <label class="bucket-scale-label">What time did you actually start?</label>
              <%= f.datetime_local_field :start_time,
                    value: @drivers_day.start_time&.strftime("%Y-%m-%dT%H:%M"),
                    class: "form-control dd-date-input" %>
            <% else %>
              <label class="bucket-scale-label">What time did you actually finish?</label>
              <%= f.datetime_local_field :end_time,
                    value: @drivers_day.end_time&.strftime("%Y-%m-%dT%H:%M"),
                    class: "form-control dd-date-input" %>
            <% end %>

            <label class="dd-endtime-warning__override">
              <%= check_box_tag :override_end_time_warning, "1", params[:override_end_time_warning].present? %>
              <%= fixing_start ? "It really was that quick — end it anyway" : "It really was that long — end it anyway" %>
            </label>
          </div>
        <% end %>

        <div class="bucket-scale-wrap">
          <label class="bucket-scale-label">Total buckets collected</label>
          <%= f.input_field :total_buckets,
                as: :integer,
                min: 0,
                placeholder: "0",
                required: true,
                class: "bucket-scale-input" %>
        </div>

        <div class="bucket-scale-wrap mt-3">
          <label class="bucket-scale-label">End KMs</label>
          <%= f.input_field :end_kms,
                as: :integer,
                min: 0,
                placeholder: "0",
                required: true,
                class: "bucket-scale-input" %>
        </div>

        <div class="form-group mt-3">
          <%= f.label :message_from_alfred, "Any note for Kiki?", class: "bucket-scale-label" %>
          <%= f.text_area :message_from_alfred, class: "form-control", rows: 3 %>
        </div>

        <div class="mt-4">
          <%= f.submit "Thank you!", class: "submit-btn w-100" %>
        </div>
      <% end %>
    </div>
  </div>


</div>
