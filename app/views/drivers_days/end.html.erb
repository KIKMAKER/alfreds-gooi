<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title">Well done!</h1>
      <p class="dd-header__sub">Almost there — just a few last details</p>
    </div>
  </div>

  <div class="dd-form-card">
    <div class="dd-form-card__header">
      <i class="fa-solid fa-flag-checkered"></i>
      <h3>Wrap up the day</h3>
    </div>
    <div class="dd-form-card__body">
      <p class="text-muted mb-3">Remember to clean the buckets and put away the keys.</p>

      <%= simple_form_for @drivers_day, url: end_drivers_day_path do |f| %>

        <div class="bucket-scale-wrap">
          <label class="bucket-scale-label">Total buckets collected</label>
          <%= f.input_field :total_buckets,
                as: :integer,
                min: 0,
                placeholder: "0",
                required: true,
                class: "bucket-scale-input" %>
        </div>

        <div class="bucket-scale-wrap mt-3">
          <label class="bucket-scale-label">End KMs</label>
          <%= f.input_field :end_kms,
                as: :integer,
                min: 0,
                placeholder: "0",
                required: true,
                class: "bucket-scale-input" %>
        </div>

        <div class="form-group mt-3">
          <%= f.label :message_from_alfred, "Any note for Kiki?", class: "bucket-scale-label" %>
          <%= f.text_area :message_from_alfred, class: "form-control", rows: 3 %>
        </div>

        <div class="mt-4">
          <%= f.submit "Thank you!", class: "submit-btn w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="dd-form-card mt-3">
    <div class="dd-form-card__header">
      <i class="fa-brands fa-whatsapp"></i>
      <h3>Send tomorrow's gooi message</h3>
    </div>
    <div class="dd-form-card__body">
      <p class="text-muted mb-3">Let tomorrow's customers know collection is coming.</p>
      <%# Phase 2: replace href with gooi_message_drivers_day_path(@drivers_day) %>
      <%= link_to "#", class: "btn-yellow w-100 disabled", aria: { disabled: true } do %>
        <i class="fa-brands fa-whatsapp"></i> Send Gooi Message
      <% end %>
    </div>
  </div>

</div>
