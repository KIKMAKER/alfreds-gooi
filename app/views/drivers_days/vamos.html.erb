<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title">Good morning, <%= current_user.first_name %></h1>
      <p class="dd-header__sub"><%= @today %></p>
    </div>
  </div>

  <% if @collections.empty? %>
    <div class="dd-form-card">
      <div class="dd-form-card__body">
        <p>No collections waiting for you today.</p>
        <p>But I love that you checked...</p>
      </div>
    </div>

  <% else %>
    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-box-open"></i>
        <h3><%= pluralize(@count, 'parcel') %> waiting to be collected</h3>
      </div>

      <% if @new_customers&.any? %>
        <div class="dd-form-card__body">
          <p class="mb-3"><strong>and <%= pluralize(@new_customers.count, 'new customer') %> to meet!</strong></p>
          <% @new_customers.each do |collection| %>
            <div class="dd-note mb-2">
              <p class="mb-1"><strong><%= collection.subscription.display_name %></strong></p>
              <p class="mb-1 text-muted"><%= collection.subscription.street_address %></p>
              <%= link_to collection.subscription.user.generate_whatsapp_link("Hello from gooi! I will be coming past today to drop off your starter kit. Please add this number to your contacts so that you can recieve our weekly reminders about collection day. Welcome to gooi! It's a joy to have you onboard."), target: :_blank, class: "btn-yellow btn-sm mt-1" do %>
                <i class="fa-brands fa-whatsapp whatsapp-icon"></i> Message <%= collection.subscription.display_name.split.first %>
              <% end %>
            </div>
          <% end %>
          <p class="mt-3"><strong>Take <%= pluralize(@new_customers.count, 'bucket') %> for them!</strong></p>
        </div>
      <% end %>
    </div>

    <% unless @drivers_day.note_nil_zero? %>
      <div class="dd-form-card">
        <div class="dd-form-card__header">
          <i class="fa-solid fa-note-sticky"></i>
          <h3>Note for today</h3>
        </div>
        <div class="dd-form-card__body">
          <p><%= @drivers_day.note %></p>
        </div>
      </div>
    <% end %>

    <% if @orders_for_delivery&.any? %>
      <div class="dd-form-card">
        <div class="dd-form-card__header">
          <i class="fa-solid fa-box"></i>
          <h3><%= pluralize(@orders_for_delivery.count, 'order') %> to deliver today</h3>
        </div>
        <div class="dd-form-card__body">
          <% @orders_for_delivery.each do |order| %>
            <div class="dd-note mb-2">
              <p class="mb-1"><strong><%= order.collection.subscription.display_name %></strong></p>
              <% order.order_items.each do |item| %>
                <p class="mb-0 text-muted"><%= item.quantity %>× <%= item.product.title %></p>
              <% end %>
            </div>
          <% end %>
          <p class="text-muted mt-2">Make sure to take them with you!</p>
        </div>
      </div>
    <% end %>

    <div class="dd-form-card mt-3">
      <div class="dd-form-card__header">
        <i class="fa-brands fa-whatsapp"></i>
        <h3>Message tomorrow's customers</h3>
      </div>
      <div class="dd-form-card__body">
        <p class="text-muted mb-3">Send a heads-up to the next day's route before you set off.</p>
        <%= link_to driver_messages_path, class: "btn-yellow w-100" do %>
          <i class="fa-brands fa-whatsapp"></i> Message a Day
        <% end %>
      </div>
    </div>

  <% end %>

  <% if @drivers_day.end_time.present? %>
    <%= link_to "View Stats", complete_drivers_day_path(@drivers_day), class: "btn-yellow w-100 mt-3" %>
  <% else %>
    <%= link_to "Let's go!", start_drivers_day_path(@drivers_day), class: "btn-yellow w-100 mt-3" %>
  <% end %>

</div>
