<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title">Before you go…</h1>
      <p class="dd-header__sub">A few things to check first</p>
    </div>
  </div>

  <% if @subscriptions.empty? %>
    <div class="dd-form-card">
      <div class="dd-form-card__body">
        <p>No subscriptions waiting for you today.</p>
      </div>
    </div>

  <% else %>
    <% if @skip_subscriptions.nil? %>
      <div class="dd-form-card">
        <div class="dd-form-card__body">
          <p>Collections haven't all loaded yet. Maybe give Kiki a call?</p>
        </div>
      </div>

    <% else %>

      <% if @skip_subscriptions.any? %>
        <div class="dd-form-card">
          <div class="dd-form-card__header">
            <i class="fa-solid fa-ban"></i>
            <h3><%= pluralize(@skip_subscriptions.count, 'house') %> asked to be skipped</h3>
          </div>
          <div class="dd-form-card__body">
            <% @skip_subscriptions.each do |sub| %>
              <p class="mb-1"><strong><%= sub.display_name %></strong> — <%= sub.street_address %></p>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @bags_needed.any? %>
        <div class="dd-form-card">
          <div class="dd-form-card__header">
            <i class="fa-solid fa-bag-shopping"></i>
            <h3><%= pluralize(@bags_needed.count, 'house needs') %> <%= @total_bags_needed %> bags</h3>
          </div>
          <div class="dd-form-card__body">
            <% @bags_needed.each do |sub| %>
              <p class="mb-1"><strong><%= sub.collections.max_by(&:id).needs_bags %> bags</strong> for <%= sub.display_name %> — <%= sub.street_address %></p>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @products_needed.any? %>
        <div class="dd-form-card">
          <div class="dd-form-card__header">
            <i class="fa-solid fa-box"></i>
            <h3>Products to deliver today</h3>
          </div>
          <div class="dd-form-card__body">
            <% @products_needed.each do |item| %>
              <p class="mb-1"><strong><%= item[:quantity] %>×</strong> <%= item[:product].title %></p>
            <% end %>
            <p class="text-muted mt-2">Make sure to take them with you!</p>
          </div>
        </div>
      <% end %>

      <% if @recently_lapsed.any? %>
        <div class="dd-form-card">
          <div class="dd-form-card__header">
            <i class="fa-solid fa-clock-rotate-left"></i>
            <h3><%= pluralize(@recently_lapsed.count, 'customer') %> recently lapsed</h3>
          </div>
          <div class="dd-form-card__body">
            <p class="text-muted mb-2">Their subscriptions ended in the last 2 weeks. You can collect from them as a courtesy.</p>
            <%= link_to "Message recently lapsed customers", recently_lapsed_subscriptions_path, class: "btn-yellow btn-sm" %>
          </div>
        </div>
      <% end %>

    <% end %>
  <% end %>

  <div class="dd-form-card">
    <div class="dd-form-card__header">
      <i class="fa-solid fa-car"></i>
      <h3>Let's get to it!</h3>
    </div>
    <div class="dd-form-card__body">
      <%= simple_form_for @drivers_day, url: start_drivers_day_path do |f| %>
        <div class="bucket-scale-wrap">
          <label class="bucket-scale-label">Starting KMs</label>
          <%= f.input_field :start_kms,
                as: :integer,
                min: 0,
                placeholder: "0",
                autofocus: true,
                required: true,
                class: "bucket-scale-input" %>
        </div>
        <div class="mt-3">
          <%= f.submit "Time to vamos!", class: "submit-btn w-100" %>
        </div>
      <% end %>
    </div>
  </div>

</div>
