<div class="drivers-day-container">

  <% if @drivers_day&.end_time && @stat %>

    <div class="dd-header">
      <div>
        <h1 class="dd-header__title">Day complete!</h1>
        <p class="dd-header__sub">Thank you for your work today</p>
      </div>
      <div class="dd-header__actions">
        <%= image_tag 'Alfred Sticker.svg', class: 'avatar-small' %>
      </div>
    </div>

    <%# ── Trees equivalent ──────────────────────────────────────── %>
    <% if @drivers_day.end_kms.nil? %>
      <div class="dd-form-card">
        <div class="dd-form-card__header">
          <i class="fa-solid fa-road"></i>
          <h3>End KMs missing</h3>
        </div>
        <div class="dd-form-card__body">
          <p class="text-muted mb-3">The end kms didn't save. Pop them in here:</p>
          <%= simple_form_for @drivers_day do |f| %>
            <div class="bucket-scale-wrap">
              <label class="bucket-scale-label">End KMs</label>
              <%= f.input_field :end_kms, as: :integer, min: 0, placeholder: "0", required: true, class: "bucket-scale-input" %>
            </div>
            <div class="mt-3">
              <%= f.submit "Save KMs", class: "submit-btn w-100" %>
            </div>
          <% end %>
        </div>
      </div>

    <% else %>
      <div class="dd-form-card">
        <div class="dd-form-card__header">
          <i class="fa-solid fa-tree"></i>
          <h3>Environmental impact</h3>
        </div>
        <div class="dd-form-card__body">
          <p class="mb-1">We planted the equivalent of <strong><%= number_with_precision(@stat.trees_net, precision: 2) %> trees</strong></p>
          <p class="text-muted mb-0"><small>From waste: <%= number_with_precision(@stat.trees_gross, precision: 2) %> · To offset driving: <%= number_with_precision(@stat.trees_to_offset_drive, precision: 2) %></small></p>
        </div>
      </div>
    <% end %>

    <% unless @drivers_day.start_time && @drivers_day.end_time %>
      <div class="dd-form-card">
        <div class="dd-form-card__header">
          <i class="fa-solid fa-clock"></i>
          <h3>Times not saved</h3>
        </div>
        <div class="dd-form-card__body">
          <p class="text-muted mb-3">Start/end time wasn't saved. Enter them here:</p>
          <%= simple_form_for @drivers_day do |f| %>
            <%= f.input :start_time, label: "Start time", required: true %>
            <%= f.input :end_time, label: "End time", required: true %>
            <div class="mt-3">
              <%= f.submit "Save times", class: "submit-btn w-100" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Stats grid ─────────────────────────────────────────────── %>
    <p class="dd-section-heading">Today's Numbers</p>
    <div class="stats-grid">

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #3c8a63 0%, #108A63 100%);">
          <i class="fa-solid fa-weight-hanging"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= number_with_precision(@stat.net_kg, precision: 1) %></div>
          <div class="stat-label">Net kg</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #FBB718 0%, #f0a500 100%);">
          <i class="fa-solid fa-bucket"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= @stat.bucket_count %></div>
          <div class="stat-label">Buckets (<%= @stat.full_count %> F / <%= @stat.half_count %> H)</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #3c8a63 0%, #84cba3 100%);">
          <i class="fa-solid fa-equals"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= number_with_precision(@stat.full_equiv, precision: 1) %></div>
          <div class="stat-label">Full-equiv</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #3c8a63 0%, #108A63 100%);">
          <i class="fa-solid fa-scale-balanced"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= number_with_precision(@stat.avg_kg_bucket, precision: 1) %></div>
          <div class="stat-label">Avg kg / bucket</div>
          <div class="stat-sub">per full-equiv: <%= number_with_precision(@stat.avg_kg_full, precision: 1) %></div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #FBB718 0%, #F0CD54 100%);">
          <i class="fa-solid fa-house"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value"><%= @stat.households %></div>
          <div class="stat-label">Households</div>
          <div class="stat-sub">Bags: <%= @stat.bags_sum %></div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
          <i class="fa-solid fa-stopwatch"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value">
            <% if @stat.route_hours %><%= number_with_precision(@stat.route_hours, precision: 1) %>h<% else %>—<% end %>
          </div>
          <div class="stat-label">Route time</div>
          <% if @stat.stops_per_hr %>
            <div class="stat-sub"><%= number_with_precision(@stat.stops_per_hr, precision: 1) %>/h · <%= number_with_precision(@stat.kg_per_hr, precision: 1) %> kg/h</div>
          <% end %>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #3c8a63 0%, #108A63 100%);">
          <i class="fa-solid fa-road"></i>
        </div>
        <div class="stat-content">
          <div class="stat-value">
            <% if @stat.kms %><%= @stat.kms %> km<% else %>—<% end %>
          </div>
          <div class="stat-label">Distance</div>
          <% if @stat.kg_per_km %>
            <div class="stat-sub"><%= number_with_precision(@stat.kg_per_km, precision: 1) %> kg/km</div>
          <% end %>
        </div>
      </div>

    </div>

    <p class="text-muted text-center mt-2 mb-4">Travel safe, see you next time.</p>

    <div class="dd-form-card dd-form-card--highlight mb-3">
      <div class="dd-form-card__header">
        <i class="fa-brands fa-whatsapp"></i>
        <h3>Message tomorrow's customers</h3>
      </div>
      <div class="dd-form-card__body">
        <p class="text-muted mb-3">Send a heads-up to tomorrow's route before you head off.</p>
        <%= link_to driver_messages_path, class: "btn-yellow w-100" do %>
          <i class="fa-brands fa-whatsapp"></i> Message a Day
        <% end %>
      </div>
    </div>

    <%= link_to "View today's collections", today_subscriptions_path, class: "btn-yellow w-100 mb-4" %>

    <%= render 'daily_snapshot',
          drivers_day: @drivers_day,
          new_customers: @new_customers,
          compost_kg: @compost_kg,
          landfill_m3: @landfill_m3,
          kg_diverted: @kg_diverted,
          customers_served: @customers_served,
          buckets_diverted: @buckets_diverted,
          co2_avoided: @co2_avoided,
          trees_equivalent: @trees_equivalent %>

  <% else %>
    <div class="dd-header">
      <div>
        <h1 class="dd-header__title">No stats yet</h1>
        <p class="dd-header__sub">Complete your day first to see your stats.</p>
      </div>
    </div>
    <%= link_to "Back to Welcome", vamos_drivers_day_path(@drivers_day), class: "btn-yellow w-100 mt-3" %>
  <% end %>

</div>
