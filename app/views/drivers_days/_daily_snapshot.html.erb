<%# Daily Impact Snapshot Card - All variables prepared in controller %>
<div class="daily-snapshot-card">
  <div class="snapshot-header">
    <div class="logo-date-row">
      <div class="gooi-logo-snapshot">gooi report<span class="sparkle">✨</span></div>
      <div class="snapshot-date"><%= drivers_day.date.strftime('%A, %B %d, %Y').upcase %></div>
    </div>
    <!--<h1 class="snapshot-headline">
      Today we kept <span class="highlight"><%#= number_with_delimiter(@kg_diverted) %></span> kg from landfills
    </h1>-->
  </div>

  <div class="snapshot-body">
    <div class="snapshot-stats-grid">
      <div class="snapshot-stat-item">
        <div class="snapshot-stat-value"><%= customers_served %></div>
        <div class="snapshot-stat-label">Customers Served</div>
      </div>

      <div class="snapshot-stat-item">
        <div class="snapshot-stat-value"><%= number_with_precision(kg_diverted, precision: 1) %></div>
        <div class="snapshot-stat-label">Collected (kg)</div>
      </div>

      <div class="snapshot-stat-item">
        <div class="snapshot-stat-value"><%= new_customers %></div>
        <div class="snapshot-stat-label">New Households</div>
      </div>

      <div class="snapshot-stat-item">
        <div class="snapshot-stat-value"><%= compost_kg %></div>
        <div class="snapshot-stat-label">Compost Created (kg)</div>
      </div>
    </div>

    <div class="impact-section">
      <div class="impact-title">Environmental Impact</div>
      <div class="impact-stats">
        <div class="impact-item">
          <div class="impact-value"><%= number_with_delimiter(co2_avoided) %></div>
          <div class="impact-desc">CO₂ emissions avoided</div>
        </div>
        <div class="impact-item">
          <div class="impact-value"><%= trees_equivalent %></div>
          <div class="impact-desc">tree seedlings grown for 10 years</div>
        </div>
        <div class="impact-item">
          <div class="impact-value"><%= landfill_m3 %></div>
          <div class="impact-desc">landfill space saved (m<sup>3</sup>)</div>
        </div>
      </div>
    </div>
  </div>

  <% if low_collection_subs&.any? %>
    <div class="snapshot-new-customers" style="margin: 1.5rem 0; padding: 1rem 1.5rem; background: #f9f3e3; border-radius: 12px;">
      <div class="impact-title" style="margin-bottom: 0.5rem;">Getting started (≤2 collections)</div>
      <ul style="margin: 0; padding-left: 1.2rem;">
        <% low_collection_subs.each do |sub| %>
          <li style="font-size: 0.95rem; margin-bottom: 0.25rem;">
            <%= sub.display_name %> — <%= sub.suburb %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="snapshot-footer">
    <% site_names = drivers_day.drop_off_events.map { |e| e.drop_off_site&.name }.compact.uniq %>
    <p>Together we're building <strong><%= site_names.any? ? site_names.to_sentence : "a healthier planet" %></strong>.</p>
  </div>
</div>
