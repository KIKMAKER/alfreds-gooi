<div class="drivers-day-container">

  <div class="dd-header">
    <div>
      <h1 class="dd-header__title"><%= @drivers_day.date.strftime("%A, %-d %b") %></h1>
      <p class="dd-header__sub">Today's route</p>
    </div>
    <div class="dd-header__actions">
      <%= link_to "Someone missing?", missing_customers_drivers_day_path(@drivers_day), class: "tiny-yellow-btn" %>
      <%= button_to "Optimise", optimise_route_path(drivers_day_id: @drivers_day.id), method: :patch, class: "tiny-yellow-btn", form: { data: { turbo: false } } %>
    </div>
  </div>

  <div class="route-day-nav">
    <% if @prev_day %>
      <%= link_to "←", route_drivers_days_path(date: @prev_day.date), class: "route-day-nav__arrow" %>
    <% else %>
      <span class="route-day-nav__arrow route-day-nav__arrow--disabled">←</span>
    <% end %>
    <span class="route-day-nav__label"><%= @drivers_day.date.strftime("%A, %-d %b") %></span>
    <% if @next_day %>
      <%= link_to "→", route_drivers_days_path(date: @next_day.date), class: "route-day-nav__arrow" %>
    <% else %>
      <span class="route-day-nav__arrow route-day-nav__arrow--disabled">→</span>
    <% end %>
  </div>

  <div class="collection-header">
    <div class="name"><p>Name</p></div>
    <div class="bag"><p>Collect</p></div>
    <div class="address"><p>Address</p></div>
  </div>

  <div class="collections">
    <ul data-controller="sortable"
        data-sortable-url-value="<%= reorder_drivers_day_path(@drivers_day) %>">
      <% @route_items.each do |item| %>
        <% if item.is_a?(DropOffEvent) %>
          <li class="collection sortable-item"
              data-sortable-type="drop_off_event"
              data-sortable-id="<%= item.id %>">
            <span class="drag-handle">⠿</span>
            <div class="name">
              <p><%= link_to "#{item.drop_off_site.name.split.first}", drivers_day_drop_off_event_path(@drivers_day, item) %></p>
            </div>
            <div class="bag">
              <%= link_to "Weigh", drivers_day_drop_off_event_path(@drivers_day, item), class: "small-yellow-btn" %>
            </div>
            <div class="address">
              <%= link_to item.drop_off_site.street_address&.truncate(20), "https://maps.google.com/?q=#{item.drop_off_site.street_address}, #{item.drop_off_site.suburb}", target: :_blank %>
            </div>
          </li>

        <% else %>
          <li class="collection sortable-item"
              data-sortable-type="collection"
              data-sortable-id="<%= item.id %>">
            <span class="drag-handle">⠿</span>
            <div class="name">
              <p><%= link_to item.subscription.display_name.truncate(13), admin_subscription_path(item.subscription) %></p>
              <% if current_user.admin? %>
                <p><%= link_to 'X', collection_path(item), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></p>
              <% end %>
            </div>
            <div class="bag">
              <% if item.skip %>
                <%= link_to "skip", edit_collection_path(item), class: "small-yellow-btn" %>
              <% else %>
                <% if (item.bags || 0) >= 1 %>
                  <%= link_to pluralize(item.bags, 'bag'), edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif (item.buckets || 0) >= 1 %>
                  <%= link_to pluralize(item.buckets, 'bucket'), edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif item.new_customer %>
                  <%= link_to "Meet #{item.subscription.display_name.split.first}", edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif item.subscription.user.drop_off? %>
                  <%= link_to "Drop off", edit_collection_path(item), class: "small-yellow-btn" %>
                <% elsif item.subscription.Commercial? %>
                  <%= link_to pluralize(item.buckets_45l.to_i + item.buckets_25l.to_i, 'bucket'), edit_collection_path(item), class: "small-yellow-btn" %>
                <% else %>
                  <%= link_to "Collect", edit_collection_path(item), class: "small-yellow-btn" %>
                <% end %>
              <% end %>
            </div>
            <div class="address">
              <%= link_to item.subscription.street_address&.truncate(20), "https://maps.google.com/?q=#{item.subscription.street_address}", target: :_blank %>
            </div>
          </li>
        <% end %>
      <% end %>
    </ul>
  </div>

  <div class="mt-4">
    <% if current_user.admin? %>
      <%= link_to "Notes", today_notes_path, class: "tiny-yellow-btn mb-2" %>
    <% end %>
    <% if current_user.driver? || current_user.admin? %>
      <%= link_to "End Day", end_drivers_day_path(@drivers_day), class: "btn-yellow w-100" %>
    <% end %>
  </div>

</div>
