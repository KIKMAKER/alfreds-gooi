<div class="admin-container">
  <% if @show_index_link %>
    <%= link_to "← All your sites", drop_off_site_managers_path, class: "fad-pill-link d-inline-block mb-3" %>
  <% end %>

  <div class="pt-3 pb-2">
    <p class="dash-eyebrow">Drop-Off Site</p>
    <h1>Welcome, <%= current_user.first_name || @drop_off_site.contact_name %>!</h1>
    <p class="text-muted">Thank you for partnering with Alfred's Gooi to divert organic waste from landfill.</p>
  </div>

  <% if @drop_off_site.photo.attached? %>
    <div class="mb-4" style="border-radius: 1em; overflow: hidden; max-height: 280px;">
      <%= image_tag @drop_off_site.photo, style: "width: 100%; height: 280px; object-fit: cover;" %>
    </div>
  <% end %>

  <%# KPI strip %>
  <div class="row g-3 mb-4">
    <div class="col-6">
      <div class="dash-kpi-card">
        <div class="dash-kpi-label">Total weight collected</div>
        <div class="dash-kpi-value"><%= number_with_precision(@drop_off_site.total_weight_kg, precision: 1) %> kg</div>
      </div>
    </div>
    <div class="col-6">
      <div class="dash-kpi-card">
        <div class="dash-kpi-label">Total drop-offs</div>
        <div class="dash-kpi-value"><%= @drop_off_site.total_dropoffs_count %></div>
        <% if @drop_off_site.total_dropoffs_count > 0 %>
          <div class="dash-kpi-label mt-2">
            Avg <%= number_with_precision(@drop_off_site.total_weight_kg / @drop_off_site.total_dropoffs_count, precision: 1) %> kg / visit
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Site info %>
  <div class="dash-category-card mb-4">
    <div class="fad-card-header mb-3">
      <span class="dash-category-heading"><%= @drop_off_site.name %></span>
      <div class="fad-action-bar">
        <%= link_to "Edit details", edit_drop_off_site_manager_path(@drop_off_site), class: "fad-pill-link" %>
        <% whatsapp_message = "Hello, it is #{@drop_off_site.contact_name} from #{@drop_off_site.name}. Please contact me." %>
        <%= link_to "WhatsApp Alfred's Gooi",
              "https://wa.me/27785325513?text=#{ERB::Util.url_encode(whatsapp_message)}",
              target: :_blank, class: "fad-pill-link" %>
      </div>
    </div>
    <table class="fad-table">
      <tr>
        <td class="fad-table__meta">Collection day</td>
        <td><%= @drop_off_site.collection_day %></td>
      </tr>
      <tr>
        <td class="fad-table__meta">Address</td>
        <td><%= @drop_off_site.street_address %>, <%= @drop_off_site.suburb %></td>
      </tr>
      <tr>
        <td class="fad-table__meta">Contact</td>
        <td><%= @drop_off_site.contact_name %></td>
      </tr>
      <tr>
        <td class="fad-table__meta">Phone</td>
        <td><%= @drop_off_site.phone_number %></td>
      </tr>
      <% if @drop_off_site.notes.present? %>
        <tr>
          <td class="fad-table__meta">Notes</td>
          <td><%= @drop_off_site.notes %></td>
        </tr>
      <% end %>
    </table>
  </div>

  <%# Recent events %>
  <div class="dash-category-card mb-5">
    <div class="dash-category-heading mb-3">Recent drop-off events</div>
    <% if @recent_events.any? %>
      <table class="fad-table">
        <thead>
          <tr>
            <th>Date</th>
            <th class="fad-table__val">Weight</th>
            <th class="fad-table__val">Buckets</th>
            <th class="fad-table__val">Status</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_events.each do |event| %>
            <tr>
              <td><%= event.date.strftime("%-d %b") %></td>
              <td class="fad-table__val"><%= number_with_precision(event.total_weight_from_buckets, precision: 1) %> kg</td>
              <td class="fad-table__val"><%= event.buckets.count %></td>
              <td class="fad-table__val">
                <% if event.is_done %>
                  <span style="color: #108A63; font-weight: 600;">Done</span>
                <% else %>
                  <span style="color: #b45309; font-weight: 600;">Pending</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="fad-empty">No drop-off events recorded yet.</p>
    <% end %>
  </div>
</div>
