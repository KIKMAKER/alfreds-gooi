<div class="admin-container">
  <div class="pt-4 pb-3">
    <p class="dash-eyebrow">Drop-Off Sites</p>
    <h1>Your Sites</h1>
  </div>

  <div class="fad-event-list">
    <% @drop_off_sites.each do |site| %>
      <div class="fad-event-row">
        <div class="fad-event-row__main">
          <%= link_to site.name, drop_off_site_manager_path(site), class: "fad-event-row__name" %>
          <span class="fad-event-row__dates">
            <%= site.collection_day %> &middot; <%= site.suburb %> &middot; <%= number_with_precision(site.total_weight_kg, precision: 1) %> kg collected
          </span>
        </div>
        <div class="fad-event-row__actions">
          <%= link_to "View →", drop_off_site_manager_path(site), class: "fad-pill-link" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
