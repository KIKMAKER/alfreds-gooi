<div class="admin-container">
  <div class="pt-4 pb-2">
    <p class="dash-eyebrow">Drop-Off Site</p>
    <h1>Edit Contact Details</h1>
    <p class="text-muted">Keep your contact info up to date for <%= @drop_off_site.name %>.</p>
  </div>

  <%= form_with model: @drop_off_site, url: drop_off_site_manager_path(@drop_off_site), method: :patch do |f| %>
    <% if @drop_off_site.errors.any? %>
      <div class="alert alert-danger mb-3">
        <ul class="mb-0">
          <% @drop_off_site.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="dash-category-card mb-4">
      <div class="mb-3">
        <%= f.label :contact_name, class: "form-label fw-semibold" %>
        <%= f.text_field :contact_name, class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.label :phone_number, class: "form-label fw-semibold" %>
        <%= f.text_field :phone_number, class: "form-control" %>
      </div>
      <div class="mb-4">
        <%= f.label :notes, "Notes (access codes, special instructions, etc.)", class: "form-label fw-semibold" %>
        <%= f.text_area :notes, rows: 4, class: "form-control" %>
      </div>
      <div class="fad-action-bar">
        <%= f.submit "Save changes", class: "fad-action-btn" %>
        <%= link_to "Cancel", drop_off_site_manager_path(@drop_off_site), class: "fad-pill-link" %>
      </div>
    </div>
  <% end %>
</div>
