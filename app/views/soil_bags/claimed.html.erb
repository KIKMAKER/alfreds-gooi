<div class="soil-bag">
  <div class="soil-bag__card">
    <i class="fa-solid fa-circle-check soil-bag__icon soil-bag__icon--done"></i>

    <h1 class="soil-bag__title">Lekker — it's on the van</h1>
    <p class="soil-bag__lede">
      Alfred will hand you your bag of compost on
      <strong><%= @collection.date.strftime("%A, %-d %B") %></strong>,
      along with your usual collection.
    </p>
    <p class="soil-bag__note">Enjoy the garden. Nothing to pay.</p>
  </div>
</div>
