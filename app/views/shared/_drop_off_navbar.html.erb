<div class="navbar-container admin-navbar">
  <div class="inner-container">
    <%= link_to root_path do %>
      <%= image_tag('gooi_logo_CR.svg', class: 'gooi-logo') %>
    <% end %>
    <div class="links-container" style="margin-left: auto;">
      <% if user_signed_in? && current_user.drop_off? && current_user.drop_off_sites.any? %>
        <%= link_to current_user.drop_off_sites.first.name,
              drop_off_site_manager_path(current_user.drop_off_sites.first),
              class: "link-title" %>
        <%= link_to "Account", edit_user_registration_path, class: "link-title" %>
      <% end %>
      <%= link_to "Log Out", destroy_user_session_path,
            data: { turbo_method: :delete }, class: "new-nav-auth-btn" %>
    </div>
  </div>
</div>
