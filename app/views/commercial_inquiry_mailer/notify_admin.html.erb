<h2>New Commercial Inquiry</h2>

<h3>Contact Information</h3>
<p><strong>Name:</strong> <%= @user.first_name %> <%= @user.last_name %></p>
<p><strong>Email:</strong> <%= @user.email %></p>
<p><strong>Phone:</strong> <%= @user.phone_number %></p>

<h3>Business Details</h3>
<p><strong>Business Name:</strong> <%= @inquiry.business_name %></p>
<p><strong>Business Address:</strong><br><%= simple_format(@inquiry.business_address) %></p>

<h3>Requirements</h3>
<p><strong>Estimated Buckets per Collection:</strong> <%= @inquiry.estimated_buckets %> x 45L buckets</p>
<p><strong>Collection Frequency:</strong> <%= @inquiry.collection_frequency %></p>
<p><strong>Preferred Contract Duration:</strong> <%= @inquiry.preferred_duration %> months</p>

<% if @inquiry.additional_notes.present? %>
  <h3>Additional Notes</h3>
  <p><%= simple_format(@inquiry.additional_notes) %></p>
<% end %>

<%
  notes_prefill = "#{@inquiry.estimated_buckets} x 45L buckets, #{@inquiry.collection_frequency}, #{@inquiry.preferred_duration}-month contract."
  notes_prefill += " #{@inquiry.additional_notes}" if @inquiry.additional_notes.present?
  quote_url = new_admin_quotation_url(quotation: {
    prospect_name:    "#{@user.first_name} #{@user.last_name}",
    prospect_email:   @user.email,
    prospect_phone:   @user.phone_number,
    prospect_company: @inquiry.business_name,
    duration_months:  @inquiry.preferred_duration,
    notes:            notes_prefill
  })
%>

<p><a href="mailto:<%= @user.email %>">Reply to <%= @user.first_name %></a></p>
<p><a href="<%= quote_url %>">→ Create Quotation for <%= @inquiry.business_name %></a></p>
<p><a href="<%= admin_commercial_inquiry_url(@inquiry) %>">→ View inquiry in admin</a></p>
