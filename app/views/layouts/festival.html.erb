<!DOCTYPE html>
<html>
  <head>
    <title>Waste Tracker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/service-worker', { scope: '/festival/' })
      }
    </script>
  </head>

  <body class="festival-body" data-controller="festival-offline">

    <%# Offline banner — shown automatically when navigator.onLine is false %>
    <div class="festival-offline-bar"
         data-festival-offline-target="offlineBar"
         hidden>
      You're offline — entries will sync when signal returns.
    </div>

    <div class="festival-header">
      <%= link_to root_path, class: "festival-header__logo-link" do %>
        <%= image_tag "gooi_logo_CR.svg", class: "festival-header__logo", alt: "Gooi" %>
      <% end %>
      <span class="festival-header__title">Waste Tracker</span>
      <div class="festival-header__right">
        <span class="festival-badge"
              data-festival-offline-target="badge"
              hidden></span>
        <% if user_signed_in? && current_user.admin? %>
          <%= link_to "← Admin", admin_festival_events_path,
                class: "festival-header__logout" %>
        <% elsif session[:festival_participant_id].present? %>
          <%= link_to "Log out",
                festival_session_path("current"),
                data: { turbo_method: :delete },
                class: "festival-header__logout" %>
        <% end %>
      </div>
    </div>

    <% if notice %>
      <div class="alert alert-info alert-dismissible fade show m-2" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-warning alert-dismissible fade show m-2" role="alert">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <div class="festival-content">
      <%= yield %>
    </div>

  </body>
</html>
