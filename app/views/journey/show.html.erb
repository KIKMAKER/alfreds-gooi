<% content_for :meta_title, "#{@display_name}'s gooi journey" %>

<div class="journey">

  <%# ══════════════════════════════════════════════════════════
      SLIDE 1 — Cover
  ══════════════════════════════════════════════════════════ %>
  <section class="journey-slide journey-slide--cover">
    <div class="journey-slide__decor journey-slide__decor--1"></div>
    <div class="journey-slide__decor journey-slide__decor--2"></div>

    <div class="journey-slide__inner">
      <%= image_tag "gooi_logo_icon_white.svg", class: "journey-logo", alt: "gooi" %>

      <h1 class="journey-cover__title">
        <%= @display_name %>'s<br>gooi journey
      </h1>

      <% if @stat_start_date %>
        <div class="journey-pill">
          Collecting since <%= @stat_start_date.strftime("%-d %B %Y") %>
        </div>

        <p class="journey-cover__sub">
          <%= @stat_months_active %> <%= "month".pluralize(@stat_months_active) %> of diverting food waste from landfill
        </p>
      <% end %>
    </div>

    <div class="journey-scroll-hint">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 16l-6-6h12l-6 6z"/></svg>
      <span>scroll</span>
    </div>
  </section>

  <%# ══════════════════════════════════════════════════════════
      SLIDE 2 — Headline impact
  ══════════════════════════════════════════════════════════ %>
  <section class="journey-slide journey-slide--impact">
    <div class="journey-slide__inner">
      <p class="journey-eyebrow">Diverted from landfill</p>

      <div class="journey-impact__hero">
        <span class="journey-impact__number"><%= number_with_delimiter(@stat_input_kg.to_i) %></span>
        <span class="journey-impact__unit">kg</span>
      </div>

      <p class="journey-impact__co2">
        <%= number_with_delimiter(@stat_co2e_kg) %>kg of CO₂e not released
      </p>

      <div class="journey-pill journey-pill--amber">
        ≈ <%= number_with_delimiter(@stat_km_equivalent) %>km off the road
      </div>

      <div class="journey-impact__divider"></div>

      <p class="journey-impact__context">
        That's the equivalent of driving from Cape Town to
        <% km = @stat_km_equivalent %>
        <% if km < 500 %>
          Hermanus and back
        <% elsif km < 1500 %>
          Johannesburg
        <% elsif km < 4000 %>
          Johannesburg and back, twice
        <% else %>
          around the country, <%= (km / 3000.0).round %> times over
        <% end %>
        — in emissions avoided.
      </p>
    </div>
  </section>

  <%# ══════════════════════════════════════════════════════════
      SLIDE 3 — The numbers
  ══════════════════════════════════════════════════════════ %>
  <section class="journey-slide journey-slide--numbers">
    <div class="journey-slide__inner">
      <p class="journey-eyebrow">The numbers</p>
      <h2 class="journey-section-title">What the data says</h2>

      <div class="journey-stats-grid">
        <div class="journey-stat-card">
          <span class="journey-stat-card__value"><%= number_with_delimiter(@stat_total_collections) %></span>
          <span class="journey-stat-card__label">collections</span>
        </div>

        <div class="journey-stat-card">
          <span class="journey-stat-card__value"><%= number_with_delimiter(@stat_total_litres.round) %>L</span>
          <span class="journey-stat-card__label">total volume</span>
        </div>

        <div class="journey-stat-card">
          <span class="journey-stat-card__value"><%= number_with_delimiter(@stat_co2e_kg) %>kg</span>
          <span class="journey-stat-card__label">CO₂e avoided</span>
        </div>

        <div class="journey-stat-card">
          <span class="journey-stat-card__value"><%= @stat_consistency_rate %>%</span>
          <span class="journey-stat-card__label">consistency</span>
        </div>
      </div>

      <% if @stat_start_date %>
        <div class="journey-timeline">
          <div class="journey-timeline__dot"></div>
          <div class="journey-timeline__line">
            <span class="journey-timeline__label"><%= @stat_months_active %> <%= "month".pluralize(@stat_months_active) %></span>
          </div>
          <div class="journey-timeline__dot journey-timeline__dot--today"></div>
          <div class="journey-timeline__dates">
            <span><%= @stat_start_date.strftime("%b %Y") %></span>
            <span>Today</span>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# ══════════════════════════════════════════════════════════
      SLIDE 4 — Commitment
  ══════════════════════════════════════════════════════════ %>
  <section class="journey-slide journey-slide--commitment">
    <div class="journey-slide__decor journey-slide__decor--1"></div>
    <div class="journey-slide__decor journey-slide__decor--2"></div>

    <div class="journey-slide__inner">
      <p class="journey-eyebrow journey-eyebrow--light">
        <%= @has_active_subscription ? "Investment to date" : "Total investment" %>
      </p>

      <div class="journey-commitment__hero">
        R<%= number_with_delimiter(@stat_total_paid.to_i) %>
      </div>

      <p class="journey-commitment__sub">
        invested in sustainable waste management
      </p>

      <p class="journey-commitment__breakdown">
        <% if @stat_cost_per_collection %>
          <% if @has_active_subscription %>~<% end %>R<%= number_with_delimiter(@stat_cost_per_collection) %> per collection<% if @has_active_subscription %> (est.)<% end %>
          &nbsp;·&nbsp;
        <% end %>
        <%= number_with_delimiter(@stat_total_collections) %> collections to date
        <% if @stat_months_active %>
          &nbsp;·&nbsp; <%= @stat_months_active %> <%= "month".pluralize(@stat_months_active) %>
        <% end %>
      </p>

      <div class="journey-rule"></div>

      <div class="journey-footer-brand">
        <%= image_tag "gooi_logo_icon_amber.svg", class: "journey-footer-brand__icon", alt: "gooi" %>
        <span class="journey-footer-brand__text">Powered by gooi · gooi.me</span>
      </div>
    </div>
  </section>

</div>
