<div class="drivers-day-container">

  <%# ── Header ── %>
  <div class="dd-header">
    <div>
      <h1 class="dd-header__title"><%= link_to @subscription.display_name, admin_subscription_path(@subscription) %></h1>
      <p class="dd-header__sub"><%= @subscription.street_address %></p>
    </div>
    <div class="dd-header__actions">
      <%= link_to @return_to, class: "btn-secondary-outline btn-sm" do %>
        <i class="fa-solid fa-arrow-left"></i> Back
      <% end %>
      <% _wa_recipient = @subscription.primary_contact || @subscription.user %>
      <%= link_to "https://wa.me/#{_wa_recipient.phone_number.gsub(/\D/, '')}", target: :_blank, class: "btn-yellow btn-sm" do %>
        <i class="fa-brands fa-whatsapp whatsapp-icon"></i>
      <% end %>
    </div>
  </div>

  <%# ── Quick messages ── %>
  <div class="dd-form-card">
    <div class="dd-form-card__header">
      <i class="fa-brands fa-whatsapp"></i>
      <h3>Quick messages</h3>
    </div>
    <div class="dd-form-card__body p-0">

      <%# Primary contact (falls back to user if no contact exists) %>
      <% user = @subscription.primary_contact || @subscription.user %>
      <% first = user.first_name %>
      <div class="quick-msg-row">
        <span class="quick-msg-row__name"><%= first %></span>
        <div class="quick-msg-row__actions">
          <%= link_to user.generate_whatsapp_link("Hello #{first}, I'm on my way!"),
                      target: :_blank, class: "quick-msg-btn", title: "On my way" do %>
            🚗
          <% end %>
          <%= link_to user.generate_whatsapp_link("Hello #{first}, I'm here to collect your gooi!"),
                      target: :_blank, class: "quick-msg-btn", title: "I'm here" do %>
            🏠
          <% end %>
          <%= link_to user.generate_whatsapp_link("Thank you #{first}, I've got your gooi. Hope you have a wonderful week!"),
                      target: :_blank, class: "quick-msg-btn", title: "Done, thanks" do %>
            🪴
          <% end %>
        </div>
      </div>

      <% rem = @subscription.remaining_collections %>
      <% if rem %>
        <% remaining_display = [rem, 0].max %>
        <% collected = @subscription.total_collections %>
        <% sub_desc = @subscription.once_off? ? "once-off subscription" : "#{@subscription.duration} month subscription" %>
        <% wa_msg = "Hello #{first}, you have #{remaining_display} gooi collections remaining on this #{sub_desc}. We have collected #{collected} times. Click www.gooi.me/subscriptions/new to resubscribe." %>
        <div class="quick-msg-row">
          <span class="quick-msg-row__name">Collections remaining: <strong><%= remaining_display %></strong></span>
          <div class="quick-msg-row__actions">
            <%= link_to user.generate_whatsapp_link(wa_msg),
                        target: :_blank, class: "quick-msg-btn", title: "Send renewal reminder" do %>
              📅
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Notes (access code + kiki note) ── %>
  <% if @subscription.access_code.present? || !@collection.kiki_note_nil_zero? %>
    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-note-sticky"></i>
        <h3>Notes</h3>
      </div>
      <div class="dd-form-card__body">
        <% if @subscription.access_code.present? %>
          <p class="mb-1"><strong>Access code:</strong> <%= @subscription.access_code %></p>
        <% end %>
        <% unless @collection.kiki_note_nil_zero? %>
          <p class="mb-0"><%= @collection.kiki_note %></p>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Free compost bag claimed via the promo link ── %>
  <% if @collection.soil_bag_claimed? %>
    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-seedling"></i>
        <h3>Hand over <%= pluralize(@collection.soil_bag, 'compost bag') %></h3>
      </div>
      <div class="dd-form-card__body">
        <p class="mb-0">Claimed from the free compost promo — nothing to collect.</p>
      </div>
    </div>
  <% end %>

  <%# ── Orders to deliver ── %>
  <% if @orders.any? %>
    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-box"></i>
        <h3>Orders to deliver</h3>
      </div>
      <div class="dd-form-card__body">
        <% @orders.each do |order| %>
          <div class="dd-order-item">
            <% order.order_items.each do |item| %>
              <p class="mb-1"><strong><%= item.quantity %>×</strong> <%= item.product.title %></p>
            <% end %>
            <div class="dd-order-item__actions">
              <%= button_to "Mark ##{order.id} Delivered",
                            mark_delivered_order_path(order),
                            method: :post,
                            class: "btn-yellow btn-sm",
                            data: { turbo_confirm: "Confirm delivery of order ##{order.id}?" } %>
              <%= button_to "Postpone",
                            postpone_delivery_order_path(order),
                            method: :post,
                            class: "btn-secondary-outline btn-sm",
                            data: { turbo_confirm: "Postpone order ##{order.id} to next week's collection?" } %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Collection form ── %>
  <% submit_label = @collection.new_customer ? 'Dropped Off!' : 'Done!' %>

  <%= simple_form_for [@collection] do |f| %>

    <%# ── Skip card — prominent, at top of form ── %>
    <div class="dd-form-card <%= 'dd-form-card--skip-active' if @collection.skip? %>">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-ban"></i>
        <h3>Skip this collection<% if @collection.skip? %> — currently skipped<% end %></h3>
      </div>
      <div class="dd-form-card__body">
        <% if @collection.skip? %>
          <p class="dd-skip-notice">This collection is marked as skipped. Uncheck below to collect.</p>
        <% end %>
        <%= f.input :skip, label: "Skip this collection", wrapper_html: { class: "mb-2" } %>
        <% if @subscription.holiday_start.present? %>
          <p class="dd-holiday-badge">
            <i class="fa-solid fa-umbrella-beach"></i>
            On holiday: <strong><%= @subscription.holiday_start.strftime("%-d %b") %></strong> – <strong><%= @subscription.holiday_end.strftime("%-d %b") %></strong>
            <button type="button" class="dd-holiday-badge__edit" data-bs-toggle="modal" data-bs-target="#holidayModal">Edit</button>
          </p>
        <% else %>
          <button type="button" class="dd-holiday-link" data-bs-toggle="modal" data-bs-target="#holidayModal">
            <i class="fa-solid fa-umbrella-beach"></i> Set holiday dates
          </button>
        <% end %>
      </div>
    </div>

    <%# Count card — what did you collect? %>
    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-scale-balanced"></i>
        <h3><%= @collection.new_customer ? "Starter kit delivery" : "What did you collect?" %></h3>
      </div>
      <div class="dd-form-card__body">
        <% if current_user.admin? %>
          <% if @subscription.user.drop_off? %>
            <div class="bucket-scale-wrap">
              <label class="bucket-scale-label">Buckets dropped off</label>
              <%= f.input_field :dropped_off_buckets, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
            </div>
          <% end %>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">Bags</label>
            <%= f.input_field :bags, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">XL Buckets</label>
            <%= f.input_field :buckets, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">45L Buckets</label>
            <%= f.input_field :buckets_45l, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">25L Buckets</label>
            <%= f.input_field :buckets_25l, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
        <% elsif @subscription.user.drop_off? %>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">Buckets dropped off</label>
            <%= f.input_field :dropped_off_buckets, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
        <% elsif @subscription.Commercial? %>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">45L buckets</label>
            <%= f.input_field :buckets_45l, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">25L buckets</label>
            <%= f.input_field :buckets_25l, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
        <% elsif @subscription.XL? %>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">Buckets collected</label>
            <%= f.input_field :buckets, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
        <% else %>
          <div class="bucket-scale-wrap">
            <label class="bucket-scale-label">Bags collected</label>
            <%= f.input_field :bags, as: :integer, min: 0, placeholder: "0", class: "bucket-scale-input" %>
          </div>
        <% end %>

      </div>
    </div>

    <%# Message for Kiki %>
    <div class="dd-form-card">
      <div class="dd-form-card__header">
        <i class="fa-solid fa-comment"></i>
        <h3>Message for Kiki</h3>
      </div>
      <div class="dd-form-card__body">
        <%= f.input :alfred_message, as: :text, label: false,
                    input_html: { placeholder: "Any notes for Kiki?", rows: 3, class: "form-control" } %>
      </div>
    </div>

    <%# Admin tools %>
    <% if current_user.admin? %>
      <div class="dd-form-card">
        <div class="dd-form-card__header">
          <i class="fa-solid fa-screwdriver-wrench"></i>
          <h3>Admin</h3>
        </div>
        <div class="dd-form-card__body">
          <%= f.input :kiki_note, as: :text, label: "Message for Alfred" %>
          <%= f.input :date %>
          <%= f.input :position, label: "Route position", as: :integer,
                      hint: "Order within the driver's day route" %>
          <p class="text-muted small mb-1">Subscription IDs for this user:</p>
          <p class="text-muted small mb-3"><%= @subscription.user.subscriptions.map(&:id).join(', ') %></p>
          <%= f.input :subscription_id %>

        </div>
      </div>
    <% end %>

    <div class="mt-2 mb-4">
      <%= f.submit submit_label, class: "submit-btn w-100" %>
    </div>

  <% end %>

  <%# ── Issue bag rolls ── %>
  <div class="dd-form-card">
    <div class="dd-form-card__header">
      <i class="fa-solid fa-bag-shopping"></i>
      <h3>Issue bag rolls</h3>
    </div>
    <div class="dd-form-card__body">
      <p class="text-muted mb-3">Issue compost bag rolls to this customer and generate an invoice with a SnapScan payment link.</p>
      <%= form_with url: create_bags_invoice_collection_path(@collection), method: :post, local: true do |bf| %>
        <div class="bucket-scale-wrap mb-3">
          <label class="bucket-scale-label" for="rolls_input">Number of rolls</label>
          <input type="number" id="rolls_input" name="rolls" value="1" min="1" max="20" class="bucket-scale-input" style="width: 80px">
        </div>
        <%= bf.submit "Issue & create invoice →", class: "btn-yellow btn-sm" %>
      <% end %>
    </div>
  </div>

</div>

<%# Holiday dates modal %>
<div class="modal fade" id="holidayModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-umbrella-beach me-2"></i>Holiday dates</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <%= form_with url: holiday_dates_subscription_path(@subscription), method: :patch, data: { turbo: false } do |hf| %>
        <div class="modal-body">
          <% if @subscription.holiday_start.present? %>
            <p class="text-muted small mb-3">
              Currently: <strong><%= @subscription.holiday_start.strftime("%-d %b") %> – <%= @subscription.holiday_end.strftime("%-d %b") %></strong>
            </p>
          <% end %>
          <div class="mb-3">
            <label class="form-label">Holiday start</label>
            <%= hf.text_field "subscription[holiday_start]", value: @subscription.holiday_start&.strftime("%Y-%m-%d") || Date.today.strftime("%Y-%m-%d"), class: "form-control", data: { controller: "datepicker" } %>
          </div>
          <div class="mb-3">
            <label class="form-label">Holiday end</label>
            <%= hf.text_field "subscription[holiday_end]", value: @subscription.holiday_end&.strftime("%Y-%m-%d") || (Date.today + 7).strftime("%Y-%m-%d"), class: "form-control", data: { controller: "datepicker" } %>
          </div>
        </div>
        <div class="modal-footer">
          <% if @subscription.holiday_start.present? %>
            <%= link_to "Clear holiday", clear_holiday_subscription_path(@subscription),
                        class: "btn btn-outline-danger btn-sm me-auto",
                        data: { turbo_method: :post, turbo_confirm: "Remove holiday dates?" } %>
          <% end %>
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <%= hf.submit "Save dates", class: "btn-yellow btn-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
