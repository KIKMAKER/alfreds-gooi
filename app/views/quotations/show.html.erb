<div class="invoice-wrapper">
  <div class="invoice-container">
    <div class="d-flex justify-content-between align-items-center mb-4 link-decoration">
      <h1 class="mb-0">Quotation</h1>
      <% if current_user&.admin? %>
        <div class="d-flex gap-2">
          <%= link_to "Edit Quotation", edit_admin_quotation_path(@quotation), class: "link-text me-3" %>
          <%= link_to "View PDF", pdf_quotation_path(@quotation), class: "btn btn-secondary-outline", target: "_blank" %>
          <%= link_to "Send Quotation Email", send_email_admin_quotation_path(@quotation), class: "small-yellow-btn", data: { turbo_method: :get, turbo_confirm: "Send quotation email to #{@quotation.customer_email}?" } %>
        </div>
      <% end %>
    </div>

    <% if current_user&.admin? %>
      <div class="outline p-3 mb-4" style="background: linear-gradient(135deg, rgba(245, 177, 26, 0.1) 0%, rgba(245, 177, 26, 0.2) 100%); border-left: 4px solid rgb(245, 177, 26);">
        <h5 class="mb-3" style="color: rgb(200, 140, 20);">Quotation Status</h5>
        <div class="d-flex align-items-center gap-3">
          <span class="badge bg-<%= status_color(@quotation.status) %> fs-6">
            <%= @quotation.status.titleize %>
          </span>
          <% if @quotation.expired? %>
            <span class="badge bg-danger fs-6">Expired</span>
          <% end %>
          <% if @quotation.expired? && !@quotation.accepted? && !@quotation.rejected? %>
            <%= link_to "Extend Expiry (+30 days)", extend_expiry_admin_quotation_path(@quotation),
                class: "btn btn-sm btn-secondary-outline",
                data: { turbo_method: :post, turbo_confirm: "Extend this quote's expiry by 30 days?" } %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="user-details ms-1">
      <div class="user me-4">
        <p><strong>For:</strong> <%= @quotation.customer_name %></p>
        <p><strong>Email:</strong> <%= @quotation.customer_email %></p>
        <% if @quotation.user.present? %>
          <p><strong>Phone:</strong> <%= @quotation.user.phone_number %></p>
          <% if @quotation.user.subscriptions.any? %>
            <p><strong>Customer ID:</strong> <%= @quotation.user.subscriptions.last.customer_id %></p>
          <% end %>
        <% else %>
          <% if @quotation.prospect_phone.present? %>
            <p><strong>Phone:</strong> <%= @quotation.prospect_phone %></p>
          <% end %>
          <% if @quotation.prospect_company.present? %>
            <p><strong>Company:</strong> <%= @quotation.prospect_company %></p>
          <% end %>
        <% end %>
        <p><strong>Quote Date:</strong> <%= @quotation.created_date.strftime('%A, %b %d, %Y') %></p>
        <p><strong>Valid Until:</strong> <%= @quotation.expires_at.strftime('%A, %b %d, %Y') %>
          <% if @quotation.expired? %>
            <span class="badge bg-danger ms-2">Expired</span>
          <% end %>
        </p>
      </div>
      <% if @quotation.notes.present? %>
        <div class="business">
          <p><strong>Notes:</strong></p>
          <p><%= @quotation.notes %></p>
        </div>
      <% end %>
    </div>

    <div class="invoice-table">
      <div class="header">
        <div class="quantity-description">
          <div class="quantity">
            <h1>Quantity</h1>
          </div>
          <h1>Item</h1>
        </div>
        <h1>Amount</h1>
      </div>
      <% @quotation.quotation_items.each do |item| %>
        <div class="invoice-item">
          <div class="quantity-description">
            <div class="quantity">
              <p><%= item.quantity.to_i %></p>
            </div>
            <p><%= item.product.title %> <% if item.quantity > 1 %>(R<%= item.amount.truncate %> each)<% end %></p>
          </div>
          <p>R<%= (item.amount * item.quantity).truncate %></p>
        </div>
      <% end %>
    </div>

    <div class="invoice-total">
      <p>Total: R<%= @quotation.total_amount.truncate %></p>
    </div>

    <% if @quotation.event? %>
      <div class="ms-1 mt-2">
        <% if @quotation.event_name.present? %>
          <p class="text-muted" style="font-size: 0.9em;"><strong>Event:</strong> <%= @quotation.event_name %></p>
        <% end %>
        <% if @quotation.event_date.present? %>
          <p class="text-muted" style="font-size: 0.9em;"><strong>Date:</strong> <%= @quotation.event_date.strftime('%A, %b %d, %Y') %></p>
        <% end %>
        <% if @quotation.event_venue.present? %>
          <p class="text-muted" style="font-size: 0.9em;"><strong>Venue:</strong> <%= @quotation.event_venue %></p>
        <% end %>
      </div>
    <% else %>
      <div class="ms-1 mt-2">
        <p class="text-muted" style="font-size: 0.9em;">Monthly equivalent: R<%= @quotation.monthly_rate %>/month</p>
        <p class="text-muted" style="font-size: 0.9em;">Weekly equivalent: R<%= @quotation.weekly_rate %>/week</p>
        <% if @quotation.ongoing_weekly_rate != @quotation.weekly_rate %>
          <p class="text-muted" style="font-size: 0.9em; font-style: italic;">Ongoing rate (once starters paid off): R<%= @quotation.ongoing_monthly_rate %>/month or R<%= @quotation.ongoing_weekly_rate %>/week</p>
        <% end %>
      </div>
    <% end %>

    <div class="text-center my-4">
      <%= link_to "Download PDF", pdf_quotation_path(@quotation), class: "small-yellow-btn", target: "_blank" %>
    </div>

    <% if @quotation.accepted? %>
      <div class="payment-container">
        <h2>Quotation Accepted</h2>
        <p>Thank you — we've received your acceptance and will be in touch shortly to get your service set up.</p>
        <% if current_user&.admin? %>
          <div class="text-center mt-3">
            <% if (subscription = @quotation.created_subscription) %>
              <%= link_to "View Subscription ##{subscription.id}", admin_subscription_path(subscription), class: "btn btn-secondary-outline" %>
            <% elsif @quotation.user.present? %>
              <%= link_to "Create Subscription from this Quote",
                  new_admin_subscription_path(user_id: @quotation.user_id, quotation_id: @quotation.id),
                  class: "small-yellow-btn" %>
            <% else %>
              <p class="text-muted small mb-0">This quote isn't linked to a customer account yet — add one via Edit Quotation before creating a subscription.</p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% elsif !@quotation.expired? %>
      <div class="payment-container">
        <h2>Ready to proceed?</h2>
        <p class="mb-3">If you'd like to accept this quotation, click below and we'll be in touch to get your service set up.</p>
        <div class="text-center mb-4">
          <%= button_to "I Accept This Quotation",
              accept_quotation_path(@quotation),
              method: :post,
              class: "small-yellow-btn",
              data: { turbo_confirm: "Accept quotation ##{@quotation.number} for R#{@quotation.total_amount.to_i}? We'll be notified and follow up with you shortly." } %>
        </div>
        <hr>
        <p class="mt-3 mb-1"><strong>Questions?</strong></p>
        <p class="mb-1"><strong>Email:</strong> howzit@gooi.me</p>
        <p class="mb-0"><strong>Phone:</strong> +27 78 532 5513</p>
      </div>
    <% end %>
  </div>
</div>
