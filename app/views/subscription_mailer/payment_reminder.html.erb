<div style="font-family: Arial, sans-serif; color: #1f4632; padding: 2rem;">
  <h1 style="font-size: 2rem; font-weight: bold; margin-bottom: 0.5rem;">
    <% if @stage == :day_3 %>
      Your gooi invoice is waiting
    <% elsif @stage == :day_7 %>
      Ready to start gooiing?
    <% else %>
      Your gooi subscription is waiting for you
    <% end %>
  </h1>

  <p style="font-size: 1.1rem; margin-top: 1rem;">
    Hi <%= @subscription.user.first_name %>,
  </p>

  <% if @stage == :day_3 %>
    <p style="font-size: 1.1rem;">
      Just a reminder that your gooi invoice is still waiting. Pay now to lock in your first collection and get your starter kit on the way.
    </p>
  <% elsif @stage == :day_7 %>
    <p style="font-size: 1.1rem;">
      Your gooi subscription is still pending payment. Once payment clears, we'll get your collections scheduled and your starter kit delivered.
    </p>
  <% else %>
    <p style="font-size: 1.1rem;">
      Are you still interested in gooiing your kitchen scraps? Pay today to keep your spot — we'd love to help you manage your organic waste!
    </p>
  <% end %>

  <% if @invoice %>
    <p style="font-size: 1.1rem;">
      <strong>Invoice #<%= @invoice.number %></strong><br>
      Amount: <strong>R<%= number_with_precision(@invoice.total_amount, precision: 2) %></strong><br>
      Issued: <%= @invoice.issued_date.strftime('%-d %B %Y') %><br>
      Due: <%= @invoice.due_date.strftime('%-d %B %Y') %>
    </p>
  <% end %>

  <p style="margin: 2rem 0;">
    <a href="<%= manage_url %>"
       style="background-color: #FBB718; color: white; padding: 10px 20px; border-radius: 40px; text-decoration: none; font-weight: bold;">
      Pay My Invoice
    </a>
  </p>

  <p style="font-size: 1.1rem;">
      Unsure about something or have something to chat about? Reply to this email and we'll get back to you shortly.
    </p>
     <p style="font-size: 1.1rem;">
     Looking forward to welcoming you to the gooi family!
    </p>

  <p style="font-size: 1.1rem;">Kristen</p>
  <%= image_tag image_url('email-signature.png'), alt: "Kristen Kennedy email signature", style: "max-width: 250px; margin-top: 10px;" %>
</div>
