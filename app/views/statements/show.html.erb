<div class="subscription-show-container">

  <!-- Header -->
  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-scroll"></i>
      </div>
      <div>
        <h1>Statement</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          <%= @user.first_name %> <%= @user.last_name %> &middot; <%= Date.today.strftime('%d %b %Y') %>
        </p>
      </div>
    </div>
    <% if current_user.admin? %>
      <%= button_to send_email_statement_path(@user), method: :post,
          class: "tiny-yellow-btn",
          style: "background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); color: white; white-space: nowrap;",
          form: { data: { turbo_confirm: "Send statement to #{@user.email}?" } } do %>
        <i class="fa-solid fa-paper-plane"></i> Email
      <% end %>
    <% end %>
  </div>

  <!-- Summary -->
  <div class="info-card mb-3">
    <div class="info-card-body" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; padding: 1rem 0;">
      <div class="text-center" style="border-right: 1px solid #f0f0f0; padding: 0.5rem 0.75rem;">
        <div style="font-size: 1.1rem; font-weight: 700; color: #023F3A; font-family: 'Montserrat', sans-serif;">
          R<%= number_with_delimiter(@total_invoiced.to_i) %>
        </div>
        <div style="font-size: 0.7rem; color: #888; margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Invoiced</div>
      </div>
      <div class="text-center" style="border-right: 1px solid #f0f0f0; padding: 0.5rem 0.75rem;">
        <div style="font-size: 1.1rem; font-weight: 700; color: #3c8a63; font-family: 'Montserrat', sans-serif;">
          R<%= number_with_delimiter(@total_paid.to_i) %>
        </div>
        <div style="font-size: 0.7rem; color: #888; margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Paid</div>
      </div>
      <div class="text-center" style="padding: 0.5rem 0.75rem;">
        <div style="font-size: 1.1rem; font-weight: 700; color: <%= @balance_owing > 0 ? '#bc4749' : '#3c8a63' %>; font-family: 'Montserrat', sans-serif;">
          R<%= number_with_delimiter(@balance_owing.to_i) %>
        </div>
        <div style="font-size: 0.7rem; color: #888; margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Owing</div>
      </div>
    </div>
  </div>

  <!-- Invoices -->
  <% if @invoices.any? %>
    <div class="info-card mb-3">
      <div class="info-card-header">
        <i class="fa-solid fa-list"></i>
        <h3>Invoices</h3>
      </div>
      <div class="info-card-body" style="padding: 0;">
        <% @invoices.each do |invoice| %>
          <% subscription = invoice.subscription %>
          <%= link_to invoice_path(invoice), style: "text-decoration: none; color: inherit;" do %>
            <div class="info-row" style="padding: 0.875rem 1.5rem; cursor: pointer;">
              <div class="d-flex flex-column gap-1">
                <span style="font-weight: 600; color: #023F3A; font-size: 0.875rem;">
                  <%= invoice.issued_date&.strftime('%d %b %Y') || 'N/A' %>
                </span>
                <span style="font-size: 0.75rem; color: #888;">
                  #<%= invoice.number || invoice.id %>
                  &middot; <%= subscription.plan %>
                  <% if invoice.due_date %>
                    &middot; due <%= invoice.due_date.strftime('%d %b') %>
                  <% end %>
                </span>
              </div>
              <div class="d-flex align-items-center gap-2">
                <span style="font-weight: 700; font-family: 'Montserrat', sans-serif; color: #023F3A; font-size: 0.95rem;">
                  R<%= number_with_delimiter(invoice.total_amount.to_i) %>
                </span>
                <% if invoice.paid? %>
                  <span class="subscription-status-badge active" style="font-size: 0.7rem; padding: 2px 8px;">Paid</span>
                <% else %>
                  <span class="subscription-status-badge paused" style="font-size: 0.7rem; padding: 2px 8px;">Unpaid</span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="info-card mb-3 text-center">
      <div class="info-card-body">
        <p class="text-muted mb-0">No invoices on this account.</p>
      </div>
    </div>
  <% end %>

  <!-- Payment details -->
  <% if @balance_owing > 0 %>
    <div class="info-card">
      <div class="info-card-header" style="background: linear-gradient(135deg, #fff3cd 0%, #ffeeba 100%); border-bottom-color: #fde68a;">
        <i class="fa-solid fa-landmark" style="color: #856404;"></i>
        <h3 style="color: #856404;">Make a Payment</h3>
      </div>
      <div class="info-card-body">
        <div class="info-row">
          <span class="info-label">Bank</span>
          <span class="info-value">FNB</span>
        </div>
        <div class="info-row">
          <span class="info-label">Account name</span>
          <span class="info-value">Gooi</span>
        </div>
        <div class="info-row">
          <span class="info-label">Account number</span>
          <span class="info-value">63066225426</span>
        </div>
        <div class="info-row">
          <span class="info-label">Branch code</span>
          <span class="info-value">250655</span>
        </div>
        <div class="info-row">
          <span class="info-label">Reference</span>
          <span class="info-value"><%= @user.id %></span>
        </div>

        <div class="mt-3">
          <%= link_to "Pay R#{@balance_owing.to_i} with SnapScan",
              "https://pos.snapscan.io/qr/8jQ1QVVb?id=#{@user.customer_id}&amount=#{@balance_owing.to_i}00",
              target: "_blank", class: "action-btn w-100 justify-content-center" %>
        </div>
      </div>
    </div>
  <% end %>

</div>
