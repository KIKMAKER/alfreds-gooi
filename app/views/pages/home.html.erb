<% content_for :meta_title, "Gooi - Organic Waste Recycling Made Easy in Cape Town" %>
<% content_for :meta_description, "Weekly doorstep collection of food scraps around Table Mountain. Join Cape Town's food waste revolution. Simple, affordable composting service for households and businesses." %>

<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Weekly Compost Collection",
  "provider": { "@id": "<%= root_url %>" },
  "areaServed": "Cape Town",
  "description": "Weekly doorstep collection of food scraps from households and businesses around Table Mountain. Affordable, easy composting — two subscription plans available.",
  "offers": [
    {
      "@type": "Offer",
      "name": "Standard Plan",
      "description": "Up to two 5L bags per week",
      "price": "180",
      "priceCurrency": "ZAR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "180",
        "priceCurrency": "ZAR",
        "unitText": "month",
        "description": "From R180/month on 6-month plan"
      }
    },
    {
      "@type": "Offer",
      "name": "XL Plan",
      "description": "One 25L bucket per week",
      "price": "240",
      "priceCurrency": "ZAR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "240",
        "priceCurrency": "ZAR",
        "unitText": "month",
        "description": "From R240/month on 6-month plan"
      }
    }
  ]
}
</script>
<% end %>

<!--header-->
<div class="page-container">
  <section class="gooi-header">
    <div class="inner-header-container mb-4">
      <h1>Organic waste recycling made easy</h1>
      <p>Gooi makes composting your food waste as easy as throwing it in the bin.
        Our goal is to divert <strong class="yellow-txt">organic waste</strong> from landfills and ensure it nourishes the earth instead.
        Gooi offers weekly collection of food scraps from your doorstep.
        Ready to join the food waste revolution?</p>
      <div class="mt-5 mb-3">
        <%= link_to 'Sign Up', '#pricing', class: 'btn-gooi' %>

      </div>
      <br>
    </div>
    <!--video-->

    <div class="video-container mt-4">
      <%= video_tag("Our_Mission_at_Soil_For_Life.mp4", class: "gooi-video", controls: true, loop: true) %>
    </div>
    <!--code to create the wave in the header section-->
    <%= raw %(
              <div class="wave-container">
                <svg
                  class="waves"
                  viewBox="0 24 150 28"
                  preserveAspectRatio="none"
                  shape-rendering="auto"
                >
                <defs>
                  <path
                  id="gentle-wave"
                  d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18 58-18 88-18 58 18 88 18v44h-352z"
                  />
                </defs>
                  <g class="parallax">
                    <use
                      href="#gentle-wave"
                      x="0"
                      y="0"
                      fill="rgba(255,255,255)"
                    />
                  </g>
                </svg>
                </div>
                ) %>
