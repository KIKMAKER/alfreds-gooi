<section class="testimonial-section">
  <h1>Testimonials</h1>
  <p class="section-subtitle">What our community says</p>
  <div class="content-wrapper" style="max-width: 960px; margin: 0 auto;">
    <% if @testimonials.count >= 3 %>
      <!-- Show 3 random new testimonials with images -->
      <div class="testimonials-container">
        <% @testimonials.sample(3).each do |testimonial| %>
          <div class="testimonial-card">
            <% if testimonial.photo.attached? %>
              <div class="testimonial-image">
                <%= image_tag testimonial.photo, alt: "#{testimonial.user.first_name}'s photo" %>
              </div>
            <% end %>
            <p><%= testimonial.content %></p>
            <h4><%= testimonial.user.first_name || "Anonymous" %></h4>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Show old static testimonials until we have 3 new ones -->
      <div class="testimonials-container">
        <div class="testimonial-card">
          <p>We love composting our waste, and Alfred is the sweetest man.</p>
          <h4>Megan</h4>
        </div>
        <div class="testimonial-card">
          <p>It's been so helpful and has really made composting so much easier and more convenient!</p>
          <h4>Simone</h4>
        </div>
        <div class="testimonial-card">
          <p>Alfred is always on time and always so kind and with a happy smile.</p>
          <h4>Ryan</h4>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!--where we collect section-->
<section class="map-section">
  <div class="container">
    <h1 class="text-center">Where we collect</h1>
    <p>
      Gooi currently offers weekly doorstep pickups around Table Mountain, with plenty room to grow! Check your neighbourhood's day and sign up so you never throw another banana peel in the bin! Can't find your suburb? Let us know below.
      <br>
      <strong>Heads-up:</strong> boundaries are indicative; if you're on the edge we'll confirm your day.
    </p>
    <br>
    <div class="mt-1 row g-4 align-items-start">
      <!-- MAP: left on desktop, first on mobile -->
      <div class="col-12 col-lg-7 service-map-square">
        <div
          data-controller="service-map"
          data-service-map-token-value="<%= Rails.application.credentials.dig(:mapbox, :public_token) || ENV['MAPBOX_API_KEY'] %>"
          data-service-map-geo-url-value="<%= asset_path('Suburbs.geojson') %>"
          data-service-map-monday-value='<%= raw Subscription::MONDAY_SUBURBS.to_json %>'
          data-service-map-tuesday-value='<%= raw Subscription::TUESDAY_SUBURBS.to_json %>'
          data-service-map-wednesday-value='<%= raw Subscription::WEDNESDAY_SUBURBS.to_json %>'
          data-service-map-thursday-value='<%= raw Subscription::THURSDAY_SUBURBS.to_json %>'>

          <div id="service-map" style="width:100%;height:420px;border-radius:12px;overflow:hidden;"></div>

          <div class="service-map-key day-key mt-2">
            <div class="map-controls d-flex flex-wrap gap-2 align-items-center">
              <p><strong>Toggle:</strong></p>
              <div class="filter-buttons gap-2">
                <button class="btn-gooi-outline" type="button" data-day-filter="all">All</button>
                <button class="btn-gooi-outline" type="button" data-day-filter="Monday">Monday</button>
                <button class="btn-gooi-outline" type="button" data-day-filter="Tuesday">Tuesday</button>
                <button class="btn-gooi-outline" type="button" data-day-filter="Wednesday">Wednesday</button>
                <button class="btn-gooi-outline" type="button" data-day-filter="Thursday">Thursday</button>
              </div>
              <div class="gap-2 align-items-center day-key" id="service-map-legend"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- CARDS: right on desktop, below on mobile -->
      <div class="col-12 col-lg-5">
        <div class="row row-cols-2 g-3">
          <div class="col">
            <div class="small-icon-card h-100">
              <div class="icon-card-header">
                <i class="fa-solid fa-route fs-4"></i>
                <span class="icon-title">Weekly collection</span>
              </div>
              <p>The gooi bakkie loops Cape Town once a week.</p>
            </div>
          </div>
          <div class="col">
            <div class="small-icon-card h-100">
              <div class="icon-card-header">
                <i class="fa-regular fa-clock fs-4"></i>
                <span class="icon-title">Consistent-ish timing</span>
              </div>
              <p>Traffic & Alfred's chats can nudge times a bit.</p>
            </div>
          </div>

          <div class="col">
            <div class="small-icon-card h-100">
              <div class="icon-card-header">
                <i class="fa-regular fa-calendar-days fs-4"></i>
                <span class="icon-title">Your day = your 'hood</span>
              </div>
              <p>See Tuesday-Thursday zones on the map.</p>
            </div>
          </div>

          <div class="col">
            <div class="small-icon-card h-100">
              <div class="icon-card-header">
                <i class="fa-regular fa-circle-check fs-4"></i>
                <span class="icon-title">Always current</span>
              </div>
              <p>Routes evolve as we grow, this map stays up to date.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

</section>

<section class="map-section" style="margin-top: 0; padding-top: 0;">
  <div class="interest-card popular mt-4">
    <h3 class="mt-4" id="interest">Think we should gooi in your 'hood?</h3>
    <p class="my-2">If your address isn't on our route yet, please leave your details so we can get to you soon! You can also spread the word to your neighbours to help the compost movement grow.</p>

    <%= simple_form_for @interest do |f| %>
      <%= f.input :name, input_html: { class: 'form-control' } %>
      <%= f.input :email, input_html: { class: 'form-control' } %>
      <%= f.input :suburb, as: :select,
            collection: Interest::SUBURBS,
            include_blank: "— select your suburb —",
            input_html: { class: 'form-select' } %>
      <%= f.input :note, as: :text,
            label: "Anything to add?",
            placeholder: "e.g. 'My whole street would sign up' or 'We have a community garden'",
            hint: "If your suburb isn't in the list, select Other and mention it here.",
            input_html: { class: 'form-control', rows: 2 },
            required: false %>
      <%= hidden_field_tag :website, nil, autocomplete: "off" %>
      <%= f.submit "Plant the seed", class: "submit-btn" %>
    <% end %>
  </div>

  <div class="text-center mt-5">
    <p class="my-3">Want to learn more about our mission, what you can compost, and where your food scraps go?</p>
    <%= link_to 'Learn More About Gooi', about_path, class: 'action-btn mt-2' %>
  </div>
</section>

</div>
