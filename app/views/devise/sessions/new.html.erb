<div class="subscription-show-container">
  <div class="info-card">
    <div class="info-card-header">
      <i class="fa-solid fa-leaf"></i>
      <h3>Log in</h3>
    </div>
    <div class="info-card-body">
      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: "false" } }) do |f| %>
        <%= f.input :email,
                required: false,
                autofocus: true,
                input_html: { autocomplete: "email", class: "form-control" } %>
        <%= f.input :password,
                required: false,
                input_html: { autocomplete: "current-password", class: "form-control" } %>
        <%= f.button :submit, "Log in", class: "action-btn w-100 mt-2" %>
      <% end %>
      <div class="mt-3 text-center" style="font-size: 0.875rem;">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
