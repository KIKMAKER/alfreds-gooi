<div class="subscription-show-container">
  <div class="info-card">
    <div class="info-card-header">
      <i class="fa-solid fa-key"></i>
      <h3>Forgot your password?</h3>
    </div>
    <div class="info-card-body">
      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>
        <%= f.input :email,
              required: true,
              autofocus: true,
              input_html: { autocomplete: "email", class: "form-control" } %>
        <%= f.button :submit, "Send reset instructions", class: "action-btn w-100 mt-2" %>
      <% end %>
      <p class="text-muted text-center mt-3" style="font-size: 0.8125rem;">
        You'll receive an email from howzit@gooi.me &mdash; check your spam folder if it doesn't arrive.
      </p>
      <div class="mt-2 text-center" style="font-size: 0.875rem;">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
