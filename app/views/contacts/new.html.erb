<div class="subscription-show-container">

  <div class="subscription-header mb-3">
    <div class="subscription-header-content">
      <div class="subscription-avatar">
        <i class="fa-solid fa-user-plus"></i>
      </div>
      <div>
        <h1>Add Contact</h1>
        <p style="color: rgba(255,255,255,0.75); margin: 0; font-size: 0.875rem;">
          They'll get WhatsApp reminders on collection day
        </p>
      </div>
    </div>
    <%= link_to subscription_contacts_path(@subscription), class: "tiny-yellow-btn",
        style: "background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); color: white; white-space: nowrap;" do %>
      <i class="fa-solid fa-arrow-left"></i> Back
    <% end %>
  </div>

  <div class="info-card">
    <div class="info-card-header">
      <i class="fa-solid fa-address-card"></i>
      <h3>Contact Details</h3>
    </div>
    <div class="info-card-body">
      <%= simple_form_for [@subscription, @contact] do |f| %>
        <div class="row g-3 mb-3">
          <div class="col-6">
            <%= f.input :first_name, required: true, label: 'First name',
                        input_html: { class: 'form-control' },
                        wrapper_html: { class: 'mb-0' } %>
          </div>
          <div class="col-6">
            <%= f.input :last_name, label: 'Last name',
                        input_html: { class: 'form-control' },
                        wrapper_html: { class: 'mb-0' } %>
          </div>
        </div>

        <%= f.input :phone_number, required: true, label: 'Phone number',
                    hint: '+27821234567 or 0821234567',
                    input_html: { class: 'form-control' } %>

        <%= f.input :relationship,
                    collection: %w[spouse housemate family housekeeper other],
                    include_blank: 'Select (optional)',
                    label: 'Relationship',
                    input_html: { class: 'form-select' } %>

        <div class="p-3 mb-3" style="background: #f8f9fa; border-radius: 12px;">
          <%= f.input :whatsapp_opt_out, as: :boolean,
                      label: 'Opt out of WhatsApp reminders',
                      wrapper_html: { class: 'mb-1' } %>
          <small class="text-muted">
            <i class="fa-brands fa-whatsapp" style="color: #25D366;"></i>
            Leave unchecked to send collection reminders
          </small>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit 'Add Contact', class: 'action-btn' %>
          <%= link_to 'Cancel', subscription_contacts_path(@subscription), class: 'action-btn',
              style: 'border-color: #ccc; color: #666;' %>
        </div>
      <% end %>
    </div>
  </div>

</div>
