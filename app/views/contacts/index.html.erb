<div class="user-wrapper">
  <div class="gooi-container">
    <div class="text-center mb-4">
      <h1>Household Contacts</h1>
      <p class="text-muted"><%= @subscription.short_address %>, <%= @subscription.suburb %></p>
    </div>

    <div class="text-center mb-4">
      <%= link_to new_subscription_contact_path(@subscription), class: 'small-yellow-btn' do %>
        <i class="fa-solid fa-user-plus"></i> Add New Contact
      <% end %>
    </div>

    <div class="contacts-grid">
      <% @contacts.each do |contact| %>
        <div class="contact-card-detailed">
          <div class="contact-card-header">
            <div class="contact-avatar">
              <i class="fa-solid fa-user"></i>
            </div>
            <div class="contact-info">
              <h4 class="contact-name"><%= contact.full_name %></h4>
              <% if contact.is_primary? %>
                <span class="contact-badge primary-badge">Owner</span>
              <% elsif contact.relationship.present? %>
                <span class="contact-badge"><%= contact.relationship.titleize %></span>
              <% end %>
            </div>
          </div>

          <div class="contact-details">
            <div class="contact-detail-row">
              <i class="fa-solid fa-phone"></i>
              <span><%= contact.phone_number %></span>
            </div>
            <div class="contact-detail-row">
              <i class="fa-brands fa-whatsapp"></i>
              <% if contact.can_receive_whatsapp? %>
                <span class="whatsapp-active"><i class="fa-solid fa-circle-check"></i> Receiving reminders</span>
              <% else %>
                <span class="whatsapp-inactive"><i class="fa-solid fa-circle-xmark"></i> Opted out</span>
              <% end %>
            </div>
          </div>

          <div class="contact-actions">
            <%= link_to edit_subscription_contact_path(@subscription, contact), class: 'tiny-yellow-btn' do %>
              <i class="fa-solid fa-pen"></i> Edit
            <% end %>

            <% if contact.whatsapp_opt_out? %>
              <%= button_to toggle_whatsapp_subscription_contact_path(@subscription, contact),
                            method: :post, class: 'tiny-yellow-btn' do %>
                <i class="fa-brands fa-whatsapp"></i> Enable WhatsApp
              <% end %>
            <% else %>
              <%= button_to toggle_whatsapp_subscription_contact_path(@subscription, contact),
                            method: :post, class: 'tiny-yellow-btn', style: 'background-color: #999;' do %>
                <i class="fa-brands fa-whatsapp"></i> Disable WhatsApp
              <% end %>
            <% end %>

            <% unless contact.is_primary? %>
              <%= button_to subscription_contact_path(@subscription, contact),
                            method: :delete, class: 'tiny-yellow-btn',
                            style: 'background-color: #bc4749;',
                            data: { turbo_confirm: 'Remove this contact? They will stop receiving WhatsApp reminders.' } do %>
                <i class="fa-solid fa-trash"></i> Remove
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-4">
      <%= link_to manage_path, class: 'submit-btn' do %>
        <i class="fa-solid fa-arrow-left"></i> Back to My Subscription
      <% end %>
    </div>
  </div>
</div>
