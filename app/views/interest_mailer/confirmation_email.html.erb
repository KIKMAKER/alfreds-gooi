<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background-color:#f5faf9;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f5faf9;padding:40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:560px;">

          <%# Header %>
          <tr>
            <td style="background-color:#023F3A;border-radius:16px 16px 0 0;padding:32px 40px;text-align:center;">
              <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:28px;font-weight:700;color:#ffffff;letter-spacing:-0.5px;">gooi</p>
              <p style="margin:6px 0 0;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.55);">Cape Town compost collection</p>
            </td>
          </tr>

          <%# Body %>
          <tr>
            <td style="background-color:#ffffff;padding:40px 40px 32px;border-radius:0 0 16px 16px;border:1px solid #e0ebe9;border-top:none;">

              <p style="margin:0 0 8px;font-size:22px;font-weight:700;color:#023F3A;font-family:Georgia,'Times New Roman',serif;line-height:1.3;">
                Seed planted, <%= @first_name %>.
              </p>
              <p style="margin:0 0 24px;font-size:15px;color:#525560;line-height:1.7;">
                Thanks for letting us know you're interested in Gooi coming to <strong style="color:#023F3A;"><%= @interest.suburb %></strong>.
                We've noted your details and we'll be in touch as soon as we expand your way.
              </p>

              <%# Summary card %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0"
                     style="background:#f5faf9;border-radius:10px;border-left:4px solid #FBB718;margin-bottom:28px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 10px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#FBB718;">Your details</p>
                    <p style="margin:0 0 4px;font-size:14px;color:#023F3A;"><strong>Name:</strong> <%= @interest.name %></p>
                    <p style="margin:0 0 4px;font-size:14px;color:#023F3A;"><strong>Suburb:</strong> <%= @interest.suburb %></p>
                    <p style="margin:0;font-size:14px;color:#023F3A;"><strong>Email:</strong> <%= @interest.email %></p>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 24px;font-size:15px;color:#525560;line-height:1.7;">
                In the meantime, if you know neighbours who'd also be keen — spread the word!
                The more people in your area, the sooner we can route the bakkie your way.
              </p>

              <%# CTA %>
              <table role="presentation" cellspacing="0" cellpadding="0" style="margin-bottom:32px;">
                <tr>
                  <td style="border-radius:32px;background-color:#023F3A;">
                    <a href="<%= root_url %>"
                       style="display:inline-block;padding:12px 32px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;letter-spacing:0.03em;">
                      Learn more about Gooi
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0;font-size:14px;color:#023F3A;line-height:1.6;">
                Cheers,<br>
                <strong>Alfred &amp; the Gooi team</strong>
              </p>

            </td>
          </tr>

          <%# Footer %>
          <tr>
            <td style="padding:24px 40px;text-align:center;">
              <p style="margin:0 0 8px;font-size:12px;color:#999;">
                You received this because you submitted an interest form at
                <a href="<%= root_url %>" style="color:#023F3A;text-decoration:none;">gooi.me</a>.
              </p>
              <p style="margin:0;font-size:12px;color:#bbb;">© Gooi, Cape Town</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
